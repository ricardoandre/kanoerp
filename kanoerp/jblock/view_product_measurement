// =====================================================
// jblock — PRODUCT MEASUREMENT  (runs on the ui_list_engine engine)
//
// Thin domain config: fetch, card layout, detail. New/Edit both come from
// dedicated Drawer source_code rows (ui_product_measurement_add /
// ui_product_measurement_edit) — same shell as production's New/Edit, so
// this now behaves like every other view in the app instead of a one-off
// Modal.confirm.
//
// Reads use ctx.api.resource() exclusively (fetchAllPages/fetchByIn), NOT raw
// ctx.sql — ctx.sql.save() is admin/root-gated and silently fails for
// non-admin roles (see the NOTE in view_production and README §3).
//
// SCHEMA:
//   product_measurement            — id, name, remarks (richText/HTML).
//   product_measurement_variant    — one row per size: id,
//     fk_product_measurement_variant_id (→ product_measurement.id),
//     belongsTo sku_option, + measurement columns (count/order defined by
//     lib_measurement_fields — see below).
//   product                        — fk_product_measurement_id (→ set).
// A measurement set's linked products and its size rows are both fetched in
// ONE fetchList() pass (batched via fetchByIn), so the card + detail views
// need no extra round trips — everything the read-only UI needs is already
// on `row`. The Edit drawer re-fetches fresh on open instead (see
// ui_product_measurement_edit), so it's never working off a stale cache.
//
// Card/detail measurement tables only show columns that actually have a
// value somewhere in that set (getPopulatedFields below) — Edit is the one
// place that always shows all fields, since that's where you'd fill blanks in.
//
// CHANGED (2026-07): the measurement field list (order + bilingual labels)
// used to be hand-maintained separately in THIS file, ui_product_measurement_add,
// ui_product_measurement_edit, AND ui_product_details — four copies of the
// same list, and one of them (ui_product_details) had silently drifted out
// of sync (missing 3 fields, only caught by manually checking against the
// schema). Now sourced from ONE shared module, lib_measurement_fields,
// loaded once here alongside ui_list_engine in Root's startup effect,
// before the list view ever mounts. See that module's own header for why
// its order is append-only and never reordered (legacy XLS copy-paste
// column alignment) — a brand-new measurement column discovered later
// always appears at the END of the populated-fields list here too, never
// inserted near a "related" field.
//
// 2026-07: Edit drawer now sets zIndex:1100 (matches production's pattern) —
// Edit is opened from inside the still-open Detail drawer via the header
// "✏️ Edit" button, so without an explicit z-index bump the Edit drawer was
// stacking BEHIND Detail at the same default level and appeared to do
// nothing when clicked.
//
// 2026-07, cont'd: added a "📋 Duplicate" bulk action. It does NOT write
// anything directly — it fetches the source set's data (name, remarks, all
// variant rows) and opens the New drawer pre-filled via
// helpers.openNewWithPrefill (see ui_list_engine), so the user can review/
// edit before Save actually creates anything. Product links are
// intentionally NOT copied — fk_product_measurement_id is one-per-product,
// so a duplicate starts unlinked and the user reassigns via Edit.
// =====================================================
const { React, antd, dayjs } = ctx.libs;
const { useState, useEffect } = React;
const { Modal, Spin, message } = antd;
const ce = React.createElement;

// shared code loader — resource-based (non-admin-safe), same pattern as view_production.
const _codeCache = {};
async function loadCode(name) {
  if (_codeCache[name]) return _codeCache[name];
  const res = await ctx.api.resource('source_code').list({
    filter: { name: name },
    fields: ['code'],
    pageSize: 1,
  });
  const rows = (res && res.data && res.data.data) || [];
  const src = (rows[0] && rows[0].code) || '';
  _codeCache[name] = new Function('React', 'antd', 'dayjs', 'ctx', src)(React, antd, dayjs, ctx);
  return _codeCache[name];
}

// ── scaling helpers (same pattern as view_production / view_production_material) ──
const DEFAULT_PAGE_SIZE = 1000;
function fetchAllPages(resourceName, params) {
  const pageSize = (params && params.pageSize) || DEFAULT_PAGE_SIZE;
  function loadPage(page, acc) {
    return ctx.api.resource(resourceName).list(Object.assign({}, params, { pageSize: pageSize, page: page }))
      .then(function (res) {
        const rows = (res && res.data && res.data.data) || [];
        const merged = acc.concat(rows);
        if (rows.length < pageSize) return merged;
        return loadPage(page + 1, merged);
      });
  }
  return loadPage(1, []);
}
function chunk(arr, size) { const out = []; for (let i = 0; i < arr.length; i += size) out.push(arr.slice(i, i + size)); return out; }
const BATCH_SIZE = 150;
function uniqVals(a) { const out = [], seen = {}; a.forEach(x => { if (x == null) return; const k = String(x); if (!seen[k]) { seen[k] = 1; out.push(x); } }); return out; }
function fetchByIn(resourceName, field, values, params) {
  const values2 = uniqVals(values);
  if (!values2.length) return Promise.resolve([]);
  const batches = chunk(values2, BATCH_SIZE);
  return batches.reduce(function (promise, batch) {
    return promise.then(function (acc) {
      const filter = Object.assign({}, (params && params.filter) || {});
      filter[field] = { $in: batch };
      return fetchAllPages(resourceName, Object.assign({}, params, { filter: filter }))
        .then(function (rows) { return acc.concat(rows); });
    });
  }, Promise.resolve([]));
}

// ── measurement fields — now sourced from the shared lib_measurement_fields
// module (loaded once in Root's startup effect, below, before the list view
// ever mounts). These start empty and get populated before any of the
// functions below actually execute — see Root. ──
let MEASURE_FIELDS = [];
let MEASURE_KEYS = [];

function isPopulated(v) { return v !== null && v !== undefined && v !== ''; }
// only the columns that have a value somewhere across this set's sizes —
// used by the (read-only) card + detail views. Edit always shows all fields.
function getPopulatedFields(variants) {
  return MEASURE_FIELDS.filter(f => variants.some(v => isPopulated(v.values[f.key])));
}
// CHANGED (2026-07): card remarks now render the actual rich HTML (bold,
// lists, etc.), truncated visually via CSS line-clamp — instead of
// flattening to plain text via stripHtml. htmlIsEmpty just checks whether
// there's any real content once tags/&nbsp; are discounted (same pattern
// used elsewhere in this codebase, e.g. ui_production_detail.js).
function htmlIsEmpty(html) { return !html || !String(html).replace(/<[^>]*>/g, '').replace(/&nbsp;/gi, ' ').trim(); }
// defensive: if a non-primitive somehow ends up here (e.g. a relation
// object slipping through), never pass it straight into JSX — that's
// exactly what caused "React error #31: object with keys {...}" once
// already (see lib_measurement_fields.js's fetchAllSchemaFields fix).
function fmtNum(v) {
  if (!isPopulated(v)) return '—';
  if (typeof v === 'object') return '—';
  return v;
}

// ── data layer — everything the card + detail views need comes from ONE
// fetchList() pass: product_measurement rows, plus their linked products
// (with photo) and size rows (with sku label), batched via fetchByIn. ──
function fetchList() {
  return fetchAllPages('product_measurement', { fields: ['id', 'name', 'remarks'], sort: ['-id'] })
    .then(function (pmRows) {
      const ids = pmRows.map(r => r.id);

      const productsP = fetchByIn('product', 'fk_product_measurement_id', ids, {
        fields: ['code', 'name', 'fk_product_measurement_id'], appends: ['image'],
      });
      const variantsP = fetchByIn('product_measurement_variant', 'fk_product_measurement_variant_id', ids, {
        fields: ['id', 'fk_product_measurement_variant_id'].concat(MEASURE_KEYS), appends: ['sku_option'],
      });

      return Promise.all([productsP, variantsP]).then(function (r) {
        const prodRows = r[0], varRows = r[1];

        const productsByPm = {};
        prodRows.forEach(function (p) {
          const pid = String(p.fk_product_measurement_id);
          const img = p.image; const imgRow = Array.isArray(img) ? img[0] : img;
          const url = imgRow ? (imgRow.url || (imgRow.filename ? '/storage/uploads/' + imgRow.filename : '')) : '';
          (productsByPm[pid] = productsByPm[pid] || []).push({ code: p.code, name: p.name, image: url });
        });

        const variantsByPm = {};
        varRows.forEach(function (v) {
          const pid = String(v.fk_product_measurement_variant_id);
          const sk = v.sku_option || {};
          const values = {};
          MEASURE_FIELDS.forEach(function (f) { values[f.key] = v[f.key]; });
          (variantsByPm[pid] = variantsByPm[pid] || []).push({ sku_id: sk.id, sku_display: sk.display || '—', sku_sort: sk.sort || 0, values: values });
        });

        return pmRows.map(function (pm) {
          const pid = String(pm.id);
          const products = (productsByPm[pid] || []).slice().sort((a, b) => String(a.code).localeCompare(String(b.code)));
          const variants = (variantsByPm[pid] || []).slice().sort((a, b) => a.sku_sort - b.sku_sort);
          return { id: pm.id, name: pm.name, remarks: pm.remarks || '', products: products, variants: variants };
        });
      });
    });
}

// ── delete: cleans up children BEFORE the parent, so we never leave orphaned
// product_measurement_variant rows or products still pointing at a deleted
// set via fk_product_measurement_id (also avoids relying on unknown FK
// cascade behavior in the DB). ──
async function deleteMeasurement(id) {
  const prodRows = (await ctx.api.resource('product').list({ filter: { fk_product_measurement_id: id }, fields: ['code'], pageSize: 1000 })).data.data || [];
  const varRows = (await ctx.api.resource('product_measurement_variant').list({ filter: { fk_product_measurement_variant_id: id }, fields: ['id'], pageSize: 1000 })).data.data || [];
  for (const p of prodRows) { await ctx.api.resource('product').update({ filterByTk: p.code, values: { fk_product_measurement_id: null } }); }
  for (const v of varRows) { await ctx.api.resource('product_measurement_variant').destroy({ filterByTk: v.id }); }
  return ctx.api.resource('product_measurement').destroy({ filterByTk: id });
}

// ── duplicate: fetches the source set's data (name, remarks, all variant
// rows) so it can be handed to the New drawer as prefill — nothing is
// created here. The user reviews/edits in the drawer and Save does the
// actual write, same flow as filling out New Measurement normally. ──
async function fetchDuplicateSource(id) {
  const srcRes = await ctx.api.resource('product_measurement').get({ filterByTk: id, fields: ['id', 'name', 'remarks'] });
  const src = srcRes.data.data;

  const variants = await fetchAllPages('product_measurement_variant', {
    filter: { fk_product_measurement_variant_id: id },
    fields: ['fk_product_measurement_variant_id'].concat(MEASURE_KEYS),
    appends: ['sku_option'],
  });

  return {
    name: (src.name || 'Untitled') + ' (Copy)',
    remarks: src.remarks || '',
    variants: variants.map(function (v) {
      const sk = v.sku_option || {};
      const values = {};
      MEASURE_FIELDS.forEach(function (f) { values[f.key] = v[f.key]; });
      return { sku_id: sk.id, sku_display: sk.display || '—', sku_sort: sk.sort || 0, values: values };
    }).filter(function (v) { return v.sku_id; }),
  };
}

// ── New / Edit drawer loaders (dedicated source_code rows, Drawer-based) ──
function NewDrawerLoader(props) {
  const sC = useState(null); const Mod = sC[0]; const setMod = sC[1];
  const sS = useState(null); const Shell = sS[0]; const setShell = sS[1];
  useEffect(function () {
    loadCode('lib_drawer_shell').then(setShell).catch(function () { setShell(false); });
    loadCode('ui_product_measurement_add').then(setMod).catch(function () { setMod(false); });
  }, []);
  if (!Shell || !Shell.DrawerShell) return null; // brief, first-paint-only — cached after first use on the page
  const DrawerShell = Shell.DrawerShell;
  const ready = Mod && Mod.NewMeasurementFormBody;
  return ce(DrawerShell, {
    open: props.open, onClose: props.onClose,
    title: props.prefill ? 'Duplicate Product Measurement' : 'New Product Measurement',
    width: 1080, placement: 'right', rootClassName: 'pmm-form-drawer', loading: !ready,
  }, ready ? ce(Mod.NewMeasurementFormBody, {
    onClose: props.onClose, onCreated: props.onCreated,
    resetSignal: props.open, initialData: props.prefill || null,
  }) : null);
}

function EditDrawerLoader(props) {
  const sC = useState(null); const Mod = sC[0]; const setMod = sC[1];
  const sS = useState(null); const Shell = sS[0]; const setShell = sS[1];
  const sF = useState(null); const footer = sF[0]; const setFooter = sF[1];
  useEffect(function () {
    loadCode('lib_drawer_shell').then(setShell).catch(function () { setShell(false); });
    loadCode('ui_product_measurement_edit').then(setMod).catch(function () { setMod(false); });
  }, []);
  if (!Shell || !Shell.DrawerShell) return null;
  const DrawerShell = Shell.DrawerShell;
  const ready = Mod && Mod.EditMeasurementFormBody;
  return ce(DrawerShell, {
    open: props.open, onClose: props.onClose, title: 'Edit Product Measurement',
    width: 1080, placement: 'right', rootClassName: 'pmm-form-drawer', zIndex: 1100, loading: !ready, footer: footer,
  }, ready ? ce(Mod.EditMeasurementFormBody, { open: props.open, measurementId: props.measurementId, onClose: props.onClose, onSaved: props.onSaved, onFooterChange: setFooter }) : null);
}

// ── card renderer ──
function renderCard(o) {
  const row = o.row;
  const selectMode = o.selectMode, selected = o.selected;
  const products = row.products || [];
  const variants = row.variants || [];
  const img = products[0] && products[0].image;
  const codesText = products.length ? products.map(p => p.code).join(', ') : '—';
  const hasRemarks = !htmlIsEmpty(row.remarks);
  const populatedFields = getPopulatedFields(variants);

  return ce('div', { className: 'pmm-cardbody' },
    ce('div', { className: 'pmm-col-summary' },
      selectMode
        ? ce('div', { style: { width: 22, height: 22, borderRadius: 6, flexShrink: 0, border: '2px solid ' + (selected ? '#6366f1' : '#cbd5e1'), background: selected ? '#6366f1' : '#fff', color: '#fff', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 14 } }, selected ? '✓' : '')
        : null,
      ce('div', { style: { width: 56, height: 56, borderRadius: 10, flexShrink: 0, background: '#f3f4f6', overflow: 'hidden', display: 'flex', alignItems: 'center', justifyContent: 'center' } },
        img ? ce('img', { src: img, style: { width: '100%', height: '100%', objectFit: 'cover' } }) : ce('span', { style: { fontSize: 20, color: '#cbd5e1' } }, '📏')),
      ce('div', { style: { flex: 1, minWidth: 0 } },
        ce('div', { style: { fontWeight: 700, fontSize: 14, color: '#111827', marginBottom: 3, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, row.name || '—'),
        ce('div', { style: { fontSize: 12, color: '#6b7280', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, codesText),
        ce('div', { style: { display: 'flex', flexWrap: 'wrap', gap: 4, marginTop: 5 } },
          variants.length
            ? variants.map(v => ce('span', { key: v.sku_id, style: { fontSize: 10, fontWeight: 700, color: '#4338ca', background: '#eef2ff', border: '1px solid #c7d2fe', borderRadius: 4, padding: '1px 6px' } }, v.sku_display))
            : ce('span', { style: { fontSize: 11, color: '#cbd5e1' } }, 'No sizes'))
      )),
    ce('div', { className: 'pmm-col-measure' },
      (variants.length && populatedFields.length)
        ? ce('div', { className: 'pmm-mini-grid' },
            ce('table', null,
              ce('thead', null, ce('tr', null,
                ce('th', null, 'Size'),
                populatedFields.map(f => ce('th', { key: f.key }, f.primary)))),
              ce('tbody', null, variants.map(v => ce('tr', { key: v.sku_id },
                ce('td', { className: 'pmm-mini-size' }, v.sku_display),
                populatedFields.map(f => ce('td', { key: f.key }, fmtNum(v.values[f.key]))))))))
        : ce('span', { style: { fontSize: 11, color: '#cbd5e1' } }, '—')),
    ce('div', { className: 'pmm-col-remarks' },
      hasRemarks
        ? ce('div', { className: 'pmm-remarks-preview', dangerouslySetInnerHTML: { __html: row.remarks } })
        : ce('span', { style: { fontSize: 11, color: '#cbd5e1' } }, 'No remarks')));
}

// ── detail: everything — products (bigger photo-on-top tiles), remarks
// (rendered rich text), and the measurement grid for every size, limited to
// columns that actually have a value. All sourced straight off `row`
// (already fetched in fetchList, no extra round trip). ──
function DetailBody(props) {
  const row = props.row;
  const products = row.products || [];
  const variants = row.variants || [];
  const populatedFields = getPopulatedFields(variants);
  const fieldLabelEl = t => ce('div', { style: { fontSize: 11, fontWeight: 600, color: '#6b7280', marginBottom: 6, textTransform: 'uppercase', letterSpacing: '0.04em' } }, t);

  return ce('div', { style: { fontFamily: 'system-ui,sans-serif', fontSize: 13, display: 'flex', flexDirection: 'column', gap: 18, paddingTop: 4 } },
    ce('style', null,
      ".pmd-grid-wrap{border:1px solid #cbd5e1;overflow-x:auto;}" +
      ".pmd-grid-wrap table{border-collapse:separate;border-spacing:0;width:100%;}" +
      ".pmd-grid-wrap th{background:#f1f5f9;border:1px solid #cbd5e1;padding:4px 3px;font-size:10px;white-space:normal;text-align:center;}" +
      ".pmd-grid-wrap td{border:1px solid #e2e8f0;padding:4px;font-size:12px;text-align:center;background:#fff;}" +
      ".pmd-grid-wrap tr.pmd-alt td{background:#f8fafc;}" +
      ".pmd-grid-wrap td.pmd-size-cell{padding:6px 14px;font-weight:700;text-align:left;white-space:nowrap;}" +
      ".pmd-rte-body{font-size:13px;line-height:1.5;}" +
      ".pmd-rte-body:empty:before{content:'No remarks';color:#b0b7c3;font-style:italic;}" +
      ".pmd-prod-tile{width:120px;}" +
      ".pmd-prod-tile img,.pmd-prod-tile .pmd-prod-noimg{width:120px;height:120px;border-radius:10px;object-fit:cover;background:#f3f4f6;}"),

    ce('div', null, fieldLabelEl('Products (' + products.length + ')'),
      products.length
        ? ce('div', { style: { display: 'flex', flexWrap: 'wrap', gap: 14 } },
            products.map(p => ce('div', { key: p.code, className: 'pmd-prod-tile' },
              p.image
                ? ce('img', { src: p.image })
                : ce('div', { className: 'pmd-prod-noimg', style: { display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 30, color: '#cbd5e1' } }, '👕'),
              ce('div', { style: { marginTop: 6, fontSize: 12, fontWeight: 700, color: '#111827' } }, p.code),
              ce('div', { style: { fontSize: 11, color: '#6b7280' } }, p.name || '—'))))
        : ce('div', { style: { fontSize: 12, color: '#9ca3af', fontStyle: 'italic' } }, 'No products linked.')),

    ce('div', null, fieldLabelEl('Remarks'),
      ce('div', { style: { border: '1px solid #e5e7eb', borderRadius: 8, padding: '10px 12px' } },
        ce('div', { className: 'pmd-rte-body', dangerouslySetInnerHTML: { __html: row.remarks || '' } }))),

    ce('div', null, fieldLabelEl('Measurements (' + variants.length + ' size' + (variants.length === 1 ? '' : 's') + ')'),
      (variants.length && populatedFields.length)
        ? ce('div', { className: 'pmd-grid-wrap' },
            ce('table', null,
              ce('thead', null, ce('tr', null,
                ce('th', { style: { textAlign: 'left' } }, 'Size'),
                populatedFields.map(f => ce('th', { key: f.key },
                  ce('div', null, ce('div', { style: { fontWeight: 700 } }, f.primary), f.secondary ? ce('div', { style: { color: '#94a3b8', fontWeight: 500 } }, '(' + f.secondary + ')') : null))))),
              ce('tbody', null, variants.map((v, i) => ce('tr', { key: v.sku_id, className: i % 2 === 1 ? 'pmd-alt' : '' },
                ce('td', { className: 'pmd-size-cell' }, v.sku_display),
                populatedFields.map(f => ce('td', { key: f.key }, fmtNum(v.values[f.key]))))))))
        : ce('div', { style: { fontSize: 12, color: '#9ca3af', fontStyle: 'italic' } }, 'No measurements recorded.')),

    ce('div', { style: { height: 20 } }));
}

