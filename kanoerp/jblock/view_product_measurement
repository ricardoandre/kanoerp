  // this is single-row, no selection needed.
  quickActions: [
    { key: 'edit', icon: '✏️', label: 'Edit', color: '#3b82f6', run: (row, helpers) => helpers.openEdit(row) },
    { key: 'duplicate', icon: '📋', label: 'Duplicate', color: '#6366f1', primary: false, run: function (row, helpers) {
        fetchDuplicateSource(row.id).then(function (prefill) { helpers.openNewWithPrefill(prefill); })
          .catch(function (e) { message.error('Could not load source data: ' + ((e && e.message) || e)); });
      } },
    { key: 'delete', icon: '🗑', label: 'Delete', color: '#ef4444', danger: true, primary: false, run: (row, helpers) => helpers.confirmDelete(row) },
  ],

  bulkActions: [
    { label: '📋 Duplicate', bg: '#6366f1', color: '#fff', run: function (ids, helpers) {
        if (ids.length !== 1) { message.warning('Select exactly one measurement set to duplicate.'); return; }
        fetchDuplicateSource(ids[0])
          .then(function (prefill) {
            helpers.exitSelect();
            helpers.openNewWithPrefill(prefill);
          })
          .catch(function (e) { message.error('Could not load source data: ' + ((e && e.message) || e)); });
      } },
    { label: '🗑 Delete', bg: '#ef4444', color: '#fff', run: function (ids, helpers) {
        Modal.confirm({
          title: 'Delete ' + ids.length + ' measurement set(s)?',
          content: 'This also removes their size rows and unlinks any products pointing at them. This cannot be undone.',
          okText: 'Delete', okButtonProps: { danger: true },
          onOk: () => ids.reduce((p, id) => p.then(() => deleteMeasurement(id)), Promise.resolve())
            .then(() => { message.success('Deleted ' + ids.length + '.'); helpers.exitSelect(); helpers.reload(); })
            .catch(e => message.error('Bulk delete failed: ' + ((e && e.message) || e))),
        });
      } },
  ],
};

// ── root — now also loads lib_measurement_fields alongside ui_list_engine,
// populating the module-level MEASURE_FIELDS/MEASURE_KEYS before the list
// view is ever constructed. If the lib fails to load for any reason, this
// surfaces as a load error the same way a missing ui_list_engine would —
// there's no sane partial-fallback for "no measurement columns at all". ──
const Root = function () {
  const sLV = useState(null); const LV = sLV[0]; const setLV = sLV[1];
  const sErr = useState(null); const err = sErr[0]; const setErr = sErr[1];
  useEffect(function () {
    Promise.all([
      loadCode('ui_list_engine'),
      loadCode('lib_measurement_fields'),
    ]).then(function (r) {
      const M = r[0]; const Lib = r[1];
      // fetchAllSchemaFields (not a fixed list) — this file's resource()
      // calls need an explicit field list (no SELECT * for the resource
      // API), so a schema check is how a brand-new column gets picked up
      // automatically here, same intent as the SELECT * discovery used by
      // the raw-SQL read-only views.
      return Lib.fetchAllSchemaFields(ctx).then(function (schemaKeys) {
        MEASURE_FIELDS = Lib.getDisplayFields(schemaKeys);
        MEASURE_KEYS = MEASURE_FIELDS.map(function (f) { return f.key; });
        setLV(function () { return M.createListView(config); });
      });
    }).catch(function (e) { setErr((e && e.message) || String(e)); });
  }, []);
  if (err) return ce('div', { style: { color: '#ef4444', padding: 16 } }, 'Failed to load: ' + err);
  if (!LV) return ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, 'Loading…');
  return ce('div', null, ce(LV));
};

ctx.render(ce(Root));
