    missingReachPeriods.length > 0 && ce('div', { style: { display: 'flex', alignItems: 'center', gap: 8, padding: '8px 14px', marginBottom: 16, background: '#fff7ed', border: '1px solid #fed7aa', borderRadius: 6, fontSize: 12, color: '#9a3412' } },
      ce('span', { style: { width: 8, height: 8, borderRadius: 4, background: '#f97316', flexShrink: 0 } }),
      'No account-level reach data for ' + missingReachPeriods.join(', ') + ' — showing "—" instead of a derived number.'),
    ce('div', { style: { fontWeight: 700, fontSize: 14, marginBottom: 8 } }, '1. Account Overview — last ' + TREND_PERIOD_COUNT + ' months'),
    ce(TrendChart, { periods: periods, getRow: function (k) { return overall[k]; }, selected: TREND_METRICS, metricRows: METRIC_ROWS }),
    ce(SummaryTable, { periods: periods, getRow: function (k) { return overall[k]; }, targetRules: targetRules, metricRows: METRIC_ROWS }),
    ce('div', { style: { fontWeight: 700, fontSize: 14, marginTop: 32, marginBottom: 8 } }, '2. Campaigns — ' + month.format('MMMM YYYY')),
    campaignRows ? ce(CampaignTable, { rows: campaignRows }) : null,
    ce('div', { style: { fontWeight: 700, fontSize: 14, marginTop: 32, marginBottom: 8 } }, '3. Creatives — ' + month.format('MMMM YYYY')),
    creativeRows ? ce(CreativeTable, { rows: creativeRows }) : null);
};
ctx.render(ce(Root));
