              ")"
            ).then(function(targetRows) {

            var targetMap = {};
            targetRows.forEach(function(r) {
              targetMap[String(r.collection_id)] = Number(r.total_sample) || 0;
            });

              var designerLabelMap = {};
              try {
                var parsed = JSON.parse((frows && frows[0] && frows[0].options) || '{}');
                var arr = parsed.uiSchema && parsed.uiSchema.enum ? parsed.uiSchema.enum : [];
                arr.forEach(function(o) { if (o.value) designerLabelMap[o.value] = o.label || o.value; });
              } catch(e) {}

              var sampleVariantMap = {};
              varRows.forEach(function(v) {
                var sid = String(v.sample_id);
                if (!sampleVariantMap[sid]) sampleVariantMap[sid] = { total: 0, statuses: [] };
                sampleVariantMap[sid].total += Number(v.variant_count) || 0;
                for (var i = 0; i < (Number(v.variant_count) || 0); i++) {
                  sampleVariantMap[sid].statuses.push(String(v.status || '').toLowerCase());
                }
              });

              var collOrder = [];
              var collMap = {};

              rows.forEach(function(row) {
                var cid = String(row.collection_id);
                if (!collMap[cid]) {
                  collOrder.push(cid);
                  collMap[cid] = {
                    name: row.collection_name,
                    target_photoshoot: row.target_photoshoot,
