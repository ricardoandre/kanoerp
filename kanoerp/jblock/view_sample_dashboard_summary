// By-Progress grouping (Collection Preview). Order controls display order.
var PROGRESS_ORDER = ['ideas','pola','first_sample','revision','qc','approval','approved'];

var PROGRESS_LABELS = {
  ideas:        'Ideas',
  pola:         'Pola',
  first_sample: 'First Sample',
  revision:     'Revision',
  qc:           'QC',
  approval:     'Need Approval',
  approved:     'Approved',
};

var SAMPLE_INPROGRESS  = ['ideas','pola','first_sample'];
var SAMPLE_APPROVED    = ['pricing','color','done'];
var SAMPLE_CANCEL      = ['cancel'];

var VARIANT_INPROGRESS = ['sewing','qc','approval'];
var VARIANT_APPROVED   = ['done'];
var VARIANT_CANCEL     = ['cancel'];

function getStatus(val) {
  return STATUS_META[String(val || '').toLowerCase()] || { label: val || '—', color: '#9ca3af', group: 'other' };
}

function classifySample(status) {
  var s = String(status || '').toLowerCase();
  if (SAMPLE_INPROGRESS.indexOf(s) !== -1) return 'inprogress';
  if (SAMPLE_APPROVED.indexOf(s) !== -1)   return 'approved';
  if (SAMPLE_CANCEL.indexOf(s) !== -1)     return 'cancel';
  return 'other';
}

function classifyVariant(status) {
  var s = String(status || '').toLowerCase();
  if (VARIANT_INPROGRESS.indexOf(s) !== -1) return 'inprogress';
  if (VARIANT_APPROVED.indexOf(s) !== -1)   return 'approved';
  if (VARIANT_CANCEL.indexOf(s) !== -1)     return 'cancel';
  return 'other';
}

// Determine the "By Progress" bucket for a sample based on its own status
// and its variants' statuses.
//   ideas        -> sample.status = ideas
//   pola         -> sample.status = pola
//   first_sample -> sample.status = first_sample, no variant in revision/qc/approval
//   revision     -> sample.status = first_sample, any variant = minor_revision
//   qc           -> sample.status = first_sample, any variant = qc
//   approval     -> sample.status = first_sample, any variant = approval (labeled "Need Approval")
//   approved     -> sample.status = color or done
// Priority when a sample has variants in more than one of revision/qc/approval:
// revision > qc > approval (revision surfaces the sample as needing attention
// first, then qc, then approval). Anything else (pricing, cancel)
// returns null and is excluded from the By Progress view.
function classifyProgress(sample, variantStatuses) {
  var status = String((sample && sample.status) || '').toLowerCase();
  if (status === 'ideas') return 'ideas';
  if (status === 'pola') return 'pola';
  if (status === 'first_sample') {
    var vs = (variantStatuses || []).map(function(s) { return String(s || '').toLowerCase(); });
    if (vs.indexOf('minor_revision') !== -1) return 'revision';
    if (vs.indexOf('qc') !== -1) return 'qc';
    if (vs.indexOf('approval') !== -1) return 'approval';
    return 'first_sample';
  }
  if (status === 'color' || status === 'done') return 'approved';
  return null;
}

function runSql(uid, sql) {
  var s = ctx.sql;
  if (!s) return Promise.resolve([]);
  return s.save({ uid: uid, sql: sql, dataSourceKey: 'main' })
    .catch(function(){})
    .then(function() { return s.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }); })
    .then(function(r) { return r || []; });
}

function buildImgUrl(filename, url) {
  if (url) return url;
  if (filename) return window.location.origin + '/storage/uploads/' + filename;
  return '';
}

// Small opaque price label shown on thumbnails / detail meta rows
function formatPrice(v) {
  var n = Number(v);
  if (!n) return '';
  return 'Rp' + n.toLocaleString('id-ID');
}

