var App = function() {
  var stateStage = useState('summary'); var page = stateStage[0]; var setPage = stateStage[1];
  var statePreview = useState(null); var previewParams = statePreview[0]; var setPreviewParams = statePreview[1];

  function openCollection(collectionId, opts) {
    setPreviewParams({
      collectionId: collectionId,
      initialType: (opts && opts.type) ? opts.type : null,
      initialViewMode: (opts && opts.viewMode) ? opts.viewMode : 'all',
    });
    setPage('preview');
  }

  function backToSummary() {
    setPage('summary');
    setPreviewParams(null);
  }

  if (page === 'preview' && previewParams) {
    return createElement(CollectionPreviewPage, {
      initialCollectionId: previewParams.collectionId,
      initialType: previewParams.initialType,
      initialViewMode: previewParams.initialViewMode,
      onBack: backToSummary,
    });
  }
  return createElement(SummaryReportPage, { onOpenCollection: openCollection });
};

