                    variantStatus: { inprogress: 0, approved: 0, cancel: 0 },
                    totalVariants: 0,
                    estVariants: 0,
                    oldCount: 0,
                  };
                }

                var sampleIds = row.sample_ids ? String(row.sample_ids).split(',') : [];

                var variantTotal = sampleIds.reduce(function(sum, sid) {
                  return sum + ((sampleVariantMap[sid.trim()] || {}).total || 0);
                }, 0);

                var isOld = String(row.is_new) === 'false' || row.is_new === 0 || row.is_new === false;
                var sampleStatusLower = String(row.sample_status || '').toLowerCase();
                var isDoneOrColor = (sampleStatusLower === 'done' || sampleStatusLower === 'color');

                var estTotal = sampleIds.reduce(function(sum, sid) {
                  var sv = sampleVariantMap[sid.trim()];
                  var total = sv ? sv.total : 0;

                  if (isDoneOrColor) return sum + total;
                  if (isOld) return sum + total;
                  if (!sv || total === 0) return sum + 3;
                  if (total > 1) return sum + total;

                  if (total === 1) {
                    var allInProgress = sv.statuses.every(function(s) {
                      return VARIANT_INPROGRESS.indexOf(s) !== -1;
                    });
                    if (allInProgress) return sum + 3;
                  }

                  return sum + total;
                }, 0);

                var typeKey = row.type || 'unknown';
                if (!isOld) {
                  if (!collMap[cid].types[typeKey]) {
                    collMap[cid].types[typeKey] = { sample_count: 0 };
                  }
                  collMap[cid].types[typeKey].sample_count += Number(row.sample_count) || 0;

                  var dKey = row.designer || '';
                  if (dKey) {
                    collMap[cid].designers[dKey] = (collMap[cid].designers[dKey] || 0) + (Number(row.sample_count) || 0);
                  }
                }

                collMap[cid].totalVariants += variantTotal;
                collMap[cid].estVariants   += estTotal;
              });

              sStatusRows.forEach(function(r) {
                var cid = String(r.collection_id);
                if (!collMap[cid]) return;
                var cls = classifySample(r.status);
                if (cls === 'inprogress' || cls === 'approved' || cls === 'cancel') {
                  collMap[cid].sampleStatus[cls] += Number(r.cnt) || 0;
                }
              });

              var today = new Date();
              today.setHours(0, 0, 0, 0);

              var cpMap = {};
              cpRows.forEach(function(cp) {
                var cid = String(cp.collection_id);
                if (!cpMap[cid]) cpMap[cid] = [];
                cpMap[cid].push({
                  date: new Date(cp.checkpoint_date),
                  dateStr: String(cp.checkpoint_date).substring(0, 10),
                  approved_sample: Number(cp.approved_sample) || 0,
                });
              });

              function fmtDate(d) {
                var m = String(d.getMonth() + 1).padStart(2, '0');
                var day = String(d.getDate()).padStart(2, '0');
                return d.getFullYear() + '-' + m + '-' + day;
              }

              Object.keys(collMap).forEach(function(cid) {
                collMap[cid].targetSample = targetMap[cid] || 0;
                var cps = cpMap[cid] || [];
                var past = null, next = null;
                cps.forEach(function(cp) {
                  if (cp.date <= today) {
                    if (!past || cp.date > past.date) past = cp;
                  } else {
                    if (!next || cp.date < next.date) next = cp;
                  }
                });
                var approvedCount = collMap[cid].sampleStatus.approved;
                var isLate = past && approvedCount < past.approved_sample;
                collMap[cid].pastCheckpoint = past ? Object.assign({}, past, { dateStr: fmtDate(past.date) }) : null;
                collMap[cid].nextCheckpoint = next ? Object.assign({}, next, { dateStr: fmtDate(next.date) }) : null;
                collMap[cid].isLate = isLate;
              });

              vStatusRows.forEach(function(r) {
                var cid = String(r.collection_id);
                if (!collMap[cid]) return;
                var cls = classifyVariant(r.status);
                if (cls === 'inprogress' || cls === 'approved' || cls === 'cancel') {
                  collMap[cid].variantStatus[cls] += Number(r.cnt) || 0;
                }
              });

              oldRows.forEach(function(r) {
                var cid = String(r.collection_id);
                if (collMap[cid]) collMap[cid].oldCount = Number(r.old_count) || 0;
              });

              setData({ collMap: collMap, collOrder: collOrder, designerLabelMap: designerLabelMap });
              setLoading(false);
            });
            });
          });
          });
        });
        });
      });
    }).catch(function() { setLoading(false); });
  }, []);

  var S = {
    wrap:      { padding: 16, background: '#fff', borderRadius: 8, fontFamily: 'system-ui,sans-serif', boxSizing: 'border-box' },
    title:     { fontSize: 16, fontWeight: 700, marginBottom: 16, color: '#111827' },
