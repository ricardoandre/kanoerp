        "WHERE sample_variant.fk_sample_variant_id = sample.id " +
        "AND sample.status <> 'cancel' " +
        "AND sample_variant.status <> 'cancel' " +
        "GROUP BY sample_variant.fk_sample_variant_id, sample_variant.status"
      ).then(function(varRows) {

        return q('sample_coll_oldcount',
          "SELECT sample.fk_collection_id AS collection_id, COUNT(*) AS old_count " +
          "FROM sample_variant, sample " +
          "WHERE sample_variant.fk_sample_variant_id = sample.id " +
          "AND sample.status <> 'cancel' " +
          "AND sample.is_new = FALSE " +
          "AND sample_variant.status <> 'cancel' " +
          "GROUP BY sample.fk_collection_id"
        ).then(function(oldRows) {

        return q(CONFIG.uid_sample_status,
          "SELECT fk_collection_id AS collection_id, status, COUNT(*) AS cnt " +
          "FROM sample GROUP BY fk_collection_id, status"
        ).then(function(sStatusRows) {

          return q(CONFIG.uid_variant_status,
            "SELECT sample.fk_collection_id AS collection_id, sample_variant.status AS status, COUNT(*) AS cnt " +
            "FROM sample_variant, sample " +
            "WHERE sample_variant.fk_sample_variant_id = sample.id " +
            "GROUP BY sample.fk_collection_id, sample_variant.status"
          ).then(function(vStatusRows) {

          return q(CONFIG.uid_designer_opts,
            "SELECT CAST(options AS CHAR) AS options FROM fields WHERE collection_name = 'sample' AND name = 'designer'"
          ).then(function(frows) {

            return q('sample_coll_checkpoints',
              "SELECT fk_collection_id AS collection_id, checkpoint_date, approved_sample " +
              "FROM collection_checkpoint ORDER BY checkpoint_date ASC"
