  var collections = data.collOrder.map(function(cid) { return data.collMap[cid]; });
  var designerLabelMap = data.designerLabelMap || {};

  return React.createElement('div', { className: 'ssr-wrap', style: S.wrap },
    React.createElement('style', null, `
      @media (max-width: 640px) {
