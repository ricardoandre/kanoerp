  if (!data || !data.collOrder || !data.collOrder.length) {
    return React.createElement('div', { style: S.wrap },
      React.createElement('div', { style: S.title }, 'Sample Summary Report'),
      React.createElement('div', { style: { padding: 40, textAlign: 'center', color: '#d1d5db', fontStyle: 'italic' } }, 'No data found')
