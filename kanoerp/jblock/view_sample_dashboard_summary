  };

  function statusSection(label, statusObj) {
    return React.createElement('div', { style: S.statusCard },
      React.createElement('div', { style: S.statusLabel }, label),
      React.createElement('div', { style: S.statusRow },
        React.createElement('div', { style: S.statusItem },
          React.createElement('div', { style: S.statusNum('#f97316') }, statusObj.inprogress),
          React.createElement('div', { style: S.statusSub }, 'In Progress')
