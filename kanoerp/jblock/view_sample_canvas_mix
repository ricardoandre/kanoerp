// ── BROWSE EXISTING IMAGES MODAL ────────────────────────────────
// Lets the user pick a collection, then multi-select from a combined grid of
// that collection's sample.reference_images + sample_variant.image, to link
// into canvas.images without re-uploading.
var BrowseImagesModal = function(props) {
  var open        = props.open;
  var collections = props.collections || [];
  var existingIds = props.existingIds || {};
  var onClose     = props.onClose;
  var onConfirm   = props.onConfirm; // (chosenItems[]) => void

  var sCol  = useState(null);  var colId    = sCol[0];  var setColId    = sCol[1];
  var sImgs = useState([]);    var images   = sImgs[0]; var setImages   = sImgs[1];
  var sLoad = useState(false); var loading  = sLoad[0]; var setLoading  = sLoad[1];
  var sSel  = useState({});    var selected = sSel[0];  var setSelected = sSel[1];

  useEffect(function() {
    if (!open) { setColId(null); setImages([]); setSelected({}); }
  }, [open]);

  useEffect(function() {
    if (!colId) { setImages([]); return; }
    setLoading(true);
    setSelected({});
    fetchCollectionImages(colId).then(function(list) {
      setImages(list);
      setLoading(false);
    });
  }, [colId]);

  function toggle(id) {
    setSelected(function(prev) {
      var next = Object.assign({}, prev);
      if (next[id]) delete next[id]; else next[id] = true;
      return next;
    });
  }

  var selectedCount = Object.keys(selected).length;

  function handleConfirm() {
    var chosen = images.filter(function(im) { return selected[im.attachmentId]; });
    onConfirm(chosen);
  }

  return createElement(Modal, {
    title: 'Add Images from Collection',
    open: open,
    onCancel: onClose,
    width: 640,
    footer: [
      createElement('button', {
        key: 'cancel', onClick: onClose,
        style: { padding: '6px 14px', fontSize: 12, border: '1px solid #e2e8f0', borderRadius: 5, background: '#fff', color: '#64748b', cursor: 'pointer', marginRight: 8 }
      }, 'Cancel'),
      createElement('button', {
        key: 'add', onClick: handleConfirm, disabled: selectedCount === 0,
        style: {
          padding: '6px 16px', fontSize: 12, border: 'none', borderRadius: 5, fontWeight: 700, color: '#fff',
          cursor: selectedCount ? 'pointer' : 'default',
          background: selectedCount ? '#6366f1' : '#c7c2ff',
        }
      }, selectedCount ? ('Add ' + selectedCount + ' Image' + (selectedCount > 1 ? 's' : '')) : 'Add Images'),
    ],
  },
    createElement('div', { style: { display: 'flex', flexDirection: 'column', gap: 12 } },
      createElement(Select, {
        value: colId || undefined,
        onChange: function(v) { setColId(v); },
        placeholder: 'Select a collection…',
        style: { width: '100%' },
        options: collections.map(function(c) { return { value: String(c.id), label: c.name }; }),
      }),
      !colId
        ? createElement('div', { style: { color: '#9ca3af', fontSize: 12, textAlign: 'center', padding: '30px 0' } }, 'Pick a collection to browse its images')
        : loading
          ? createElement('div', { style: { color: '#9ca3af', fontSize: 12, textAlign: 'center', padding: '30px 0' } }, 'Loading…')
          : images.length === 0
            ? createElement('div', { style: { color: '#9ca3af', fontSize: 12, textAlign: 'center', padding: '30px 0' } }, 'No images found for this collection')
            : createElement('div', { style: { display: 'flex', flexWrap: 'wrap', gap: 10, maxHeight: 420, overflowY: 'auto', padding: 2 } },
                images.map(function(im) {
                  var isSel = !!selected[im.attachmentId];
                  var already = !!existingIds[im.attachmentId];
                  return createElement('div', {
                    key: im.attachmentId,
                    onClick: function() { if (!already) toggle(im.attachmentId); },
                    style: { width: 110, cursor: already ? 'default' : 'pointer', opacity: already ? 0.4 : 1 }
                  },
                    createElement('div', {
                      style: {
                        width: 110, height: 110, borderRadius: 6, overflow: 'hidden', position: 'relative',
                        background: '#f3f4f6',
                        boxShadow: isSel ? '0 0 0 3px #6366f1' : '0 1px 3px rgba(0,0,0,0.15)',
                      }
                    },
                      createElement('img', { src: im.img_url, style: { width: '100%', height: '100%', objectFit: 'cover', display: 'block' } }),
                      isSel ? createElement('div', {
                        style: { position: 'absolute', top: 4, right: 4, width: 18, height: 18, borderRadius: 9, background: '#6366f1', color: '#fff', fontSize: 11, display: 'flex', alignItems: 'center', justifyContent: 'center' }
                      }, '✓') : null,
                      already ? createElement('div', {
                        style: { position: 'absolute', bottom: 0, left: 0, right: 0, background: 'rgba(0,0,0,0.6)', color: '#fff', fontSize: 9, textAlign: 'center', padding: '2px 0' }
                      }, 'Already added') : null
                    ),
                    createElement('div', { style: { fontSize: 10, color: '#6b7280', marginTop: 4, textAlign: 'center', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, im.label)
                  );
                })
              )
    )
  );
};

