// ── IMAGE TILE (drag + resize on canvas) ──────────────────────
// Used for both sample images (type: 'sample') and manually-added
// images (type: 'image'). Only manual images get a delete control —
// sample tiles are driven by the sample table, not deletable here.
var ImageTile = function(props) {
  var item      = props.item;
  var onUpdate  = props.onUpdate;
  var onFocus   = props.onFocus;
  var onDelete  = props.onDelete;
  var isFocused = props.isFocused;
  var dragging  = useRef(false);
  var resizing  = useRef(false);
  var start     = useRef({});

  var onDragDown = function(e) {
    if (e.target.dataset.resize || e.target.dataset.delete) return;
    e.stopPropagation();
    e.preventDefault();
    dragging.current = true;
    var newZ = nextZ();
    start.current = { mx: e.clientX, my: e.clientY, ox: item.x, oy: item.y };
    onFocus(item.id);
    onUpdate(item.id, { z: newZ });

    function onMove(ev) {
      if (!dragging.current) return;
      onUpdate(item.id, {
        x: Math.max(0, start.current.ox + (ev.clientX - start.current.mx)),
        y: Math.max(0, start.current.oy + (ev.clientY - start.current.my)),
      });
    }
    function onUp() {
      dragging.current = false;
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
    }
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onUp);
  };

  var onResizeDown = function(e) {
    e.stopPropagation();
    e.preventDefault();
    resizing.current = true;
    start.current = { mx: e.clientX, my: e.clientY, ow: item.w, oh: item.h };

    function onMove(ev) {
      if (!resizing.current) return;
      onUpdate(item.id, {
        w: Math.max(80, start.current.ow + (ev.clientX - start.current.mx)),
        h: Math.max(80, start.current.oh + (ev.clientY - start.current.my)),
      });
    }
    function onUp() {
      resizing.current = false;
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('mouseup', onUp);
    }
    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseup', onUp);
  };

  return createElement('div', {
    onMouseDown: onDragDown,
    style: {
      position: 'absolute',
      left: item.x, top: item.y,
      width: item.w, height: item.h,
      cursor: 'grab', userSelect: 'none',
      borderRadius: 4, overflow: 'hidden',
      background: '#e8e4df',
      boxShadow: isFocused
        ? '0 0 0 2px #6366f1, 0 8px 24px rgba(0,0,0,0.2)'
        : '0 2px 8px rgba(0,0,0,0.12)',
      zIndex: item.z || 1,
    }
  },
    createElement('img', {
      src: item.img_url, draggable: false,
      style: { width: '100%', height: '100%', objectFit: 'cover', display: 'block', pointerEvents: 'none' },
    }),
    createElement('div', {
      style: {
        position: 'absolute', bottom: 0, left: 0, right: 0,
        background: 'linear-gradient(transparent, rgba(0,0,0,0.55))',
        color: '#fff', fontSize: 9, padding: '14px 5px 4px',
        pointerEvents: 'none', lineHeight: 1.3,
      }
    }, item.name),
    // Delete control — manual images only
    item.type === 'image' ? createElement('div', {
      'data-delete': '1',
      onMouseDown: function(e) { e.stopPropagation(); onDelete(item.id); },
      style: {
        position: 'absolute', top: 4, right: 4,
        width: 18, height: 18, borderRadius: 9,
        background: 'rgba(0,0,0,0.55)', color: '#fff',
        fontSize: 11, display: 'flex', alignItems: 'center', justifyContent: 'center',
        cursor: 'pointer', lineHeight: 1,
      }
    }, '✕') : null,
    // Resize handle
    createElement('div', {
      'data-resize': '1',
      onMouseDown: onResizeDown,
      style: {
        position: 'absolute', bottom: 0, right: 0,
        width: 20, height: 20, cursor: 'nwse-resize',
        display: 'flex', alignItems: 'flex-end', justifyContent: 'flex-end', padding: 4,
      }
    },
      createElement('div', { style: { width: 8, height: 8, pointerEvents: 'none', borderRight: '2px solid rgba(255,255,255,0.8)', borderBottom: '2px solid rgba(255,255,255,0.8)' } })
    )
  );
};

