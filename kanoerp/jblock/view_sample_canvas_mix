  useEffect(function() {
    runSql(CONFIG.uid_canvas,
      "SELECT canvas.id AS id, canvas.name AS name, canvas.fk_collection_id AS fk_collection_id FROM canvas WHERE canvas.archive IS NULL OR canvas.archive = FALSE OR canvas.archive = 0 ORDER BY canvas.name ASC"
    ).then(function(rows) { setCanvasList(rows); });
    runSql(CONFIG.uid_cols,
      "SELECT id, name FROM collection ORDER BY name ASC"
    ).then(function(rows) { setCollections(rows); });
  }, []);

  useEffect(function() {
    if (!selectedCanvas) return;
    setLoading(true);
    setItems([]);

    var canvas = canvasList.find(function(c) { return String(c.id) === String(selectedCanvas); });
    if (!canvas) { setLoading(false); return; }

    Promise.all([
      runSql(CONFIG.uid_samples + '_' + canvas.fk_collection_id,
        "SELECT sample.id AS id, sample.name AS name, sample.status AS status, " +
        "attachments.url AS img_url, attachments.filename AS img_filename " +
        "FROM sample, t_wda3bnmr9c9, attachments " +
        "WHERE sample.fk_collection_id = " + canvas.fk_collection_id + " " +
        "AND t_wda3bnmr9c9.f_57nmxuosclw = sample.id " +
        "AND attachments.id = t_wda3bnmr9c9.f_3icqdx05qdd " +
        "AND sample.status <> 'cancel' " +
        "ORDER BY sample.name ASC, attachments.id ASC"
      ),
      fetchCanvasImages(selectedCanvas),
      loadLayout(selectedCanvas),
    ]).then(function(results) {
      var sampleRows = results[0];
      var imageRows  = results[1];
      var saved_layout = results[2];

      var seen = {};
      var samples = [];
      sampleRows.forEach(function(r) {
        var sid = String(r.id);
        if (!seen[sid]) {
          seen[sid] = true;
          samples.push({ id: sid, type: 'sample', name: r.name, status: r.status, img_url: buildImgUrl(r.img_filename, r.img_url) });
        }
      });

      var images = imageRows.map(function(r) {
        return {
          id: String(r.id), type: 'image',
          name: r.title || r.filename || 'image',
          img_url: buildImgUrl(r.filename, r.url),
        };
      });

      var layoutMap = {};
      if (saved_layout) {
        saved_layout.forEach(function(l) { layoutMap[String(l.id)] = l; });
      }

      // Position: use saved if exists, else stack in the left tray column.
      // Samples and manual images share one tray stacking sequence.
      var trayIndex = 0;
      function withPosition(it, defaultW, defaultH) {
        var pos = layoutMap[it.id];
        if (pos) {
          return Object.assign({}, it, { x: pos.x, y: pos.y, w: pos.w, h: pos.h, z: pos.z || 1 });
        }
        var tx = TRAY_X;
        var ty = 20 + trayIndex * (THUMB_H + 12);
        trayIndex++;
        return Object.assign({}, it, { x: tx, y: ty, w: defaultW, h: defaultH, z: trayIndex });
      }

      var positionedSamples = samples.map(function(s) { return withPosition(s, THUMB_W, THUMB_H); });
      var positionedImages  = images.map(function(im) { return withPosition(im, THUMB_W, THUMB_H); });

      // Text comments have no backing table row — their full content lives
      // only in the saved layout JSON, so pull them straight from there.
      var texts = (saved_layout || [])
        .filter(function(l) { return l.type === 'text'; })
        .map(function(l) {
          return {
            id: l.id, type: 'text',
            text: l.text, color: l.color, fontSize: l.fontSize, bg: l.bg,
            x: l.x, y: l.y, w: l.w, h: l.h, z: l.z || 1,
          };
        });

      setItems(positionedSamples.concat(positionedImages, texts));
      setLoading(false);
    });
  }, [selectedCanvas]);

  var handleUpdate = useCallback(function(id, patch) {
    setItems(function(prev) {
      return prev.map(function(it) { return it.id === id ? Object.assign({}, it, patch) : it; });
    });
    setSaved(false);
  }, []);

  var handleDelete = useCallback(function(id) {
    setItems(function(prev) {
      var it = prev.find(function(x) { return x.id === id; });
      if (it && it.type === 'image' && selectedCanvas) {
        unlinkImageFromCanvas(selectedCanvas, it.id).catch(function(e) {
          console.error('Failed to unlink image from canvas:', e);
        });
      }
      return prev.filter(function(x) { return x.id !== id; });
    });
    setSaved(false);
    setFocused(function(f) { return f === id ? null : f; });
  }, [selectedCanvas]);

  function handleSave() {
    if (!selectedCanvas) return;
    saveLayout(selectedCanvas, items).then(function() {
      setSaved(true);
      setTimeout(function() { setSaved(false); }, 2000);
    });
  }

  function handleResetTray() {
    setItems(function(prev) {
      return prev.map(function(it, i) {
        return Object.assign({}, it, {
          x: TRAY_X,
          y: 20 + i * (THUMB_H + 12),
          w: it.type === 'sample' ? THUMB_W : it.w,
          h: it.type === 'sample' ? THUMB_H : it.h,
          z: i + 1,
        });
      });
    });
    setSaved(false);
  }

  function handleArchive() {
    if (!selectedCanvas) return;
    Modal.confirm({
      title: 'Archive Canvas',
      content: 'This canvas will be hidden from the list. Continue?',
      okText: 'Archive',
      okButtonProps: { danger: true },
      onOk: function() {
        var sql = "UPDATE canvas SET archive = TRUE WHERE id = " + selectedCanvas;
        console.log('Archiving:', sql);
        execSql('canvas_archive_' + selectedCanvas, sql)
        .then(function(res) {
          console.log('Archive result:', JSON.stringify(res));
          return runSql('canvas_list_reload',
            "SELECT canvas.id AS id, canvas.name AS name, canvas.fk_collection_id AS fk_collection_id FROM canvas WHERE canvas.archive IS NULL OR canvas.archive = FALSE OR canvas.archive = 0 ORDER BY canvas.name ASC"
          );
        }).then(function(rows) {
          setCanvasList(rows);
          setSelectedCanvas(null);
          setItems([]);
        }).catch(function(e) { console.error('Archive error:', e); });
      }
    });
  }

  function handleCreateCanvas() {
    try {
      const popupUid = ctx.model.uid + '-2';
      ctx.openView(popupUid, { mode: 'drawer', title: 'New Canvas', size: 'large' });
    } catch(e) {
      console.error('openView error:', e);
    }
  }

  function handleAddImageMenuToggle() {
    if (!selectedCanvas || uploading) return;
    setShowImgMenu(function(v) { return !v; });
  }

  function handleChooseUpload() {
    setShowImgMenu(false);
    if (fileInputRef.current) fileInputRef.current.click();
  }

  function handleChooseBrowse() {
    setShowImgMenu(false);
    setShowBrowseModal(true);
  }

  function handleFileSelected(e) {
    var file = e.target.files && e.target.files[0];
    e.target.value = ''; // allow re-selecting the same file later
    if (!file || !selectedCanvas) return;
    var canvasId = selectedCanvas;

    setUploading(true);
    Promise.resolve()
      .then(function() { return uploadAttachment(file); })
      .then(function(att) {
        return linkImageToCanvas(canvasId, att.id).then(function() { return att; });
      })
      .then(function(att) {
        var newItem = {
          id: String(att.id),
          type: 'image',
          name: att.title || att.filename || file.name,
          img_url: buildImgUrl(att.filename, att.url),
          x: TRAY_X, y: 20, w: THUMB_W, h: THUMB_H, z: nextZ(),
        };
        setItems(function(prev) { return prev.concat([newItem]); });
        setFocused(newItem.id);
        setSaved(false);
      })
      .catch(function(err) {
        console.error('Image upload failed:', err);
        Modal.error({
          title: 'Upload failed',
          content: (err && err.message) || 'Could not upload the image. Check the console for details.',
        });
      })
      .then(function() { setUploading(false); });
  }

  // Links already-existing attachments (picked from the browse modal) into
  // canvas.images, one at a time (sequential awaits, consistent with the
  // rest of this codebase's write patterns).
  async function linkChosenImages(canvasId, chosen) {
    var linked = [];
    for (var i = 0; i < chosen.length; i++) {
      var im = chosen[i];
      try {
        await linkImageToCanvas(canvasId, im.attachmentId);
        linked.push(im);
      } catch (e) {
        console.error('Failed to link image ' + im.attachmentId + ' to canvas:', e);
      }
    }
    return linked;
  }

  function handleBrowseConfirm(chosen) {
    setShowBrowseModal(false);
    if (!chosen || !chosen.length || !selectedCanvas) return;
    var canvasId = selectedCanvas;

    setUploading(true);
    linkChosenImages(canvasId, chosen)
      .then(function(linked) {
        if (!linked.length) {
          Modal.error({ title: 'Add failed', content: 'Could not add the selected image(s). Check the console for details.' });
          return;
        }
        var newItems = linked.map(function(im) {
          return {
            id: String(im.attachmentId), type: 'image',
            name: im.title || im.label, img_url: im.img_url,
            x: TRAY_X, y: 20, w: THUMB_W, h: THUMB_H, z: nextZ(),
          };
        });
        setItems(function(prev) { return prev.concat(newItems); });
        setSaved(false);
      })
      .then(function() { setUploading(false); });
  }

  function handleAddText() {
    if (!selectedCanvas) return;
    var newItem = {
      id: newItemId('txt'),
      type: 'text',
      text: '',
      color: '#1e293b',
      fontSize: 14,
      bg: '#fff9db',
      x: TRAY_X, y: 20, w: 180, h: 100, z: nextZ(),
    };
    setItems(function(prev) { return prev.concat([newItem]); });
    setFocused(newItem.id);
    setSaved(false);
  }

  return createElement('div', {
    style: { display: 'flex', flexDirection: 'column', height: '100vh', fontFamily: 'system-ui,sans-serif' }
  },

    // Hidden file input for manual image uploads
    createElement('input', {
      ref: fileInputRef, type: 'file', accept: 'image/*',
      style: { display: 'none' },
      onChange: handleFileSelected,
    }),

    // New canvas modal
    createElement(Modal, {
      title: 'New Canvas',
      open: showModal,
      onCancel: function() { setShowModal(false); },
      onOk: handleCreateCanvas,
      okText: 'Create',
    },
      createElement('div', { style: { display: 'flex', flexDirection: 'column', gap: 12, paddingTop: 8 } },
        createElement('div', null,
          createElement('div', { style: { fontSize: 12, color: '#6b7280', marginBottom: 4 } }, 'Canvas name'),
          createElement(Input, {
            value: newName,
            onChange: function(e) { setNewName(e.target.value); },
            placeholder: 'e.g. Inkano Floral Season 1',
          })
        ),
        createElement('div', null,
          createElement('div', { style: { fontSize: 12, color: '#6b7280', marginBottom: 4 } }, 'Collection'),
          createElement(Select, {
            value: newColId || undefined,
            onChange: function(v) { setNewColId(v); },
            placeholder: 'Select collection…',
            style: { width: '100%' },
            options: collections.map(function(c) { return { value: String(c.id), label: c.name }; }),
          })
        )
      )
    ),

    // Browse-existing-images modal
    createElement(BrowseImagesModal, {
      open: showBrowseModal,
      collections: collections,
      existingIds: (function() {
        var map = {};
        items.forEach(function(it) { if (it.type === 'image') map[it.id] = true; });
        return map;
      })(),
      onClose: function() { setShowBrowseModal(false); },
      onConfirm: handleBrowseConfirm,
    }),

    // Toolbar
    createElement('div', {
      style: {
        display: 'flex', alignItems: 'center', gap: 10,
        padding: '8px 16px', background: '#fff',
        borderBottom: '1px solid #e8e4df', flexShrink: 0,
        boxShadow: '0 1px 3px rgba(0,0,0,0.06)',
      }
    },
      createElement('span', { style: { fontSize: 13, fontWeight: 700, color: '#1e293b' } }, '🎨 Canvas'),
      createElement(Select, {
        value: selectedCanvas,
        onChange: function(v) { setSelectedCanvas(v); setSaved(false); },
        placeholder: 'Select a canvas…',
        style: { minWidth: 200 },
        options: canvasList.map(function(c) { return { value: String(c.id), label: c.name }; }),
      }),
      createElement('span', { style: { fontSize: 11, color: '#9ca3af' } },
        selectedCanvas ? items.length + ' items · drag to arrange · tray on left' : ''
      ),
      createElement('div', { style: { flex: 1 } }),
      selectedCanvas ? createElement('div', { style: { position: 'relative' } },
        createElement('button', {
          onClick: handleAddImageMenuToggle,
          disabled: uploading,
          style: {
            padding: '5px 12px', fontSize: 11, cursor: uploading ? 'default' : 'pointer',
            border: '1px solid #e2e8f0', borderRadius: 5, background: '#fff',
            color: uploading ? '#c8c3bc' : '#64748b',
          }
        }, uploading ? 'Uploading…' : '+ Image ▾'),
        showImgMenu ? createElement('div', {
          onClick: function() { setShowImgMenu(false); },
          style: { position: 'fixed', inset: 0, zIndex: 998 }
        }) : null,
        showImgMenu ? createElement('div', {
          style: {
            position: 'absolute', top: '100%', left: 0, marginTop: 4, zIndex: 999,
            background: '#fff', border: '1px solid #e2e8f0', borderRadius: 6,
            boxShadow: '0 8px 24px rgba(0,0,0,0.12)', minWidth: 190, overflow: 'hidden',
          }
        },
          createElement('div', {
            onClick: handleChooseUpload,
            style: { padding: '9px 12px', fontSize: 12, cursor: 'pointer', color: '#374151', borderBottom: '1px solid #f1f5f9' }
          }, '⬆ Upload New Image'),
          createElement('div', {
            onClick: handleChooseBrowse,
            style: { padding: '9px 12px', fontSize: 12, cursor: 'pointer', color: '#374151' }
          }, '🗂 Choose from Collection')
        ) : null
      ) : null,
      selectedCanvas ? createElement('button', {
        onClick: handleAddText,
        style: { padding: '5px 12px', fontSize: 11, cursor: 'pointer', border: '1px solid #e2e8f0', borderRadius: 5, background: '#fff', color: '#64748b' }
      }, '+ Text') : null,
      selectedCanvas ? createElement('button', {
        onClick: handleResetTray,
        style: { padding: '5px 12px', fontSize: 11, cursor: 'pointer', border: '1px solid #e2e8f0', borderRadius: 5, background: '#fff', color: '#64748b' }
      }, 'Reset to Tray') : null,
      selectedCanvas ? createElement('button', {
        onClick: handleArchive,
        style: { padding: '5px 12px', fontSize: 11, cursor: 'pointer', border: '1px solid #fca5a5', borderRadius: 5, background: '#fef2f2', color: '#ef4444' }
      }, 'Archive') : null,
      selectedCanvas ? createElement('button', {
        onClick: handleSave,
        style: {
          padding: '5px 14px', fontSize: 11, cursor: 'pointer', border: 'none',
          borderRadius: 5, fontWeight: 700, color: '#fff',
          background: saved ? '#22c55e' : '#6366f1', transition: 'background 0.3s',
        }
      }, saved ? '✓ Saved' : 'Save Layout') : null,
      createElement('button', {
        onClick: function() {
          try {
            var popupUid = ctx.model.uid + '-1';
            ctx.openView(popupUid, { mode: 'drawer', title: 'New Canvas', size: 'middle' });

            // Poll for new canvases every 1.5s for up to 30s
            var currentIds = new Set(canvasList.map(function(c) { return String(c.id); }));
            var attempts = 0;
            var maxAttempts = 20;

            var interval = setInterval(function() {
              attempts++;
              if (attempts > maxAttempts) { clearInterval(interval); return; }

              var pollUid = 'canvas_poll_' + Date.now();
              runSql(pollUid,
                "SELECT canvas.id AS id, canvas.name AS name, canvas.fk_collection_id AS fk_collection_id FROM canvas WHERE canvas.archive IS NULL OR canvas.archive = FALSE OR canvas.archive = 0 ORDER BY canvas.name ASC"
              ).then(function(rows) {
                var hasNew = rows.some(function(r) { return !currentIds.has(String(r.id)); });
                if (hasNew) {
                  clearInterval(interval);
                  setCanvasList(rows);
                }
              });
            }, 1500);
          } catch(e) { console.error(e); }
        },
        style: { padding: '5px 12px', fontSize: 11, cursor: 'pointer', border: '1px solid #6366f1', borderRadius: 5, background: '#eef2ff', color: '#6366f1', fontWeight: 600 }
      }, '+ New Canvas')
    ),

    // Canvas
    createElement('div', {
      onClick: function() { setFocused(null); },
      style: {
        flex: 1, overflow: 'auto',
        background: '#f7f5f2',
        backgroundImage: 'radial-gradient(circle, #d8d3cd 1px, transparent 1px)',
        backgroundSize: '28px 28px',
      }
    },
      createElement('div', { style: { position: 'relative', width: CANVAS_W, height: CANVAS_H } },

        // Tray divider line on the LEFT
        selectedCanvas
          ? createElement('div', {
              style: {
                position: 'absolute', left: TRAY_COL_W, top: 0, bottom: 0,
                width: 1, borderLeft: '1px dashed #c8c3bc',
                pointerEvents: 'none',
              }
            },
              createElement('div', {
                style: {
                  position: 'sticky', top: 12,
                  fontSize: 9, color: '#b8b3ac', fontWeight: 700,
                  textTransform: 'uppercase', letterSpacing: '0.1em',
                  writingMode: 'vertical-rl', paddingLeft: 4,
                }
              }, 'Tray ↑ drag to canvas →')
            )
          : null,

        loading
          ? createElement('div', { style: { position: 'absolute', top: '40%', left: '45%', color: '#9ca3af', fontSize: 13 } }, 'Loading…')
          : !selectedCanvas
            ? createElement('div', { style: { position: 'absolute', top: '40%', left: '45%', transform: 'translate(-50%,-50%)', color: '#c8c3bc', fontSize: 14, textAlign: 'center' } },
                createElement('div', { style: { fontSize: 36, marginBottom: 8 } }, '🎨'),
                'Select a canvas to begin'
              )
            : items.map(function(item) {
                if (item.type === 'text') {
                  return createElement(TextTile, {
                    key: item.id, item: item,
                    isFocused: focused === item.id,
                    onUpdate: handleUpdate,
                    onFocus: setFocused,
                    onDelete: handleDelete,
                  });
                }
                return createElement(ImageTile, {
                  key: item.id, item: item,
                  isFocused: focused === item.id,
                  onUpdate: handleUpdate,
                  onFocus: setFocused,
                  onDelete: handleDelete,
                });
              })
      )
    )
  );
};

ctx.render(createElement(Comp));
