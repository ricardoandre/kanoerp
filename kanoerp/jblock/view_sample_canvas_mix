};

function runSql(uid, sql) {
  var s = getSql();
  if (!s) return Promise.resolve([]);
  return s.save({ uid: uid, sql: sql, dataSourceKey: 'main' })
    .catch(function(){})
    .then(function() {
      return s.runById(uid, { type: 'selectRows', dataSourceKey: 'main' });
    })
    .then(function(r) { return r || []; });
}

function execSql(uid, sql) {
  var s = getSql();
  if (!s) return Promise.resolve(null);
  return s.save({ uid: uid, sql: sql, dataSourceKey: 'main' })
    .catch(function(){})
    .then(function() {
      return s.runById(uid, { type: 'exec', dataSourceKey: 'main' });
    });
}

function buildImgUrl(filename, url) {
  if (url) return url;
  if (filename) return window.location.origin + '/storage/uploads/' + filename;
  return '';
}

// Both 'sample' and 'image' items are backed by real DB rows (sample table /
// canvas.images attachments relation) and are re-fetched fresh on every load,
// so layout only needs to remember their position. Only 'text' items have no
// backing row — their full content lives in the layout JSON itself.
function saveLayout(canvasId, items) {
  var val = JSON.stringify(items.map(function(it) {
    var base = { id: it.id, type: it.type || 'sample', x: it.x, y: it.y, w: it.w, h: it.h, z: it.z || 1 };
    if (it.type === 'text') {
      base.text = it.text || '';
      base.color = it.color || '#1e293b';
      base.fontSize = it.fontSize || 14;
      base.bg = it.bg || '#fff9db';
    }
    return base;
  }));
  var escaped = val.replace(/'/g, "''");
  return execSql('canvas_save_' + canvasId,
    "UPDATE canvas SET layout = '" + escaped + "' WHERE id = " + canvasId
  );
}

function loadLayout(canvasId) {
  return runSql('canvas_load_' + canvasId,
    "SELECT CAST(layout AS CHAR) AS layout FROM canvas WHERE id = " + canvasId
  ).then(function(rows) {
    if (!rows || !rows.length || !rows[0].layout) return null;
    try { return JSON.parse(rows[0].layout); } catch(e) { return null; }
  });
}

// ── canvas.images relation (attachment field) ──────────────────
// Same introspection pattern already used elsewhere in this codebase for
// product.image: attachment fields aren't real SQL columns, so we read the
// field's through-table + keys from `fields` once, then join `attachments`.
var _canvasImgMetaCache = null;
function getCanvasImagesMeta() {
  if (_canvasImgMetaCache) return Promise.resolve(_canvasImgMetaCache);
  return runSql('canvas_imgmeta',
    "SELECT CAST(options AS CHAR) AS options FROM fields WHERE collection_name='canvas' AND name='images'"
  ).then(function(rows) {
    if (!rows.length) return null;
    var opt = {};
    try { opt = JSON.parse(rows[0].options || '{}'); } catch(e) { return null; }
    var meta = { through: opt.through, fk: opt.foreignKey, ok: opt.otherKey, sk: opt.sourceKey || 'id' };
    if (!meta.through || !meta.fk || !meta.ok) return null;
    _canvasImgMetaCache = meta;
    return meta;
  }).catch(function() { return null; });
}

function fetchCanvasImages(canvasId) {
  return getCanvasImagesMeta().then(function(meta) {
    if (!meta) return [];
    return runSql('canvas_imgs_' + canvasId,
      "SELECT attachments.id AS id, attachments.title AS title, attachments.url AS url, attachments.filename AS filename " +
      "FROM canvas " +
      "JOIN " + meta.through + " ON " + meta.through + "." + meta.fk + " = canvas." + meta.sk + " " +
      "JOIN attachments ON attachments.id = " + meta.through + "." + meta.ok + " " +
      "WHERE canvas.id = " + canvasId + " " +
      "ORDER BY attachments.id ASC"
    );
  }).catch(function() { return []; });
}

// ── Browse existing images (sample.reference_images + sample_variant.image) ──
// for a given collection, so they can be linked into canvas.images without
// re-uploading. Junction tables confirmed via schema dump.
function fetchCollectionImages(collectionId) {
  return Promise.all([
    runSql('browse_sample_' + collectionId,
      "SELECT sample.id AS sample_id, sample.name AS sample_name, " +
      "attachments.id AS attachment_id, attachments.title AS title, attachments.url AS url, attachments.filename AS filename " +
      "FROM sample " +
      "JOIN t_wda3bnmr9c9 ON t_wda3bnmr9c9.f_57nmxuosclw = sample.id " +
      "JOIN attachments ON attachments.id = t_wda3bnmr9c9.f_3icqdx05qdd " +
      "WHERE sample.fk_collection_id = " + collectionId + " AND sample.status <> 'cancel' " +
      "ORDER BY sample.name ASC, attachments.id ASC"
    ),
    runSql('browse_variant_' + collectionId,
      "SELECT sample.id AS sample_id, sample.name AS sample_name, " +
      "attachments.id AS attachment_id, attachments.title AS title, attachments.url AS url, attachments.filename AS filename " +
      "FROM sample_variant " +
      "JOIN sample ON sample_variant.fk_sample_variant_id = sample.id " +
      "JOIN t_hq2tyo4911x ON t_hq2tyo4911x.f_9uw8zn7ipd2 = sample_variant.id " +
      "JOIN attachments ON attachments.id = t_hq2tyo4911x.f_bv8dcij84et " +
      "WHERE sample.fk_collection_id = " + collectionId + " AND sample.status <> 'cancel' " +
      "ORDER BY sample.name ASC, sample_variant.id ASC, attachments.id ASC"
    ),
  ]).then(function(results) {
    var sampleRows  = results[0] || [];
    var variantRows = results[1] || [];
    var seen = {};
    var out = [];
    sampleRows.forEach(function(r) {
      var aid = String(r.attachment_id);
      if (seen[aid]) return;
      seen[aid] = true;
      out.push({ attachmentId: aid, label: r.sample_name, title: r.title, img_url: buildImgUrl(r.filename, r.url) });
    });
    variantRows.forEach(function(r) {
      var aid = String(r.attachment_id);
      if (seen[aid]) return;
      seen[aid] = true;
      out.push({ attachmentId: aid, label: r.sample_name + ' · variant', title: r.title, img_url: buildImgUrl(r.filename, r.url) });
    });
    return out;
  }).catch(function() { return []; });
}

// Upload a new file: POST to attachments:create (multipart), which both
// creates the attachment row and returns it. Mirrors the exact request the
// normal NocoBase "images" upload field makes (confirmed via devtools).
// Wrapped in Promise.resolve().then(...) so ANY synchronous throw (e.g. an
// unexpected shape of ctx.api) becomes a rejected promise instead of an
// uncaught exception — otherwise the caller's .catch never runs and the UI
// gets stuck on "Uploading…" forever with no error shown.
function uploadAttachment(file) {
  return Promise.resolve().then(function() {
    var FD = (typeof window !== 'undefined' && window.FormData) ? window.FormData
            : (typeof FormData !== 'undefined' ? FormData : null);
    var fd;
    try {
      fd = new FD(); // eslint-disable-line new-cap
    } catch (e) {
      throw new Error(
        'FormData is unavailable or blocked in this context ' +
        '(typeof FormData=' + typeof FormData + ', typeof window.FormData=' + (typeof window !== 'undefined' ? typeof window.FormData : 'no window') + '). ' +
        'Original error: ' + (e && e.message)
      );
    }
    fd.append('file', file);
    var cfg = { url: 'attachments:create', method: 'POST', params: { attachmentField: 'canvas.images' }, data: fd };

    if (ctx.api && typeof ctx.api.request === 'function') {
      return ctx.api.request(cfg);
    }
    if (ctx.api && ctx.api.axios && typeof ctx.api.axios.post === 'function') {
      return ctx.api.axios.post(cfg.url, fd, { params: cfg.params });
    }
    throw new Error('No usable upload method found on ctx.api (checked ctx.api.request and ctx.api.axios.post).');
  }).then(function(res) {
    var att = res && res.data && res.data.data;
    if (!att || !att.id) throw new Error('Upload succeeded but no attachment id came back. Raw response: ' + JSON.stringify(res && res.data));
    return att;
  });
}

// Link an already-uploaded attachment into this canvas record's `images`
// relation, using NocoBase's association-resource "add" action.
function linkImageToCanvas(canvasId, attachmentId) {
  return Promise.resolve().then(function() {
    return ctx.api.resource('canvas.images', canvasId).add({ values: [attachmentId] });
  });
}

function unlinkImageFromCanvas(canvasId, attachmentId) {
  return Promise.resolve().then(function() {
    return ctx.api.resource('canvas.images', canvasId).remove({ values: [attachmentId] });
  });
}

