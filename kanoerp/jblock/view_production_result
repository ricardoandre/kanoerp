// =====================================================
// CONFIG
// =====================================================
const config = {
  title: 'Production Results',
  css: VIEW_CSS,
  searchPlaceholder: 'Search konveksi, product code, name, ref…',
  emptyText: 'No production results match this filter',
  pageSize: 15,

  // message box below the title (engine renders it). Warn when any result is
  // not yet linked to a production.
  banner: function(data) {
    const unmatched = (data || []).filter(function(r) { return !r.production_id; }).length;
    if (!unmatched) return null;
    return { type: 'warning', text: 'There are ' + unmatched + ' production result(s) not yet matched to a production. Please trigger the Match Production action.' };
  },

  fetchList: fetchList,
  fetchImages: fetchImages,
  fetchExtra: fetchExtra,
  getImage: (row, map) => (map && map[rowCode(row)]) || '',

  searchText: r => [r.konveksi_name, r.product_code, r.import_product_code, r.product_name, r.production_ref],

  // main filter: NA (no mainTabs)

  secondaryFilters: [
    { key: 'production', label: 'Production', kind: 'select', search: true, allLabel: 'All',
      options: function(data) {
        const refs = uniq((data || []).map(function(r) { return r.production_ref; })).filter(function(x) { return x != null && x !== ''; }).sort();
        return [{ value: '__none__', label: '(No production — unmatched)' }].concat(refs);
      },
      match: function(r, v) { return v === '__none__' ? !r.production_id : String(r.production_ref) === String(v); } },
    { key: 'konveksi', label: 'Konveksi name', kind: 'select', field: 'konveksi_name', search: true, allLabel: 'All' },
    { key: 'product_code', label: 'Product code', kind: 'select', field: 'product_code', search: true, allLabel: 'All' },
    { key: 'product_name', label: 'Product name', kind: 'select', field: 'product_name', search: true, allLabel: 'All' },
    { key: 'shipment', label: 'Shipment date', kind: 'dateRange', field: 'shipment_date' },
    { key: 'is_permakan', label: 'Is permakan', kind: 'select', allLabel: 'All', options: () => [{ value: 'yes', label: 'Permakan' }, { value: 'no', label: 'Regular' }], match: (r, v) => v === 'yes' ? !!r.is_permakan : !r.is_permakan },
    { key: 'checking_pic', label: 'Checking PIC', kind: 'select', field: 'checking_pic', search: true, allLabel: 'All' },
  ],

  sortOptions: [
    { key: 'created_desc', label: 'Newest' },
    { key: 'ship_desc', label: 'Shipment ↓' },
    { key: 'ship_asc', label: 'Shipment ↑' },
  ],
  sortComparator: function(key) {
    if (key === 'created_desc') return null;
    const dir = key === 'ship_asc' ? 1 : -1;
    return function(a, b) {
      const av = a.shipment_date ? new Date(a.shipment_date).getTime() : (dir === 1 ? Infinity : -Infinity);
      const bv = b.shipment_date ? new Date(b.shipment_date).getTime() : (dir === 1 ? Infinity : -Infinity);
      return (av - bv) * dir;
    };
  },

  renderCard: renderCard,

  detailTitle: r => (rowCode(r) || ('#' + r.id)) + (r.sku_display ? ' · ' + r.sku_display : ''),
  statusAccent: r => qtyColor(r.quantity),
  detailRender: (row, rk, helpers) => ce(ResultDetail, { row: row, imgMap: helpers && helpers.getImage ? null : null }),

  newForm: { title: 'New Production Result', width: 480,
    initial: () => ({ shipment_date: todayStr(), production: null, sku_option: null, quantity: null, checking_pic: null, is_permakan: false, remarks: '' }),
    validate: f => !f.production ? 'Select a production.' : (!f.sku_option ? 'Select a SKU option.' : ((f.quantity === '' || f.quantity == null) ? 'Enter a quantity.' : null)),
    render: (form, setF, extra) => ce(ResultFormBody, { form: form, setF: setF, extra: extra }),
    submit: createResult, successMsg: 'Production result created.' },

  editForm: { title: 'Edit Production Result', width: 480,
    load: row => ({ shipment_date: toInputDate(row.shipment_date), production: row.production_id || null, sku_option: row.sku_option_id || null, quantity: (row.quantity == null ? null : row.quantity), checking_pic: row.checking_pic || null, is_permakan: !!row.is_permakan, remarks: row.remarks || '' }),
    validate: f => (f.quantity === '' || f.quantity == null) ? 'Enter a quantity.' : null,
    render: (form, setF, extra) => ce(ResultFormBody, { form: form, setF: setF, extra: extra }),
    submit: updateResult, successMsg: 'Production result updated.' },

  deleteRow: deleteResult,
  deleteTitle: 'Delete production result?',
  deleteLabel: row => (rowCode(row) || ('#' + row.id)),

  bulkActions: [
    { label: '🗑 Delete', bg: '#ef4444', color: '#fff', run: bulkDelete },
    { label: '🔗 Match production', bg: '#22c55e', color: '#fff', run: bulkMatch },
    { label: '⬆ Import', bg: '#0ea5e9', color: '#fff', requireSelection: false, run: bulkImport },
    { label: '✚ Bulk add', bg: '#4f46e5', color: '#fff', requireSelection: false, run: bulkAdd },
  ],
};

// detailRender needs imgMap; the engine passes it through getImage(row) via helpers.
// Wrap so the card image map is reused in the detail.
config.detailRender = function(row, rk, helpers) {
  const img = helpers && helpers.getImage ? helpers.getImage(row) : '';
  return ce(ResultDetail, { row: row, imgMap: { [rowCode(row)]: img },
    onOpenProduction: function(pid) {
      if (helpers && helpers.closeDetail) helpers.closeDetail();
      if (navRef.open) navRef.open('production', pid, helpers);
    } });
};

// ── record nav host (cross-record replace navigation: production_ref → production detail) ──
const RecordNavHost = function() {
  const sC = useState(null); const Mod = sC[0]; const setMod = sC[1];
  useEffect(function() { loadCode('ui_record_nav').then(setMod).catch(function() {}); }, []);
  if (!Mod || !Mod.RecordNav) return null;
  return ce(Mod.RecordNav, { navRef: navRef });
};

// =====================================================
// ROOT
// =====================================================
const Root = function() {
  const sLV = useState(null); const LV = sLV[0]; const setLV = sLV[1];
  const sErr = useState(null); const err = sErr[0]; const setErr = sErr[1];
  useEffect(function() {
    loadCode('ui_list_engine').then(function(M) { setLV(function() { return M.createListView(config); }); })
      .catch(function(e) { setErr((e && e.message) || String(e)); });
  }, []);
  if (err) return ce('div', { style: { color: '#ef4444', padding: 16 } }, 'Failed to load ui_list_engine: ' + err);
  if (!LV) return ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, 'Loading…');
  return ce('div', null, ce(LV), ce(RecordNavHost, null));
};

ctx.render(ce(Root));
