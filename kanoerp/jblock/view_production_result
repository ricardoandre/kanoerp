  const row = o.row, selectMode = o.selectMode, selected = o.selected;
  const img = (o.imgMap && o.imgMap[rowCode(row)]) || '';
  return ce('div', { className: 'prr-cardbody' },
    selectMode ? ce('div', { style: { width: 22, height: 22, borderRadius: 6, flexShrink: 0, border: '2px solid ' + (selected ? '#6366f1' : '#cbd5e1'), background: selected ? '#6366f1' : '#fff', color: '#fff', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 14 } }, selected ? '✓' : '') : null,
    ce('div', { style: { width: 56, height: 56, borderRadius: 10, flexShrink: 0, background: '#f3f4f6', overflow: 'hidden', display: 'flex', alignItems: 'center', justifyContent: 'center' } },
      img ? ce('img', { src: img, style: { width: '100%', height: '100%', objectFit: 'cover' } }) : ce('span', { style: { fontSize: 20, color: '#cbd5e1' } }, '👕')),
    ce('div', { style: { flex: 1, minWidth: 0 } },
      ce('div', { style: { fontWeight: 700, fontSize: 14, color: '#111827', marginBottom: 3, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, rowCode(row) || '—'),
      ce('div', { style: { fontSize: 12, color: '#6b7280', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, row.product_name || '—'),
      ce('div', { style: { fontSize: 11, color: '#9ca3af', marginTop: 2, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, row.konveksi_name || '—'),
      ce('div', { style: { display: 'flex', alignItems: 'center', gap: 6, flexWrap: 'wrap', marginTop: 5 } },
        row.checking_pic ? ce('span', { style: { fontSize: 11, color: '#64748b' } }, '👤 ' + picLabel(row.checking_pic)) : null,
        row.is_permakan ? ce('span', { style: { background: '#fef2f2', color: '#ef4444', border: '1px solid #fca5a5', borderRadius: 4, padding: '0 6px', fontSize: 10, fontWeight: 700 } }, 'PERMAK') : null)),
    ce('div', { className: 'prr-col-meta' },
      ce('div', { style: { display: 'flex', alignItems: 'center', gap: 6, justifyContent: 'flex-end' } },
        row.sku_display ? ce('span', { style: { background: '#eef2ff', color: '#4338ca', borderRadius: 4, padding: '1px 8px', fontSize: 11, fontWeight: 600 } }, row.sku_display) : null,
        ce('span', { style: { fontSize: 18, fontWeight: 800, color: qtyColor(row.quantity), lineHeight: 1.1 } }, qtyText(row.quantity))),
      ce('div', { style: { fontSize: 9, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.05em', marginTop: 6 } }, 'Shipment'),
      ce('div', { style: { fontSize: 12, fontWeight: 600, color: '#374151' } }, fmtDateNumeric(row.shipment_date) || '—')));
}

// =====================================================
// BULK ACTION HANDLERS
// =====================================================
function bulkDelete(ids, helpers) {
  Modal.confirm({ title: 'Delete ' + ids.length + ' result(s)?', content: 'This cannot be undone.', okText: 'Delete', okButtonProps: { danger: true },
    onOk: () => Promise.all(ids.map(id => deleteResult(id))).then(() => { message.success('Deleted ' + ids.length + '.'); helpers.exitSelect(); helpers.reload(); }).catch(e => message.error('Bulk delete failed: ' + ((e && e.message) || e))) });
}
function bulkMatch(ids, helpers) {
  // verification: selected rows must NOT already be matched to a production
  const idList = ids.map(x => "'" + x + "'").join(',');
  runSql('prr_match_check', "SELECT id, fk_production_id FROM production_result WHERE id IN (" + idList + ")")
    .then(function(rows) {
      const already = rows.filter(r => r.fk_production_id != null).map(r => r.id);
      if (already.length) {
        Modal.warning({ title: 'Some rows are already matched', content: already.length + ' of ' + ids.length + ' selected row(s) already have a production linked. Deselect them and try again — matching only applies to unmatched results.' });
        return;
      }
      loadCode('ui_match_production')
        .then(MP => MP.openMatchModal({ ctx, ids, onDone: () => { helpers.exitSelect(); helpers.reload(); } }))
        .catch(e => message.error('Match module not installed yet: ' + ((e && e.message) || e)));
    })
    .catch(e => message.error('Verification failed: ' + ((e && e.message) || e)));
}
function bulkImport(ids, helpers) {
  loadCode('ui_result_import')
    .then(IM => IM.openImportModal({ ctx, onSaved: () => { helpers.exitSelect(); helpers.reload(); } }))
    .catch(() => message.warning('Import module (ui_result_import) is not installed yet.'));
}
function bulkAdd(ids, helpers) {
  loadCode('ui_result_bulk_add')
    .then(BA => BA.openBulkAddModal({ ctx, onSaved: () => { helpers.exitSelect(); helpers.reload(); } }))
    .catch(() => message.warning('Bulk-add module (ui_result_bulk_add) is not installed yet.'));
}

