const ALL_METRICS = [
  { key: 'spend',             label: 'Total Spend' },
  { key: 'reach',             label: 'Reach' },
  { key: 'cost_reach',        label: 'Cost/Reach' },
  { key: 'impressions',       label: 'Impressions' },
  { key: 'cpm',               label: 'CPM' },
  { key: 'ctr',               label: 'CTR' },
  { key: 'clicks',            label: 'Clicks' },
  { key: 'cost_click',        label: 'Cost/Click' },
  { key: 'link_clicks',       label: 'Link Clicks' },
  { key: 'cost_link_click',   label: 'Cost/Link Click' },
  { key: 'lpv',               label: 'Landing Page Views' },
  { key: 'cost_lpv',          label: 'Cost/LPV' },
  { key: 'registration',      label: 'Registration' },
  { key: 'cost_registration', label: 'Cost/Registration' },
  { key: 'atc',               label: 'ATC' },
  { key: 'cost_atc',          label: 'Cost/ATC' },
  { key: 'checkout',          label: 'Checkout' },
  { key: 'cost_checkout',     label: 'Cost/Checkout' },
  { key: 'purchase',          label: 'Purchase' },
  { key: 'cost_purchase',     label: 'Cost/Purchase' },
  { key: 'revenue',           label: 'Purchase Amt' },
  { key: 'roas',              label: 'ROAS' },
  { key: 'frequency',         label: 'Frequency' },
];
function metricFmt(key, v) {
  if (['spend', 'cpm', 'cost_click', 'cost_link_click', 'cost_lpv', 'cost_registration', 'cost_atc', 'cost_checkout', 'cost_purchase', 'revenue'].indexOf(key) !== -1) return fn.fmtMoney(v);
  if (key === 'ctr') return fn.fmtPct(v);
  if (['cost_reach', 'roas', 'frequency'].indexOf(key) !== -1) return fn.fmtRatio(v);
  return fn.fmtNum(v);
}
function getObjCols(objKey) {
  if (objKey === 'purchase') return ['revenue', 'roas', 'frequency'].map(function (k) { return ALL_METRICS.find(function (m) { return m.key === k; }); });
  if (objKey === 'atc') return ['atc', 'cost_atc', 'frequency'].map(function (k) { return ALL_METRICS.find(function (m) { return m.key === k; }); });
  return ['reach', 'cost_reach', 'frequency'].map(function (k) { return ALL_METRICS.find(function (m) { return m.key === k; }); });
}

const GROWTH_METRICS = ['spend', 'atc', 'reach', 'revenue'];

const SORT_OPTIONS = [
  { label: 'Spend (High → Low)', value: 'spend_desc' },
  { label: 'Spend (Low → High)', value: 'spend_asc' },
  { label: 'Reach (High → Low)', value: 'reach_desc' },
  { label: 'Reach (Low → High)', value: 'reach_asc' },
  { label: 'ATC (High → Low)', value: 'atc_desc' },
  { label: 'ATC (Low → High)', value: 'atc_asc' },
  { label: 'Revenue Amount (High → Low)', value: 'revenue_desc' },
  { label: 'Revenue Amount (Low → High)', value: 'revenue_asc' },
];
const DEFAULT_SORT_COMBO = 'spend_desc';
function parseSortCombo(combo) {
  if (combo.slice(-4) === '_asc') return { key: combo.slice(0, -4), dir: 'asc' };
  return { key: combo.slice(0, -5), dir: 'desc' };
}
function latestMetricValue(row, periods, key) {
  if (!periods || !periods.length) return 0;
  const pr = row.periodMap[periods[0].key];
  if (!pr) return 0;
  return fn.num(computeMetrics(pr)[key]);
}
function sortComparator(periods, sortKey, sortDir) {
  return function (a, b) {
    const av = latestMetricValue(a, periods, sortKey), bv = latestMetricValue(b, periods, sortKey);
    return sortDir === 'asc' ? av - bv : bv - av;
  };
}

