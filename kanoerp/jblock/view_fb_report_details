function MetricCell(col, val) {
  return ce('div', { key: col.key },
    ce('div', { style: { fontSize: 10, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: 0.3 } }, col.label),
    ce('div', { style: { fontSize: 13, fontWeight: 600, color: '#111827' } }, metricFmt(col.key, val)));
