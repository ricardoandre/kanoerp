// =====================================================
// jblock — FACEBOOK ADS DETAILS REPORT
//
// Evaluate ads by structure: Campaign → Adset → Ad drilldown. Filter by
// account (single-select) + objective + Time window (Group by / Periods
// back / Last date, popover + local Apply) + sort. Daily granularity adds
// today as a leading column when sync-today.js has produced a row for it.
// Each row shows all periods side by side; Details panel shows the full
// metric breakdown for the LATEST period only.
//
// Shared logic/UI now lives in source_code rows (fn_fbads_data,
// ui_fbads_controls) — loaded via loadCode below, same pattern as
// view_production.js. Everything here is Structure-specific: the
// campaign/adset/ad drilldown, PeriodTable rendering, sort-by-metric combo.
//
// STATUS: fb_ads_status.status (Facebook's own effective_status).
// OBJECTIVE: fb_ads_status.objective_key, resolved via fn.resolveObjective
// — real Facebook data, falls back to name-guessing only when a campaign
// hasn't been synced yet (see ui.objectiveMetaBadge for the "guessed"/
// "mixed" indicators).
// =====================================================

const { React, antd, dayjs } = ctx.libs;
const { useState, useEffect } = React;
const { Spin, Segmented, Button, Select, InputNumber } = antd;
const ce = React.createElement;

const DEFAULT_PERIOD_COUNT = 7;
const DEFAULT_GRANULARITY = 'daily';

// ── shared code loader (README §3: jblocks cannot import each other) ──
let fn = null, ui = null;
const _codeCache = {};
async function loadCode(name) {
  if (_codeCache[name]) return _codeCache[name];
  const uid = 'code_' + name;
  const rows = await ctx.sql.save({ uid, dataSourceKey: 'main', sql: "SELECT code FROM source_code WHERE name='" + name + "'" })
    .then(() => ctx.sql.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }));
  const src = (rows && rows[0] && rows[0].code) || '';
  _codeCache[name] = new Function('React', 'antd', 'dayjs', 'ctx', src)(React, antd, dayjs, ctx);
  return _codeCache[name];
}

// =====================================================
// ── Structure-specific data layer (SQL fetchers, period-table shape) ──
// Account-filtered only at campaign level — adset/ad drill-downs are scoped
// by a specific campaign_id/adset_id already, so nothing downstream needs
// its own account filter.
// =====================================================
const METRICS_SELECT =
  "COALESCE(SUM(spend),0) AS spend, " +
  "COALESCE(SUM(reach),0) AS reach, " +
  "COALESCE(SUM(impressions),0) AS impressions, " +
  "COALESCE(SUM(clicks),0) AS clicks, " +
  "COALESCE(SUM(link_clicks),0) AS link_clicks, " +
  "COALESCE(SUM(landing_page_views),0) AS lpv, " +
  "COALESCE(SUM(registration),0) AS registration, " +
  "COALESCE(SUM(atc),0) AS atc, " +
  "COALESCE(SUM(checkout),0) AS checkout, " +
  "COALESCE(SUM(purchase),0) AS purchase, " +
  "COALESCE(SUM(revenue),0) AS revenue";

function computeMetrics(r) {
  const s = fn.num(r.spend), reach = fn.num(r.reach), imp = fn.num(r.impressions);
  const clk = fn.num(r.clicks), lc = fn.num(r.link_clicks), lpv = fn.num(r.lpv);
  const reg = fn.num(r.registration), atc = fn.num(r.atc), co = fn.num(r.checkout);
  const pur = fn.num(r.purchase), rev = fn.num(r.revenue);
  return {
    spend: s, reach: reach, impressions: imp, clicks: clk,
    link_clicks: lc, lpv: lpv, registration: reg, atc: atc,
    checkout: co, purchase: pur, revenue: rev,
    cost_reach: fn.safeDiv(s, reach),
    cpm: fn.safeDiv(s * 1000, imp),
    ctr: fn.safeDiv(lc * 100, imp),
    cost_click: fn.safeDiv(s, clk),
    cost_link_click: fn.safeDiv(s, lc),
    cost_lpv: fn.safeDiv(s, lpv),
    cost_registration: fn.safeDiv(s, reg),
    cost_atc: fn.safeDiv(s, atc),
    cost_checkout: fn.safeDiv(s, co),
    cost_purchase: fn.safeDiv(s, pur),
    roas: fn.safeDiv(rev, s),
    frequency: fn.safeDiv(imp, reach),
  };
}

function fetchCampaignsPeriodic(granularity, periods, selectedAccount) {
  const since = periods[periods.length - 1].start, until = periods[0].end;
  const keyExpr = fn.periodKeyExpr(granularity);
  return fn.runSql(ctx, 'fbstr_campaigns_p',
    "SELECT campaign_id, MAX(campaign_name) AS campaign_name, " + keyExpr + " AS period_key, " + METRICS_SELECT + " " +
    "FROM campaigns_insights " +
    "WHERE date BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    fn.accountFilterSql(selectedAccount) +
    "GROUP BY campaign_id, period_key"
  );
}
function fetchAdsetsPeriodic(campaignId, granularity, periods) {
  const since = periods[periods.length - 1].start, until = periods[0].end;
  const keyExpr = fn.periodKeyExpr(granularity);
  return fn.runSql(ctx, 'fbstr_adsets_p_' + campaignId,
    "SELECT adset_id, MAX(adset_name) AS adset_name, " + keyExpr + " AS period_key, " + METRICS_SELECT + " " +
    "FROM adsets_insights " +
    "WHERE campaign_id = " + fn.sqlStr(campaignId) + " " +
    "AND date BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "GROUP BY adset_id, period_key"
  );
}
function fetchAdsPeriodic(adsetId, granularity, periods) {
  const since = periods[periods.length - 1].start, until = periods[0].end;
  const keyExpr = fn.periodKeyExpr(granularity);
  return fn.runSql(ctx, 'fbstr_ads_p_' + adsetId,
    "SELECT ad_id, MAX(ad_name) AS ad_name, " + keyExpr + " AS period_key, " + METRICS_SELECT + " " +
    "FROM ads_insights " +
    "WHERE adset_id = " + fn.sqlStr(adsetId) + " " +
    "AND date BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "GROUP BY ad_id, period_key"
  );
}
function fetchAdImages() {
  return fn.runSql(ctx, 'fbstr_imgmeta', "SELECT CAST(options AS CHAR) AS options FROM fields WHERE collection_name='ads_creative' AND name='image'")
    .then(function (rows) {
      if (!rows.length) return {};
      let opt = {};
      try { opt = JSON.parse(rows[0].options || '{}'); } catch (e) { return {}; }
      const through = opt.through, fk = opt.foreignKey, ok = opt.otherKey, sk = opt.sourceKey || 'ad_id';
      if (!through || !fk || !ok) return {};
      return fn.runSql(ctx, 'fbstr_imgjoin',
        "SELECT ads_creative.ad_id AS ad_id, attachments.url AS url, attachments.filename AS filename " +
        "FROM ads_creative " +
        "JOIN " + through + " ON " + through + "." + fk + " = ads_creative." + sk + " " +
        "JOIN attachments ON attachments.id = " + through + "." + ok + " " +
        "ORDER BY attachments.id ASC"
      ).then(function (irows) {
        const map = {};
        irows.forEach(function (r) { if (!map[r.ad_id]) map[r.ad_id] = r.url || (r.filename ? '/storage/uploads/' + r.filename : ''); });
        return map;
      });
    }).catch(function () { return {}; });
}

function fetchCampaignPeriodReach(periodType, periods, campaignIds) {
  if (!campaignIds.length) return Promise.resolve([]);
  const since = periods[periods.length - 1].start, until = periods[0].start;
  return fn.runSql(ctx, 'fbstr_camp_reach',
    "SELECT entity_id, period_start AS period_key, COALESCE(SUM(reach),0) AS reach, COALESCE(SUM(impression),0) AS impressions " +
    "FROM fb_ads_period_data " +
    "WHERE entity_type = 'campaign' AND period_type = '" + periodType + "' " +
    "AND period_start BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "AND CAST(entity_id AS CHAR) IN (" + fn.sqlInList(campaignIds) + ") " +
    "GROUP BY entity_id, period_start"
  );
}
function fetchAdPeriodReach(periodType, periods, adIds) {
  if (!adIds.length) return Promise.resolve([]);
  const since = periods[periods.length - 1].start, until = periods[0].start;
  return fn.runSql(ctx, 'fbstr_ad_reach',
    "SELECT entity_id, period_start AS period_key, COALESCE(SUM(reach),0) AS reach, COALESCE(SUM(impression),0) AS impressions " +
    "FROM fb_ads_period_data " +
    "WHERE entity_type = 'ad' AND period_type = '" + periodType + "' " +
    "AND period_start BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "AND CAST(entity_id AS CHAR) IN (" + fn.sqlInList(adIds) + ") " +
    "GROUP BY entity_id, period_start"
  );
}
function fetchAdsetPeriodReach(periodType, periods, adsetIds) {
  if (!adsetIds.length) return Promise.resolve([]);
  const since = periods[periods.length - 1].start, until = periods[0].start;
  return fn.runSql(ctx, 'fbstr_adset_reach',
    "SELECT entity_id, period_start AS period_key, COALESCE(SUM(reach),0) AS reach, COALESCE(SUM(impression),0) AS impressions " +
    "FROM fb_ads_period_data " +
    "WHERE entity_type = 'adset' AND period_type = '" + periodType + "' " +
    "AND period_start BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "AND CAST(entity_id AS CHAR) IN (" + fn.sqlInList(adsetIds) + ") " +
    "GROUP BY entity_id, period_start"
  );
}
function applyReachOverrides(byEntity, reachRows) {
  const map = {};
  reachRows.forEach(function (r) { map[r.entity_id + '|' + r.period_key] = r; });
  Object.keys(byEntity).forEach(function (id) {
    const pm = byEntity[id];
    Object.keys(pm).forEach(function (pk) {
      const hit = map[id + '|' + pk];
      if (hit) { pm[pk].reach = hit.reach; pm[pk].impressions = hit.impressions; pm[pk].reachSource = 'real'; }
      else { pm[pk].reachSource = 'approx'; }
    });
  });
}
function buildEntityRows(periodicRows, idField, nameField) {
  const byEntity = {}, nameMap = {};
  periodicRows.forEach(function (r) {
    const id = r[idField];
    if (!byEntity[id]) byEntity[id] = {};
    byEntity[id][r.period_key] = r;
    if (r[nameField]) nameMap[id] = r[nameField];
  });
  return { byEntity: byEntity, nameMap: nameMap };
}
function sumSpend(periodMap) {
  return Object.keys(periodMap).reduce(function (s, pk) { return s + fn.num(periodMap[pk].spend); }, 0);
}
function findLatestDataKey(periodicRows, fallback) {
  return periodicRows.reduce(function (best, r) { return (!best || r.period_key > best) ? r.period_key : best; }, null) || fallback;
}
function hasActivity(row) { return !!row; }

