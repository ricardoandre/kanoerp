function AdsetRow(props) {
  const adset = props.adset, objKey = props.objKey;
  const periods = props.periods, granularity = props.granularity, periodType = props.periodType;
  const sortKey = props.sortKey, sortDir = props.sortDir, targetRules = props.targetRules;
  const sDetail = useState(false); const showDetail = sDetail[0]; const setShowDetail = sDetail[1];
  const sExpand = useState(false); const expand = sExpand[0]; const setExpand = sExpand[1];
  const sAds = useState(null); const ads = sAds[0]; const setAds = sAds[1];
  const sImages = useState({}); const adImages = sImages[0]; const setAdImages = sImages[1];
  const sLoading = useState(false); const loading = sLoading[0]; const setLoading = sLoading[1];
  const latestRow = adset.periodMap[periods[0].key] || {};
  const latestMetrics = computeMetrics(latestRow);

  function toggleAds() {
    if (!expand && !ads) {
      setLoading(true);
      Promise.all([fetchAdsPeriodic(adset.adset_id, granularity, periods), fetchAdImages()])
        .then(function (res) {
          const adPeriodicRows = res[0], images = res[1];
          const built = buildEntityRows(adPeriodicRows, 'ad_id', 'ad_name');
          const latestKey = findLatestDataKey(adPeriodicRows, periods[0].key);
          const adIds = Object.keys(built.byEntity);
          const needsPeriodReach = granularity !== 'daily';
          const reachPromise = needsPeriodReach ? fetchAdPeriodReach(periodType, periods, adIds) : Promise.resolve([]);
          return reachPromise.then(function (reachRows) {
            if (needsPeriodReach) applyReachOverrides(built.byEntity, reachRows);
            return fn.fetchStatusMap(ctx, 'ad', adIds).then(function (statusMap) {
              const adRows = adIds.map(function (id) {
                const pm = built.byEntity[id];
                return { ad_id: id, ad_name: built.nameMap[id], periodMap: pm, isActive: hasActivity(pm[latestKey]), fbStatus: statusMap[id] || null };
              });
              setAds(adRows);
              setAdImages(images);
              setLoading(false);
              setExpand(true);
            });
          });
        })
        .catch(function () { setLoading(false); setExpand(true); });
    } else {
      setExpand(!expand);
    }
  }

  const visibleAds = ads ? ads.slice().sort(sortComparator(periods, sortKey, sortDir)) : null;

  return ce('div', { className: 'fbstr-indent-1' },
    ce('div', { className: 'fbstr-row' },
      ce('div', { className: 'fbstr-row-content' },
        ce('div', null, ui.statusBadge(adset.fbStatus), ce('span', { className: 'fbstr-name' }, '📁 ' + (adset.adset_name || adset.adset_id))),
        PeriodTable(adset.periodMap, periods, objKey, targetRules)),
      ce('div', { className: 'fbstr-row-actions' },
        ce('button', { className: 'fbstr-expand-btn', onClick: function () { setShowDetail(!showDetail); } }, showDetail ? 'Details ▲' : 'Details ▼'),
        ce('button', { className: 'fbstr-expand-btn', onClick: toggleAds },
          loading ? '…' : (expand ? 'Ads ▲' : 'Ads ▼')))),
    showDetail ? AllMetricsPanel(latestMetrics) : null,
    expand && visibleAds && visibleAds.map(function (ad) {
      return ce(AdRow, { key: ad.ad_id, ad: ad, objKey: objKey, image: adImages[ad.ad_id] || '', periods: periods, targetRules: targetRules });
    }),
    expand && ads && visibleAds.length === 0 ? ce('div', { className: 'fbstr-indent-2', style: { padding: '8px 0', color: '#9ca3af', fontSize: 12 } }, 'No ad data found.') : null,
    expand && loading ? ce('div', { className: 'fbstr-indent-2', style: { padding: '8px 0', color: '#9ca3af', fontSize: 12 } }, 'Loading ads…') : null);
}

// =====================================================
// ── CAMPAIGN ROW ──
// =====================================================
function CampaignRow(props) {
  const camp = props.camp;
  const periods = props.periods, granularity = props.granularity, periodType = props.periodType;
  const sortKey = props.sortKey, sortDir = props.sortDir, targetRules = props.targetRules;
  const objKey = camp.objective;
  const sDetail = useState(false); const showDetail = sDetail[0]; const setShowDetail = sDetail[1];
  const sExpand = useState(false); const expand = sExpand[0]; const setExpand = sExpand[1];
  const sAdsets = useState(null); const adsets = sAdsets[0]; const setAdsets = sAdsets[1];
  const sLoading = useState(false); const loading = sLoading[0]; const setLoading = sLoading[1];
  const latestRow = camp.periodMap[periods[0].key] || {};
  const latestMetrics = computeMetrics(latestRow);

  function toggleAdsets() {
    if (!expand && !adsets) {
      setLoading(true);
      fetchAdsetsPeriodic(camp.campaign_id, granularity, periods)
        .then(function (rows) {
          const built = buildEntityRows(rows, 'adset_id', 'adset_name');
          const latestKey = findLatestDataKey(rows, periods[0].key);
          const adsetIds = Object.keys(built.byEntity);
          const needsPeriodReach = granularity !== 'daily';
          const reachPromise = needsPeriodReach ? fetchAdsetPeriodReach(periodType, periods, adsetIds) : Promise.resolve([]);

          return reachPromise.then(function (reachRows) {
            if (needsPeriodReach) applyReachOverrides(built.byEntity, reachRows);
            return fn.fetchStatusMap(ctx, 'adset', adsetIds).then(function (statusMap) {
              const adsetRows = adsetIds.map(function (id) {
                return { adset_id: id, adset_name: built.nameMap[id], periodMap: built.byEntity[id], isActive: hasActivity(built.byEntity[id][latestKey]), fbStatus: statusMap[id] || null };
              });
              setAdsets(adsetRows);
              setLoading(false);
              setExpand(true);
            });
          });
        })
        .catch(function () { setLoading(false); setExpand(true); });
    } else {
      setExpand(!expand);
    }
  }

  const visibleAdsets = adsets ? adsets.slice().sort(sortComparator(periods, sortKey, sortDir)) : null;

  return ce('div', { style: { borderBottom: '1px solid #e5e7eb' } },
    ce('div', { className: 'fbstr-row', style: { borderBottom: 'none', padding: '10px 0' } },
      ce('div', { className: 'fbstr-row-content' },
        ce('div', null,
          ui.badge(objKey), ui.objectiveMetaBadge(camp.objectiveInfo), ui.statusBadge(camp.fbStatus),
          ce('span', { className: 'fbstr-name' }, camp.campaign_name || camp.campaign_id)),
        PeriodTable(camp.periodMap, periods, objKey, targetRules)),
      ce('div', { className: 'fbstr-row-actions' },
        ce('button', { className: 'fbstr-expand-btn', onClick: function () { setShowDetail(!showDetail); } }, showDetail ? 'Details ▲' : 'Details ▼'),
        ce('button', { className: 'fbstr-expand-btn', onClick: toggleAdsets },
          loading ? '…' : (expand ? 'Adsets ▲' : 'Adsets ▼')))),
    showDetail ? AllMetricsPanel(latestMetrics) : null,
    expand && visibleAdsets && visibleAdsets.map(function (adset) {
      return ce(AdsetRow, { key: adset.adset_id, adset: adset, objKey: objKey, periods: periods, granularity: granularity, periodType: periodType, sortKey: sortKey, sortDir: sortDir, targetRules: targetRules });
    }),
    expand && adsets && visibleAdsets.length === 0 ? ce('div', { className: 'fbstr-indent-1', style: { padding: '8px 0', color: '#9ca3af', fontSize: 12 } }, 'No adset data found.') : null,
    expand && loading ? ce('div', { className: 'fbstr-indent-1', style: { padding: '8px 0', color: '#9ca3af', fontSize: 12 } }, 'Loading adsets…') : null);
}

// =====================================================
// ── ROOT ──
// =====================================================
const Root = function () {
  const sReady = useState(false); const ready = sReady[0]; const setReady = sReady[1];
  const sLoadErr = useState(null); const loadErr = sLoadErr[0]; const setLoadErr = sLoadErr[1];

  const sGranularity = useState(DEFAULT_GRANULARITY); const granularity = sGranularity[0]; const setGranularity = sGranularity[1];
  const sFilterObj = useState('all'); const filterObj = sFilterObj[0]; const setFilterObj = sFilterObj[1];
  const sSortCombo = useState(DEFAULT_SORT_COMBO); const sortCombo = sSortCombo[0]; const setSortCombo = sSortCombo[1];
  const sCampaigns = useState(null); const campaigns = sCampaigns[0]; const setCampaigns = sCampaigns[1];
  const sPeriods = useState(null); const periods = sPeriods[0]; const setPeriods = sPeriods[1];
  const sErr = useState(null); const err = sErr[0]; const setErr = sErr[1];
  const sLoading = useState(false); const loading = sLoading[0]; const setLoading = sLoading[1];
  const sDataQuality = useState(null); const dataQuality = sDataQuality[0]; const setDataQuality = sDataQuality[1];
  const sTargetRules = useState(null); const targetRules = sTargetRules[0]; const setTargetRules = sTargetRules[1];

  const sAvailableAccounts = useState([]); const availableAccounts = sAvailableAccounts[0]; const setAvailableAccounts = sAvailableAccounts[1];
  const sSelectedAccount = useState(null); const selectedAccount = sSelectedAccount[0]; const setSelectedAccount = sSelectedAccount[1];

  const sPeriodCount = useState(DEFAULT_PERIOD_COUNT); const periodCount = sPeriodCount[0]; const setPeriodCount = sPeriodCount[1];
  const sLastDate = useState(dayjs().startOf('day')); const lastDate = sLastDate[0]; const setLastDate = sLastDate[1];

  function generate(gran, account, count, lastDateParam) {
    setLoading(true); setErr(null);
    const p = fn.buildPeriods(gran, count, lastDateParam);
    const needsPeriodReach = gran !== 'daily';
    const periodType = gran === 'monthly' ? 'month' : 'week';

    fetchCampaignsPeriodic(gran, p, account).then(function (rows) {
      let finalPeriods = p;
      if (gran === 'daily' && p.length && p[0].partial) {
        const hasToday = rows.some(function (r) { return r.period_key === p[0].key; });
        if (!hasToday) finalPeriods = p.slice(1);
      }
      setPeriods(finalPeriods);

      const built = buildEntityRows(rows, 'campaign_id', 'campaign_name');
      const latestKey = findLatestDataKey(rows, finalPeriods[0].key);
      const campaignIds = Object.keys(built.byEntity);
      const reachPromise = needsPeriodReach ? fetchCampaignPeriodReach(periodType, p, campaignIds) : Promise.resolve([]);

      return reachPromise.then(function (reachRows) {
        if (needsPeriodReach) applyReachOverrides(built.byEntity, reachRows);
        return Promise.all([fn.fetchStatusMap(ctx, 'campaign', campaignIds), fn.fetchObjectiveMap(ctx, campaignIds)]).then(function (results) {
          const statusMap = results[0], objectiveMap = results[1];
          const campaignRows = campaignIds.map(function (id) {
            const pm = built.byEntity[id];
            const name = built.nameMap[id];
            const objectiveInfo = fn.resolveObjective(objectiveMap[id], name);
            return { campaign_id: id, campaign_name: name, objective: objectiveInfo.objective, objectiveInfo: objectiveInfo, periodMap: pm, isActive: hasActivity(pm[latestKey]), fbStatus: statusMap[id] || null, spend: sumSpend(pm) };
          });
          setCampaigns(campaignRows);
          setLoading(false);

          if (needsPeriodReach) {
            let approx = 0, total = 0;
            campaignRows.forEach(function (c) {
              Object.keys(c.periodMap).forEach(function (pk) { total++; if (c.periodMap[pk].reachSource !== 'real') approx++; });
            });
            setDataQuality({ campaignApprox: approx, campaignTotal: total });
          } else {
            setDataQuality(null);
          }
        });
      });
    }).catch(function (e) { setErr((e && e.message) || String(e)); setLoading(false); });
  }

  function handleAccountChange(account) { setSelectedAccount(account); generate(granularity, account, periodCount, lastDate); }
  function handleReload() { generate(granularity, selectedAccount, periodCount, lastDate); }
  function handleApplyTimeWindow(gran, count, ld) {
    setGranularity(gran); setPeriodCount(count); setLastDate(ld);
    generate(gran, selectedAccount, count, ld);
  }

  useEffect(function () {
    Promise.all([loadCode('fn_fbads_data'), loadCode('ui_fbads_controls')])
      .then(function (mods) {
        fn = mods[0]; ui = mods[1];
        setSelectedAccount(fn.DEFAULT_ACCOUNT);
        setReady(true);
      })
      .catch(function (e) { setLoadErr((e && e.message) || String(e)); });
  }, []);

  useEffect(function () {
    if (!ready) return;
    generate(granularity, selectedAccount, periodCount, lastDate);
    fn.fetchAccountList(ctx).then(function (rows) {
      setAvailableAccounts(rows.map(function (r) { return r.account; }));
    }).catch(function () {});
    fn.fetchTargetRules(ctx).then(function (rules) { setTargetRules(rules); });
  }, [ready]);

  if (loadErr) return ce('div', { style: { color: '#dc2626', padding: 16 } }, 'Failed to load shared FB Ads modules: ' + loadErr);
  if (!ready || !targetRules) return ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, ce(Spin), ce('div', { style: { marginTop: 8 } }, 'Loading…'));

  const sortDef = parseSortCombo(sortCombo);
  const sortKey = sortDef.key, sortDir = sortDef.dir;
  const filteredCampaigns = campaigns
    ? campaigns
        .filter(function (c) { return filterObj === 'all' || c.objective === filterObj; })
        .slice()
        .sort(sortComparator(periods, sortKey, sortDir))
    : null;
  const periodType = granularity === 'monthly' ? 'month' : 'week';

  let campaignListContent;
  if (loading) {
    campaignListContent = ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, ce(Spin), ce('div', { style: { marginTop: 8 } }, 'Loading campaigns…'));
  } else if (filteredCampaigns) {
    campaignListContent = filteredCampaigns.length === 0
      ? ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, 'No campaigns found for this filter.')
      : ce('div', { style: { border: '1px solid #e5e7eb', borderRadius: 8, padding: '0 16px' } },
          ce('div', { style: { display: 'flex', gap: 0, padding: '8px 0 4px', borderBottom: '2px solid #e5e7eb', marginBottom: 4 } },
            ce('div', { style: { flex: 1, fontSize: 11, fontWeight: 700, color: '#6b7280', textTransform: 'uppercase' } }, filteredCampaigns.length + ' campaign(s)')),
          filteredCampaigns.map(function (camp) {
            return ce(CampaignRow, {
              key: camp.campaign_id, camp: camp,
              periods: periods, granularity: granularity, periodType: periodType,
              sortKey: sortKey, sortDir: sortDir, targetRules: targetRules,
            });
          }));
  } else {
    campaignListContent = ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af', fontSize: 13 } }, 'Loading…');
  }

  return ce('div', { className: 'fbstr-root' },
    ScopedStyle(),
    ce('div', { className: 'fbstr-header-title', style: { fontSize: 18, fontWeight: 700, marginBottom: 4 } }, 'Facebook Ads — Details Report'),
    ce('div', { style: { fontSize: 13, color: '#6b7280', marginBottom: 4 } },
      'Each row shows the last ' + (periods ? periods.length : periodCount) + ' ' + granularity + ' periods side by side, last date ' + lastDate.format('D MMM YYYY') + '.'),
    ce('div', { style: { fontSize: 11, color: '#9ca3af', marginBottom: 16 } },
      'Targets — Cost/ATC < ' + fn.fmtMoney(targetRules.cost_atc.target) + ', Cost/Reach < ' + fn.fmtRatio(targetRules.cost_reach.target) + ', ROAS > ' + fn.fmtRatio(targetRules.roas.target) + ' (edit in fb_ads_target)'),

    ce('div', { className: 'fbstr-filterbar' },
      ui.Field('Account', ce(Select, {
        value: selectedAccount, onChange: handleAccountChange,
        style: { width: 200 }, placeholder: 'All accounts', allowClear: true,
        options: availableAccounts.map(function (a) { return { label: a, value: a }; }),
      })),
      ui.Field('Objective', ce(Segmented, { value: filterObj, onChange: setFilterObj, options: ui.OBJ_OPTIONS })),
      ui.Field('Time window', ce(ui.TimeWindowPopover, { granularity: granularity, periodCount: periodCount, lastDate: lastDate, loading: loading, onApply: handleApplyTimeWindow })),
      ui.Field('Sort by', ce(Select, { value: sortCombo, onChange: setSortCombo, style: { width: 220 }, options: SORT_OPTIONS })),
      ui.Field('', ce(Button, { onClick: handleReload, title: 'Reload with current filters', style: { borderColor: '#0891b2', color: '#0891b2' } }, loading ? 'Refreshing…' : '↻ Refresh'))),

    err ? ce('div', { style: { color: '#dc2626', marginBottom: 16, fontSize: 13 } }, err) : null,

    dataQuality && dataQuality.campaignApprox > 0 && !loading && ce('div', {
      style: { display: 'flex', flexDirection: 'column', gap: 4, padding: '8px 14px', marginTop: 16, marginBottom: 16, background: '#eff6ff', border: '1px solid #bfdbfe', borderRadius: 6, fontSize: 12, color: '#1e3a8a' },
    },
      ce('div', { style: { display: 'flex', alignItems: 'center', gap: 8 } },
        ce('span', { style: { width: 8, height: 8, borderRadius: 4, background: '#3b82f6', flexShrink: 0 } }),
        'Campaign-level: ' + dataQuality.campaignApprox + ' of ' + dataQuality.campaignTotal + ' period cells are approximated (fb_ads_period_data not yet backfilled for those).'),
      ce('div', { style: { paddingLeft: 16 } }, 'Ad-level and adset-level cells are marked "~ approx reach/freq" individually once you expand.')),

    ce('div', { style: { marginTop: 16 } }, campaignListContent));
};

ctx.render(ce(Root));
