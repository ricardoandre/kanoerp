function thStyle(left) {
  return { textAlign: left ? 'left' : 'right', padding: '6px 10px', background: '#f9fafb', borderBottom: '1px solid #e5e7eb', fontWeight: 700, fontSize: 10, color: '#6b7280', textTransform: 'uppercase', letterSpacing: 0.3 };
}
function tdStyle(left, extra) {
  const base = { textAlign: left ? 'left' : 'right', padding: '5px 10px', borderBottom: '1px solid #f3f4f6', fontWeight: left ? 600 : 400, color: left ? '#111827' : '#374151', fontSize: 12 };
  return Object.assign(base, extra || {});
}

function PeriodTable(periodMap, periods, objKey, targetRules) {
  const cols = getObjCols(objKey);
  const rows = [{ key: 'spend', label: 'Spend' }].concat(cols);

  return ce('div', { className: 'fbstr-table-wrap' },
    ce('table', { className: 'fbstr-table', style: { borderCollapse: 'separate', borderSpacing: 0, tableLayout: 'fixed' } },
      ce('colgroup', null,
        ce('col', { style: { width: 100 } }),
        periods.map(function (p) { return ce('col', { key: p.key, style: { width: 105 } }); })),
      ce('thead', null, ce('tr', null,
        ce('th', { className: 'fbstr-sticky-col', style: Object.assign(thStyle(true), { zIndex: 3 }) }, ''),
        periods.map(function (p) {
          const row = periodMap[p.key];
          const approx = row && row.reachSource === 'approx';
          return ce('th', { key: p.key, style: thStyle(false) },
            approx && ce('span', { style: { display: 'inline-block', width: 6, height: 6, borderRadius: 3, background: '#3b82f6', marginRight: 4 }, title: 'Approximated reach/frequency — not yet backfilled' }),
            p.label);
        }))),
      ce('tbody', null, rows.map(function (m, ri) {
        const rowBg = ri % 2 ? '#fafafa' : '#fff';
        return ce('tr', { key: m.key, style: { background: rowBg } },
          ce('td', { className: 'fbstr-sticky-col', style: Object.assign(tdStyle(true, { background: rowBg }), { zIndex: 2 }) }, m.label),
          periods.map(function (p, pi) {
            const row = periodMap[p.key];
            if (!row) return ce('td', { key: p.key, style: tdStyle(false) }, '—');
            const val = computeMetrics(row)[m.key];
            let color = null;
            if (GROWTH_METRICS.indexOf(m.key) !== -1) {
              const prevRow = periods[pi + 1] && periodMap[periods[pi + 1].key];
              color = prevRow ? fn.growthColorFromValues(val, computeMetrics(prevRow)[m.key]) : null;
            } else {
              const rule = targetRules[m.key];
              if (rule) color = fn.targetColorFromValue(val, row[rule.countField], rule);
            }
            return ce('td', { key: p.key, style: tdStyle(false, color ? { color: color, fontWeight: 700 } : null) }, metricFmt(m.key, val));
          }));
      }))));
}

