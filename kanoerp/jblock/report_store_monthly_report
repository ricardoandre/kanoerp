        : ce('div', { style: { width: 48, height: 48, borderRadius: 6, background: '#f3f4f6', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 8, color: '#cbd5e1', flexShrink: 0 } }, 'No image'),
      ce('div', { style: { flex: 1, minWidth: 0 } },
        ce('div', { style: { fontWeight: 700, fontSize: 13, color: '#111827', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, detail.code),
        ce('div', { style: { fontSize: 11, color: '#6b7280', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' } }, detail.name || '—')
      ),
      ce('div', { style: { textAlign: 'right', flexShrink: 0 } },
        ce('div', { style: { fontSize: 9, color: '#9ca3af', textTransform: 'uppercase' } }, 'Total Sales (6mo)'),
        ce('div', { style: { fontSize: 16, fontWeight: 700, color: SALES_PURPLE } }, dash(detail.totalSales6mo))
      ),
      ce('div', { style: { textAlign: 'right', flexShrink: 0 } },
        ce('div', { style: { fontSize: 9, color: '#9ca3af', textTransform: 'uppercase' } }, 'Current Stock'),
        ce('div', { style: { fontSize: 16, fontWeight: 700, color: detail.currentStock <= 0 ? OOS_RED : STOCK_COLOR } }, dash(detail.currentStock))
      )
    ),
    ce('div', { className: 'mreport-scroll', style: { overflowX: 'auto' } },
      ce('table', { className: 'mreport-detail-table', style: { borderCollapse: 'separate', borderSpacing: 0, width: '100%', tableLayout: 'fixed' } },
        ce('colgroup', null, cols),
        ce('thead', null,
          ce('tr', null,
            ce('th', { style: thItemStyle, rowSpan: 2 }, 'Size'),
            monthsAsc.map(m => ce('th', { key: m.key, colSpan: 3, style: Object.assign({}, thStyle, { textAlign: 'center' }) }, shortMonthLabel(m.key))),
            ce('th', { style: Object.assign({}, thStyle, { color: STOCK_COLOR }), rowSpan: 2 }, 'Stock'),
            ce('th', { style: Object.assign({}, thStyle, { color: SUGGEST_ORANGE, borderLeft: '1px solid #f3f4f6' }), rowSpan: 2 }, 'Suggest')
          ),
          ce('tr', null,
            monthsAsc.map(function (m) {
              return [
                ce('th', { key: m.key + '_b', style: Object.assign({}, thStyle, { color: STOCK_COLOR, borderLeft: '1px solid #f3f4f6' }) }, 'Beg'),
                ce('th', { key: m.key + '_r', style: Object.assign({}, thStyle, { color: '#6b7280' }) }, 'ADJ'),
                ce('th', { key: m.key + '_s', style: thStyle }, 'Sold'),
              ];
            })
          )
        ),
        ce('tbody', null,
          ce('tr', { style: { background: '#f8fafc' } },
            ce('td', { style: { ...tdItemStyle, background: '#f8fafc', fontWeight: 700 } }, 'Total'),
            monthsAsc.map(function (m) {
              return [
                ce('td', { key: m.key + '_b', style: { ...tdStyle, fontWeight: 700, color: STOCK_COLOR, borderLeft: '1px solid #f3f4f6' } }, dash(detail.beginByMonth[m.key])),
                ce('td', { key: m.key + '_r', style: { ...tdStyle, fontWeight: 700, color: detail.adjByMonth[m.key] > 0 ? RESTOCK_GREEN : (detail.adjByMonth[m.key] < 0 ? OOS_RED : undefined) } }, dash(detail.adjByMonth[m.key])),
                ce('td', { key: m.key + '_s', style: { ...tdStyle, fontWeight: 700 } }, dash(detail.salesByMonth[m.key])),
              ];
            }).flat(),
            ce('td', { style: { ...tdStyle, fontWeight: 700, color: detail.currentStock <= 0 ? OOS_RED : STOCK_COLOR } }, dash(detail.currentStock)),
            ce('td', { style: { ...tdStyle, fontWeight: 700, color: SUGGEST_ORANGE, borderLeft: '1px solid #f3f4f6' } }, dash(detail.totalSuggestedRestock))
          ),
          detail.sizes.length
            ? detail.sizes.map(function (s, i) {
                const bg = i % 2 === 0 ? '#ffffff' : '#fafafa';
                return ce('tr', { key: s.skuOptionId, style: { background: bg } },
                  ce('td', { style: { ...tdItemStyle, background: bg } }, s.label),
                  monthsAsc.map(function (m) {
                    const beg = s.beginByMonth[m.key];
                    const sold = s.salesByMonth[m.key];
                    const adj = s.adjByMonth[m.key];
                    const flagRed = beg <= 0 && s.priorMonthSales[m.key] > 0;
                    return [
                      ce('td', { key: m.key + '_b', style: { ...tdStyle, color: flagRed ? OOS_RED : STOCK_COLOR, fontWeight: flagRed ? 700 : 400, borderLeft: '1px solid #f3f4f6' } }, dash(beg)),
                      ce('td', { key: m.key + '_r', style: { ...tdStyle, color: adj > 0 ? RESTOCK_GREEN : (adj < 0 ? OOS_RED : undefined) } }, dash(adj)),
                      ce('td', { key: m.key + '_s', style: tdStyle }, dash(sold)),
                    ];
                  }).flat(),
                  ce('td', { style: { ...tdStyle, fontWeight: 600, color: s.currentStock <= 0 ? OOS_RED : STOCK_COLOR } }, dash(s.currentStock)),
                  ce('td', { style: { ...tdStyle, fontWeight: s.suggestedRestock > 0 ? 700 : 400, color: s.suggestedRestock > 0 ? SUGGEST_ORANGE : undefined, borderLeft: '1px solid #f3f4f6' } }, dash(s.suggestedRestock))
                );
              })
            : ce('tr', null, ce('td', { colSpan: monthsAsc.length * 3 + 3, style: { padding: '10px', textAlign: 'center', color: '#9ca3af', fontSize: 11 } }, 'No size data.'))
        )
      )
    )
  );
}
// ── drill-down drawer: mode 'product' (one block) or 'model' (many blocks) ──
function DetailsDrawer(props) {
  const open = props.open;
  const onClose = props.onClose;
  const mode = props.mode; // 'product' | 'model'
  const drawerKey = props.drawerKey; // product code, or model name
  const monthsAsc = props.monthsAsc;
  const imageMap = props.imageMap;
  const rawData = props.rawData;
  if (!drawerKey || !rawData) {
    return ce(Drawer, { open: open, onClose: onClose, width: 960, title: 'Details' }, null);
  }
  if (mode === 'product') {
    const detail = buildProductSizeDetail(drawerKey, rawData.salesRowsAllTime, rawData.ledgerRowsAllTime, rawData.events, monthsAsc, rawData.anchorEndDate);
    return ce(Drawer, { open: open, onClose: onClose, width: 960, title: detail.code + (detail.name ? (' — ' + detail.name) : '') },
      ce(ProductSizeBlock, { detail: detail, monthsAsc: monthsAsc, imageMap: imageMap })
    );
  }
  const monthKeys = monthsAsc.map(m => m.key);
  const ranked = getModelProductCodes(drawerKey, rawData.salesRowsAllTime, monthKeys);
  const MODEL_CAP = 25;
  const capped = ranked.slice(0, MODEL_CAP);
  const blocks = capped.map(function (x) {
    return buildProductSizeDetail(x.code, rawData.salesRowsAllTime, rawData.ledgerRowsAllTime, rawData.events, monthsAsc, rawData.anchorEndDate);
  });
  return ce(Drawer, { open: open, onClose: onClose, width: 1040, title: drawerKey },
    ranked.length > MODEL_CAP
      ? ce('div', { style: { fontSize: 11, color: '#9ca3af', marginBottom: 12 } }, 'Showing top ' + MODEL_CAP + ' of ' + ranked.length + ' products, by sales.')
      : null,
    blocks.length
      ? blocks.map(function (d) { return ce(ProductSizeBlock, { key: d.code, detail: d, monthsAsc: monthsAsc, imageMap: imageMap }); })
      : ce('div', { style: { padding: 20, textAlign: 'center', color: '#9ca3af', fontSize: 12 } }, 'No product data for this model.')
  );
}
// ── root ──
function Root() {
  const [stores, setStores] = useState([]);
  const [storeId, setStoreId] = useState(null);
  const [monthPeriod, setMonthPeriod] = useState(function () { return dayjs().subtract(1, 'month'); });
  const [loading, setLoading] = useState(false);
  const [err, setErr] = useState(null);
  const [imageMap, setImageMap] = useState({});
  const [data, setData] = useState(null);
  const [drawerOpen, setDrawerOpen] = useState(false);
  const [drawerMode, setDrawerMode] = useState('product');
  const [drawerKey, setDrawerKey] = useState(null);
  useEffect(function () {
    fetchStores().then(setStores).catch(function (e) { setErr((e && e.message) || String(e)); });
    fetchImages().then(setImageMap);
  }, []);
  useEffect(function () {
    if (!storeId) { setData(null); return; }
    const anchor = monthPeriod || dayjs().subtract(1, 'month');
    const months = buildMonths(anchor);
    const monthKeys = months.map(m => m.key);
    const anchorEndDate = anchor.endOf('month').format('YYYY-MM-DD');
    let alive = true;
    setLoading(true);
    setErr(null);
    Promise.all([fetchSalesRows(storeId, anchorEndDate), fetchLedgerRows(storeId, anchorEndDate)])
      .then(function (r) {
        if (!alive) return;
        const salesRowsAllTime = r[0], ledgerRowsAllTime = r[1];
        const events = buildEvents(salesRowsAllTime, ledgerRowsAllTime);
        const monthlyStoreTotal = computeMonthlyStoreTotal(salesRowsAllTime, monthKeys);
        const groupedModel = buildGroupedSales(salesRowsAllTime, ledgerRowsAllTime, 'model', monthKeys);
        const groupedProduct = buildGroupedSales(salesRowsAllTime, ledgerRowsAllTime, 'product', monthKeys);
        const groupedVariant = buildGroupedSales(salesRowsAllTime, ledgerRowsAllTime, 'variant', monthKeys);
        attachChosenMonthOOS(groupedModel, events, monthKeys[0], anchorEndDate);
        attachChosenMonthOOS(groupedProduct, events, monthKeys[0], anchorEndDate);
        const modelTrend = computeTrendSummary(groupedModel, months);
        const productTrend = computeTrendSummary(groupedProduct, months);
        const productIndex = buildProductVariantIndex(salesRowsAllTime, ledgerRowsAllTime);
        const metrics = computeProductMetrics(productIndex, salesRowsAllTime, events, months, anchorEndDate);
        const metricsList = Object.values(metrics);
        const rank6mo = metricsList.slice().sort((a, b) => b.sales6mo - a.sales6mo);
        const rankLastMonth = metricsList.slice().sort((a, b) => b.salesLastMonth - a.salesLastMonth);
        const rank6moIndex = {}; rank6mo.forEach((m, i) => { rank6moIndex[m.code] = i + 1; });
        const rankLastMonthIndex = {}; rankLastMonth.forEach((m, i) => { rankLastMonthIndex[m.code] = i + 1; });
        const opportunityScores = computeRestockOpportunity(productIndex, salesRowsAllTime, events, months, anchorEndDate);
        const restock = metricsList
          .map(m => Object.assign({}, m, { rank6mo: rank6moIndex[m.code], rankLastMonth: rankLastMonthIndex[m.code], score: opportunityScores[m.code] || 0 }))
          .filter(m => m.score > 0);
        restock.sort((a, b) => b.score - a.score);
        // Product Rotation minimum trial: a product must have its earliest
        // record (first sale or stock-ledger entry) BEFORE the 1st of the
        // month immediately preceding Month Period — e.g. for a June
        // anchor, before May 1 — which guarantees at least 3 calendar
        // months of history (Apr/May/Jun in that example) by the end of
        // the window. Products newer than that are excluded from
        // Rotation entirely (not just ranked low), same as Need Restock
        // excludes zero-opportunity products. ALSO excludes products
        // that are currently out of stock (end-of-Month-Period stock
        // <= 0) — nothing to "drop" from a product that's already gone;
        // Rotation should only surface poor sellers still tying up
        // shelf space.
        const firstRecordByProduct = computeFirstRecordDateByProduct(salesRowsAllTime, ledgerRowsAllTime);
        const rotationCutoffDate = anchor.subtract(1, 'month').startOf('month').format('YYYY-MM-DD');
        const rotationEligible = metricsList.filter(function (m) {
          const first = firstRecordByProduct[m.code];
          return !!first && first < rotationCutoffDate && m.currentStock > 0;
        });
        const rotation = rotationEligible.slice().sort((a, b) => a.sales6mo - b.sales6mo).map((m, i) => Object.assign({}, m, { rankWorst: i + 1 }));
        setData({
          months: months, monthsAsc: months.slice().reverse(), anchorEndDate: anchorEndDate,
          monthlyStoreTotal: monthlyStoreTotal,
          groupedModel: groupedModel, groupedProduct: groupedProduct, groupedVariant: groupedVariant,
          modelTrend: modelTrend, productTrend: productTrend,
          restock: restock, rotation: rotation,
          salesRowsAllTime: salesRowsAllTime, ledgerRowsAllTime: ledgerRowsAllTime, events: events,
        });
        setDrawerOpen(false);
        setDrawerKey(null);
      })
      .catch(function (e) {
        if (!alive) return;
        setErr((e && e.message) || String(e));
        setData(null);
      })
      .finally(function () { if (alive) setLoading(false); });
    return function () { alive = false; };
  }, [storeId, monthPeriod]);
  function openDrawer(mode, key) {
    setDrawerMode(mode);
    setDrawerKey(key);
    setDrawerOpen(true);
  }
  function openProductDrawer(code) { openDrawer('product', code); }
  const fieldLabel = t => ce('div', { style: { fontSize: 10, fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.06em', color: '#94a3af', marginBottom: 4 } }, t);
  const trendValuesAsc = data ? data.monthsAsc.map(m => data.monthlyStoreTotal[m.key] || 0) : [];
  const lastMonthLabel = data ? data.months[0].label : '';
  // side-by-side on wide screens, stacks on narrow ones via flex-wrap
  function sideBySide(leftTitle, leftNode, rightTitle, rightNode) {
    return ce('div', { style: { display: 'flex', gap: 16, flexWrap: 'wrap', marginTop: 16 } },
      ce('div', { style: { flex: '1 1 340px', minWidth: 300 } }, subheading(leftTitle), leftNode),
      ce('div', { style: { flex: '1 1 340px', minWidth: 300 } }, subheading(rightTitle), rightNode)
    );
  }
  return ce('div', { style: { fontFamily: 'system-ui,sans-serif', fontSize: 13, padding: 4 } },
    ce('style', { key: 'mreport-style' }, RESPONSIVE_STYLE),
    ce('div', { style: { display: 'flex', gap: 12, marginBottom: 20, flexWrap: 'wrap' } },
      ce('div', { style: { minWidth: 220, flex: '1 1 220px' } },
        fieldLabel('Store'),
        ce(Select, {
          value: storeId, onChange: setStoreId, style: { width: '100%' }, allowClear: true,
          placeholder: 'Select a store to generate a report',
          options: stores.map(s => ({ value: s.id, label: s.store_code ? (s.store_code + ' — ' + s.name) : s.name })),
          showSearch: true,
          filterOption: (input, option) => (option.label || '').toLowerCase().indexOf(input.toLowerCase()) !== -1,
        })
      ),
      ce('div', { style: { minWidth: 140, flex: '0 1 160px' } },
        fieldLabel('Month Period'),
        ce(DatePicker, { picker: 'month', value: monthPeriod, onChange: v => setMonthPeriod(v || dayjs().subtract(1, 'month')), style: { width: '100%' }, allowClear: false, format: 'MMM YYYY' })
      )
    ),
    !storeId
      ? ce('div', { style: { padding: '40px 12px', textAlign: 'center', color: '#9ca3af', fontSize: 13 } }, 'Select a store to generate a report.')
      : err
        ? ce('div', { style: { padding: 16, color: '#ef4444', fontSize: 12 } }, err)
        : loading && !data
          ? ce('div', { style: { padding: '40px 12px', textAlign: 'center', color: '#9ca3af', fontSize: 13 } }, 'Loading…')
          : data
            ? ce('div', null,
                loading ? ce('div', { style: { fontSize: 11, color: '#9ca3af', marginBottom: 6 } }, 'Refreshing…') : null,
                ce('div', { style: { marginBottom: 28 } },
                  sectionTitle('Total Sales Trend', 'Total items (pcs) sold, last 6 months'),
                  ce('div', { style: { border: '1px solid #e5e7eb', borderRadius: 6, padding: '12px 8px 4px' } },
                    ce(TrendChart, { monthsAsc: data.monthsAsc, values: trendValuesAsc })
                  )
                ),
                ce('div', { style: { marginBottom: 28 } },
                  sectionTitle('Sales by Model', '⚠ marks the chosen month if that model had an OOS variant then — click a row for details'),
                  ce(SalesGroupTable, { months: data.months, rows: data.groupedModel, itemLabel: 'Model', showOOSWarning: true, groupKind: 'model', onEntityClick: openDrawer }),
                  sideBySide(
                    'Rising Model', ce(TrendSummaryList, { items: data.modelTrend.rising, imageMap: imageMap, tone: 'up', kind: 'model', onEntityClick: openDrawer }),
                    'Declining Model', ce(TrendSummaryList, { items: data.modelTrend.declining, imageMap: imageMap, tone: 'down', kind: 'model', onEntityClick: openDrawer })
                  )
                ),
                ce('div', { style: { marginBottom: 28 } },
                  sectionTitle('Sales by Product', '⚠ marks the chosen month if that product had an OOS variant then — click a row for details'),
                  ce(SalesGroupTable, { months: data.months, rows: data.groupedProduct, itemLabel: 'Product', showOOSWarning: true, groupKind: 'product', onEntityClick: openDrawer }),
                  sideBySide(
                    'Rising Product', ce(TrendSummaryList, { items: data.productTrend.rising, imageMap: imageMap, tone: 'up', kind: 'product', onEntityClick: openDrawer }),
                    'Declining Product', ce(TrendSummaryList, { items: data.productTrend.declining, imageMap: imageMap, tone: 'down', kind: 'product', onEntityClick: openDrawer })
                  )
                ),
                ce('div', { style: { marginBottom: 28 } },
                  sectionTitle('Sales by Variant'),
                  ce(SalesGroupTable, { months: data.months, rows: data.groupedVariant, itemLabel: 'Variant', showOOSWarning: false, groupKind: 'variant', onEntityClick: null })
                ),
                ce('div', { style: { marginBottom: 28 } },
                  sectionTitle('Need Restock', 'Products with the highest missed-sales opportunity if under-stocked sizes were restocked to their own best month — click a row for details'),
                  ce(RankedProductList, { items: data.restock, imageMap: imageMap, kind: 'restock', monthLabel: lastMonthLabel, onRowClick: openProductDrawer })
                ),
                ce('div', { style: { marginBottom: 8 } },
                  sectionTitle('Product Rotation', 'Lowest 6-month sales among products with at least a 3-month trial and still in stock — candidates to consider dropping — click a row for details'),
                  ce(RankedProductList, { items: data.rotation, imageMap: imageMap, kind: 'rotation', monthLabel: lastMonthLabel, onRowClick: openProductDrawer })
                ),
                ce(DetailsDrawer, {
                  open: drawerOpen, onClose: function () { setDrawerOpen(false); },
                  mode: drawerMode, drawerKey: drawerKey, monthsAsc: data.monthsAsc, imageMap: imageMap,
                  rawData: { salesRowsAllTime: data.salesRowsAllTime, ledgerRowsAllTime: data.ledgerRowsAllTime, events: data.events, anchorEndDate: data.anchorEndDate },
                })
              )
            : null
  );
}
ctx.render(ce(Root));
