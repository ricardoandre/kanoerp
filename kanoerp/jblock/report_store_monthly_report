}
// ── which products belong under a clicked model, ranked by sales in window ──
function getModelProductCodes(modelName, salesRowsAllTime, monthKeys) {
  const monthSet = {};
  monthKeys.forEach(k => { monthSet[k] = true; });
  const perProduct = {};
  salesRowsAllTime.forEach(function (r) {
    if ((r.model || '') !== modelName) return;
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    if (!monthSet[mk]) return;
    const code = r.product_code || '';
    if (!code) return;
    perProduct[code] = (perProduct[code] || 0) + num(r.quantity);
  });
  const arr = Object.keys(perProduct).map(code => ({ code: code, sortVal: perProduct[code] }));
  arr.sort((a, b) => b.sortVal - a.sortVal);
  return arr;
}
// ── per-product, per-size breakdown for the drill-down drawer (months
// passed in ASCENDING order — oldest left, newest right). Includes an ADJ
// figure per month alongside Beginning stock and Sold, plus a
// totalSales6mo rollup for the summary header. ──
function buildProductSizeDetail(productCode, salesRowsAllTime, ledgerRowsAllTime, events, monthsAsc, anchorEndDate) {
  const monthBoundary = {};
  monthsAsc.forEach(m => { monthBoundary[m.key] = dayjs(m.key + '-01').subtract(1, 'day').format('YYYY-MM-DD'); });
  const productSales = salesRowsAllTime.filter(r => (r.product_code || '') === productCode);
  const productLedger = ledgerRowsAllTime.filter(r => (r.product_code || '') === productCode);
  let productName = '';
  const sizes = {};
  function ensureSize(r) {
    const sid = r.sku_option_id;
    if (!sizes[sid]) sizes[sid] = { label: r.sku_display || r.sku_value || '(no size)', sortOrder: num(r.sku_sort), variantId: r.variant_id, salesByExactMonth: {}, adjByExactMonth: {} };
    return sizes[sid];
  }
  productSales.forEach(function (r) {
    if (!productName && r.product_name) productName = r.product_name;
    const s = ensureSize(r);
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    s.salesByExactMonth[mk] = (s.salesByExactMonth[mk] || 0) + num(r.quantity);
  });
  productLedger.forEach(function (r) {
    if (!productName && r.product_name) productName = r.product_name;
    const s = ensureSize(r);
    // ADJ = net of ALL stock_ledger entries in that exact month, positive
    // AND negative (stock-in, incoming/outgoing transfers, adjustments —
    // everything), not just inbound units.
    const q = num(r.quantity);
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    s.adjByExactMonth[mk] = (s.adjByExactMonth[mk] || 0) + q;
  });
  const sizeList = Object.keys(sizes).map(function (sid) {
    const s = sizes[sid];
    const currentStock = stockAsOf(events, s.variantId, anchorEndDate);
    const beginByMonth = {}, salesByMonth = {}, adjByMonth = {}, priorMonthSales = {};
    let peakSales = 0;
    monthsAsc.forEach(function (m) {
      beginByMonth[m.key] = stockAsOf(events, s.variantId, monthBoundary[m.key]);
      salesByMonth[m.key] = s.salesByExactMonth[m.key] || 0;
      adjByMonth[m.key] = s.adjByExactMonth[m.key] || 0;
      if (salesByMonth[m.key] > peakSales) peakSales = salesByMonth[m.key];
      const priorKey = dayjs(m.key + '-01').subtract(1, 'month').format('YYYY-MM');
      priorMonthSales[m.key] = s.salesByExactMonth[priorKey] || 0;
    });
    // suggested restock = this size's own best month of sales minus its
    // current stock, floored at 0, plus a fixed +1 unit buffer — 0 when
    // current stock already covers the peak month. NOTE: the +1 buffer
    // is NOT part of the Need Restock sort score (that uses the
    // unbuffered opportunity figure) — it only applies to this suggested
    // quantity.
    const restockOpportunity = Math.max(peakSales - currentStock, 0);
    const suggestedRestock = restockOpportunity > 0 ? restockOpportunity + 1 : 0;
    return { skuOptionId: sid, label: s.label, sortOrder: s.sortOrder, currentStock: currentStock, beginByMonth: beginByMonth, salesByMonth: salesByMonth, adjByMonth: adjByMonth, priorMonthSales: priorMonthSales, peakSales: peakSales, suggestedRestock: suggestedRestock };
  });
  sizeList.sort((a, b) => a.sortOrder - b.sortOrder);
  const currentStock = sizeList.reduce((s, x) => s + x.currentStock, 0);
  const beginByMonth = {}, salesByMonth = {}, adjByMonth = {};
  monthsAsc.forEach(function (m) {
    beginByMonth[m.key] = sizeList.reduce((s, x) => s + x.beginByMonth[m.key], 0);
    salesByMonth[m.key] = sizeList.reduce((s, x) => s + x.salesByMonth[m.key], 0);
    adjByMonth[m.key] = sizeList.reduce((s, x) => s + x.adjByMonth[m.key], 0);
  });
  const totalSales6mo = monthsAsc.reduce((s, m) => s + salesByMonth[m.key], 0);
  const totalSuggestedRestock = sizeList.reduce((s, x) => s + x.suggestedRestock, 0);
  return { code: productCode, name: productName, currentStock: currentStock, totalSales6mo: totalSales6mo, totalSuggestedRestock: totalSuggestedRestock, beginByMonth: beginByMonth, salesByMonth: salesByMonth, adjByMonth: adjByMonth, sizes: sizeList };
}
