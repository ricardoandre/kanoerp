const CAP = 10;
const ITEM_COL_MAX_WIDTH = 220;
// ── helpers ──
function uniqueUid(base) {
  return base + '_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 8);
}
function runSql(uid, sql) {
  const u = uniqueUid(uid);
  return ctx.sql.save({ uid: u, sql, dataSourceKey: 'main' })
    .then(() => ctx.sql.runById(u, { type: 'selectRows', dataSourceKey: 'main' }))
    .then(r => r || []);
}
function num(v) { const n = Number(v); return isNaN(n) ? 0 : n; }
function esc(s) { return String(s).replace(/'/g, "''"); }
function ymd(d) { return dayjs(d).format('YYYY-MM-DD'); }
function dash(n) { return n === 0 ? '-' : String(n); }
// compact "MMM 'YY" label used only inside the drill-down drawer table,
// where 6 months × 3 sub-columns need to fit without horizontal scroll.
function shortMonthLabel(monthKey) {
  return dayjs(monthKey + '-01').format("MMM 'YY");
}
function fetchStores() {
  return runSql('vmr_stores', "SELECT id, store_code, name FROM store ORDER BY name ASC");
}
function fetchImages() {
  const pageSize = 1000;
  function loadPage(page, acc) {
    return ctx.api.resource('product').list({
      fields: ['code'], appends: ['image'], pageSize: pageSize, page: page,
    }).then(function (res) {
      const rows = (res && res.data && res.data.data) || [];
      const merged = acc.concat(rows);
      if (rows.length < pageSize) return merged;
      return loadPage(page + 1, merged);
    });
  }
  return loadPage(1, []).then(function (rows) {
    const map = {};
    rows.forEach(function (p) {
      const img = p.image;
      const imgRow = Array.isArray(img) ? img[0] : img;
      if (!imgRow) return;
      map[p.code] = imgRow.url || (imgRow.filename ? '/storage/uploads/' + imgRow.filename : '');
    });
    return map;
  }).catch(function () { return {}; });
}
function fetchSalesRows(storeId, uptoDate) {
  return runSql('vmr_sales_v3',
    "SELECT ss.quantity AS quantity, ss.transaction_date AS transaction_date, " +
    "  pv.id AS variant_id, pv.fk_product_code AS product_code, pv.fk_sku_option_id AS sku_option_id, " +
    "  p.model AS model, p.name AS product_name, so.display AS sku_display, so.value AS sku_value, so.sort AS sku_sort " +
    "FROM store_sales ss " +
    "JOIN product_variant pv ON ss.fk_product_variant_id = pv.id " +
    "JOIN product p ON pv.fk_product_code = p.code " +
    "JOIN sku_option so ON pv.fk_sku_option_id = so.id " +
    "WHERE ss.fk_store_id = " + Number(storeId) +
    "  AND ss.transaction_date <= '" + esc(uptoDate) + "'"
  );
}
function fetchLedgerRows(storeId, uptoDate) {
  return runSql('vmr_ledger_v3',
    "SELECT sl.quantity AS quantity, sl.transaction_date AS transaction_date, " +
    "  pv.id AS variant_id, pv.fk_product_code AS product_code, pv.fk_sku_option_id AS sku_option_id, " +
    "  p.model AS model, p.name AS product_name, so.display AS sku_display, so.value AS sku_value, so.sort AS sku_sort " +
    "FROM stock_ledger sl " +
    "JOIN product_variant pv ON sl.fk_product_variant_id = pv.id " +
    "JOIN product p ON pv.fk_product_code = p.code " +
    "JOIN sku_option so ON pv.fk_sku_option_id = so.id " +
    "WHERE sl.fk_store_id = " + Number(storeId) +
    "  AND sl.transaction_date <= '" + esc(uptoDate) + "'"
  );
}
// ── months: 6, anchor first, descending (most recent first) ──
function buildMonths(anchorMonth) {
  const months = [];
  for (let i = 0; i < 6; i++) {
    const m = anchorMonth.subtract(i, 'month');
    months.push({ key: m.format('YYYY-MM'), label: m.format('MMM YYYY') });
  }
  return months;
}
// ── stock reconstruction ──
function buildEvents(salesRowsAllTime, ledgerRowsAllTime) {
  const events = {};
  function push(row, sign) {
    const vid = String(row.variant_id);
    if (!events[vid]) events[vid] = [];
    events[vid].push({ date: ymd(row.transaction_date), delta: sign * num(row.quantity) });
  }
  salesRowsAllTime.forEach(r => push(r, -1));
  ledgerRowsAllTime.forEach(r => push(r, 1));
  return events;
}
function stockAsOf(events, variantId, dateStr) {
  const list = events[String(variantId)];
  if (!list) return 0;
  let sum = 0;
  for (let i = 0; i < list.length; i++) { if (list[i].date <= dateStr) sum += list[i].delta; }
  return sum;
}
function stockForVariantSet(events, variantIdSet, dateStr) {
  let sum = 0;
  variantIdSet.forEach(vid => { sum += stockAsOf(events, vid, dateStr); });
  return sum;
}
function isOOSForVariantSet(events, variantIdSet, dateStr) {
  let any = false;
  variantIdSet.forEach(function (vid) { if (stockAsOf(events, vid, dateStr) <= 0) any = true; });
  return any;
}
function endOfMonthCapped(monthKey, anchorEndDate) {
  const eom = dayjs(monthKey + '-01').endOf('month').format('YYYY-MM-DD');
  return eom > anchorEndDate ? anchorEndDate : eom;
}
// ── section 1 data ──
function computeMonthlyStoreTotal(salesRowsAllTime, monthKeys) {
  const monthSet = {};
  monthKeys.forEach(k => { monthSet[k] = true; });
  const totals = {};
  monthKeys.forEach(k => { totals[k] = 0; });
  salesRowsAllTime.forEach(function (r) {
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    if (monthSet[mk]) totals[mk] += num(r.quantity);
  });
  return totals;
}
// ── sections 2/3/4 data ──
function groupKeyForSimple(row, groupBy) {
  if (groupBy === 'product') {
    return { key: 'prod_' + (row.product_code || ''), label: (row.product_code || '(no product)') + (row.product_name ? (' — ' + row.product_name) : ''), code: row.product_code || null, name: row.product_name || '' };
  }
  if (groupBy === 'variant') {
    return { key: 'sku_' + row.sku_option_id, label: row.sku_display || row.sku_value || '(no size)', code: null, name: '' };
  }
  return { key: 'model_' + (row.model || ''), label: row.model || '(no model)', code: null, name: '' };
}
function buildGroupedSales(salesRowsAllTime, ledgerRowsAllTime, groupBy, monthKeys) {
  const monthSet = {};
  monthKeys.forEach(k => { monthSet[k] = true; });
  const groups = {};
  function ensure(g) {
    if (!groups[g.key]) {
      const byMonth = {};
      monthKeys.forEach(mk => { byMonth[mk] = 0; });
      groups[g.key] = { label: g.label, code: g.code, name: g.name, total: 0, byMonth: byMonth, variantIds: new Set() };
    }
    return groups[g.key];
  }
  salesRowsAllTime.forEach(function (r) {
    const g = groupKeyForSimple(r, groupBy);
    const group = ensure(g);
    group.variantIds.add(String(r.variant_id));
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    if (monthSet[mk]) {
      const q = num(r.quantity);
      group.total += q; group.byMonth[mk] += q;
    }
  });
  ledgerRowsAllTime.forEach(function (r) {
    const g = groupKeyForSimple(r, groupBy);
    if (!groups[g.key]) return;
    groups[g.key].variantIds.add(String(r.variant_id));
  });
  const list = Object.keys(groups).map(k => groups[k]);
  list.sort((a, b) => b.total - a.total);
  return list;
}
// OOS is checked ONLY for the chosen (most recent displayed) month, not
// every month in the window.
function attachChosenMonthOOS(rows, events, chosenMonthKey, anchorEndDate) {
  rows.forEach(function (row) {
    row.isOOSChosen = isOOSForVariantSet(events, row.variantIds, endOfMonthCapped(chosenMonthKey, anchorEndDate));
  });
}
// ── rising/declining trend summary ──
function computeTrendSummary(rows, months) {
  const chosenKey = months[0].key;
  const priorKeys = months.slice(1).map(m => m.key);
  const rising = [], declining = [];
  rows.forEach(function (row) {
    const priorValues = priorKeys.map(k => row.byMonth[k]).filter(v => v > 0);
    if (!priorValues.length) return;
    const avgPrev = priorValues.reduce((s, v) => s + v, 0) / priorValues.length;
    const current = row.byMonth[chosenKey] || 0;
    const gain = current - avgPrev;
    const entry = { label: row.label, code: row.code, current: current, avgPrev: avgPrev, gain: gain };
    if (gain > 0) rising.push(entry);
    else if (gain < 0) declining.push(entry);
  });
  rising.sort((a, b) => b.gain - a.gain);
  declining.sort((a, b) => a.gain - b.gain);
  return { rising: rising, declining: declining };
}
// ── product-level index + metrics (sections 5/6) ──
function buildProductVariantIndex(salesRowsAllTime, ledgerRowsAllTime) {
  const idx = {};
  function ensure(code) {
    if (!idx[code]) idx[code] = { code: code, name: '', model: '', variantIds: new Set() };
    return idx[code];
  }
  function consume(rows) {
    rows.forEach(function (r) {
      const code = r.product_code || '';
      if (!code) return;
      const p = ensure(code);
      if (!p.name && r.product_name) p.name = r.product_name;
      if (!p.model && r.model) p.model = r.model;
      p.variantIds.add(String(r.variant_id));
    });
  }
  consume(salesRowsAllTime);
  consume(ledgerRowsAllTime);
  return idx;
}
// ── Product Rotation's minimum trial period: a product's earliest record
// (first sale OR first stock-ledger entry, whichever comes first — i.e.
// when it first showed up at this store at all, whether or not it went
// on to sell) — used so brand-new products aren't flagged for dropping
// before they've had a fair chance. Returns { code -> 'YYYY-MM-DD' }. ──
function computeFirstRecordDateByProduct(salesRowsAllTime, ledgerRowsAllTime) {
  const first = {};
  function consider(rows) {
    rows.forEach(function (r) {
      const code = r.product_code || '';
      if (!code) return;
      const d = ymd(r.transaction_date);
      if (!first[code] || d < first[code]) first[code] = d;
    });
  }
  consider(salesRowsAllTime);
  consider(ledgerRowsAllTime);
  return first;
}
function computeProductMetrics(productIndex, salesRowsAllTime, events, months, anchorEndDate) {
  const monthKeys = months.map(m => m.key);
  const lastMonthKey = monthKeys[0];
  const salesByProductMonth = {};
  salesRowsAllTime.forEach(function (r) {
    const code = r.product_code || '';
    if (!code) return;
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    if (!salesByProductMonth[code]) salesByProductMonth[code] = {};
    salesByProductMonth[code][mk] = (salesByProductMonth[code][mk] || 0) + num(r.quantity);
  });
  const metrics = {};
  Object.keys(productIndex).forEach(function (code) {
    const p = productIndex[code];
    const byMonth = salesByProductMonth[code] || {};
    let sales6mo = 0;
    monthKeys.forEach(mk => { sales6mo += (byMonth[mk] || 0); });
    const salesLastMonth = byMonth[lastMonthKey] || 0;
    const currentStock = stockForVariantSet(events, p.variantIds, anchorEndDate);
    const hasOOSVariant = isOOSForVariantSet(events, p.variantIds, anchorEndDate);
    let oosStreak = 0;
    for (let i = 0; i < months.length; i++) {
      const eom = endOfMonthCapped(months[i].key, anchorEndDate);
      if (isOOSForVariantSet(events, p.variantIds, eom)) oosStreak++; else break;
    }
    metrics[code] = { code: code, name: p.name, model: p.model, sales6mo: sales6mo, salesLastMonth: salesLastMonth, currentStock: currentStock, hasOOSVariant: hasOOSVariant, oosStreak: oosStreak };
  });
  return metrics;
}
// ── Need Restock's "missed sales opportunity" score: per-variant, take
// that variant's single best month of sales in the displayed window,
// subtract its current (end-of-Month-Period) stock, floor at 0, then sum
// across every variant of the product. A variant already stocked at or
// above its own peak demand contributes 0 — no OOS requirement, the score
// itself does the filtering.
// CAPPED by a second figure, the product's own Highest Monthly Sales —
// the biggest single month the WHOLE product (all variants combined)
// actually did within the window. The per-variant sum above can overstate
// potential, since each variant's peak may have landed in a different
// month and could never really happen all at once; if that realistic
// ceiling is lower than the summed opportunity, use the ceiling instead.
// Returns { code -> score }. ──
function computeRestockOpportunity(productIndex, salesRowsAllTime, events, months, anchorEndDate) {
  const monthKeys = months.map(m => m.key);
  const salesByVariantMonth = {};
  const salesByProductMonth = {};
  salesRowsAllTime.forEach(function (r) {
    const mk = dayjs(r.transaction_date).format('YYYY-MM');
    if (monthKeys.indexOf(mk) === -1) return;
    const vid = String(r.variant_id);
    const q = num(r.quantity);
    if (!salesByVariantMonth[vid]) salesByVariantMonth[vid] = {};
    salesByVariantMonth[vid][mk] = (salesByVariantMonth[vid][mk] || 0) + q;
    const code = r.product_code || '';
    if (code) {
      if (!salesByProductMonth[code]) salesByProductMonth[code] = {};
      salesByProductMonth[code][mk] = (salesByProductMonth[code][mk] || 0) + q;
    }
  });
  const scores = {};
  Object.keys(productIndex).forEach(function (code) {
    const p = productIndex[code];
    let opportunityScore = 0;
    p.variantIds.forEach(function (vid) {
      const byMonth = salesByVariantMonth[vid] || {};
      let peak = 0;
      monthKeys.forEach(function (mk) { const v = byMonth[mk] || 0; if (v > peak) peak = v; });
      const currentStock = stockAsOf(events, vid, anchorEndDate);
      opportunityScore += Math.max(peak - currentStock, 0);
    });
    const byProductMonth = salesByProductMonth[code] || {};
    let highestMonthlySales = 0;
    monthKeys.forEach(function (mk) { const v = byProductMonth[mk] || 0; if (v > highestMonthlySales) highestMonthlySales = v; });
    scores[code] = highestMonthlySales < opportunityScore ? highestMonthlySales : opportunityScore;
  });
