// ── section 1: bar chart ──
function TrendChart(props) {
  const monthsAsc = props.monthsAsc;
  const values = props.values;
  const width = 700, height = 220, padding = 32;
  const max = Math.max.apply(null, values.concat([1]));
  const n = Math.max(monthsAsc.length, 1);
  const slot = (width - padding * 2) / n;
  const barWidth = slot * 0.6;
  const usableHeight = height - padding * 2 - 14;
  const bars = monthsAsc.map(function (m, i) {
    const v = values[i] || 0;
    const h = max > 0 ? (v / max) * usableHeight : 0;
    const x = padding + i * slot + (slot - barWidth) / 2;
    const y = height - padding - h;
    return ce('g', { key: m.key },
      ce('rect', { x: x, y: y, width: barWidth, height: h, fill: STOCK_COLOR, rx: 3 }),
      ce('text', { x: x + barWidth / 2, y: y - 6, textAnchor: 'middle', fontSize: 11, fill: '#374151', fontWeight: 600 }, String(v)),
