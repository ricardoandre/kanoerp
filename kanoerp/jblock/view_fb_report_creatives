const Root = function () {
  const sReady = useState(false); const ready = sReady[0]; const setReady = sReady[1];
  const sLoadErr = useState(null); const loadErr = sLoadErr[0]; const setLoadErr = sLoadErr[1];

  const sObjective = useState(DEFAULT_OBJECTIVE); const objective = sObjective[0]; const setObjective = sObjective[1];
  const sGranularity = useState(DEFAULT_GRANULARITY); const granularity = sGranularity[0]; const setGranularity = sGranularity[1];
  const sCount = useState(DEFAULT_PERIOD_COUNT); const periodCount = sCount[0]; const setCount = sCount[1];
  const sLastDate = useState(dayjs().startOf('day')); const lastDate = sLastDate[0]; const setLastDate = sLastDate[1];
  const sActiveOnly = useState(DEFAULT_ACTIVE_ONLY); const activeOnly = sActiveOnly[0]; const setActiveOnly = sActiveOnly[1];
  const sSort = useState('metric_desc'); const sortVal = sSort[0]; const setSortVal = sSort[1];
  const sData = useState(null); const data = sData[0]; const setData = sData[1];
  const sPeriods = useState(null); const periods = sPeriods[0]; const setPeriods = sPeriods[1];
  const sErr = useState(null); const err = sErr[0]; const setErr = sErr[1];
  const sLoading = useState(true); const loading = sLoading[0]; const setLoading = sLoading[1];
  const sTargetRules = useState(null); const targetRules = sTargetRules[0]; const setTargetRules = sTargetRules[1];
  const sDataQuality = useState(null); const dataQuality = sDataQuality[0]; const setDataQuality = sDataQuality[1];

  const sAvailableAccounts = useState([]); const availableAccounts = sAvailableAccounts[0]; const setAvailableAccounts = sAvailableAccounts[1];
  const sSelectedAccount = useState(null); const selectedAccount = sSelectedAccount[0]; const setSelectedAccount = sSelectedAccount[1];

  function generate(obj, gran, count, account, lastDateParam) {
    setLoading(true); setErr(null);
    const p = fn.buildPeriods(gran, count, lastDateParam);
    loadDetailsData(obj, gran, p, account)
      .then(function (d) {
        let finalPeriods = p;
        if (gran === 'daily' && p.length && p[0].partial && !d.hasToday) {
          finalPeriods = p.slice(1);
        }
        setPeriods(finalPeriods);
        setData(d); setLoading(false);
        setDataQuality(d && d.reachQuality && d.reachQuality.approx > 0 ? d.reachQuality : null);
      })
      .catch(function (e) { setErr((e && e.message) || String(e)); setLoading(false); });
  }

  function handleAccountChange(account) { setSelectedAccount(account); generate(objective, granularity, periodCount, account, lastDate); }
  function handleObjectiveChange(v) { setObjective(v); setSortVal('metric_desc'); generate(v, granularity, periodCount, selectedAccount, lastDate); }
  function handleApplyTimeWindow(gran, count, ld) {
    setGranularity(gran); setCount(count); setLastDate(ld);
    generate(objective, gran, count, selectedAccount, ld);
  }
  function handleReload() { generate(objective, granularity, periodCount, selectedAccount, lastDate); }

  useEffect(function () {
    Promise.all([loadCode('fn_fbads_data'), loadCode('ui_fbads_controls')])
      .then(function (mods) {
        fn = mods[0]; ui = mods[1];
        setSelectedAccount(fn.DEFAULT_ACCOUNT);
        setReady(true);
      })
      .catch(function (e) { setLoadErr((e && e.message) || String(e)); });
  }, []);

  useEffect(function () {
    if (!ready) return;
    generate(objective, granularity, periodCount, selectedAccount, lastDate);
    fn.fetchAccountList(ctx).then(function (rows) { setAvailableAccounts(rows.map(function (r) { return r.account; })); }).catch(function () {});
    fn.fetchTargetRules(ctx).then(function (rules) { setTargetRules(rules); });
  }, [ready]);

  if (loadErr) return ce('div', { style: { color: '#ef4444', padding: 16 } }, 'Failed to load shared FB Ads modules: ' + loadErr);
  if (!ready || !targetRules) return ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, ce(Spin), ce('div', { style: { marginTop: 8 } }, 'Loading…'));

  function applyActiveFilter(rows) { return activeOnly ? rows.filter(function (r) { return r.isActive; }) : rows; }

  const periodUnitLabel = granularity === 'monthly' ? 'months' : granularity === 'daily' ? 'days' : 'weeks';
  const currentTarget = creativeTargetFor(objective, targetRules);
  const targetDesc = objective === 'reach' ? 'Target Cost/Reach < ' + fn.fmtRatio(targetRules.cost_reach.target)
    : objective === 'atc' ? 'Target Cost/ATC < ' + fn.fmtMoney(targetRules.cost_atc.target)
    : 'Target ROAS > ' + fn.fmtRatio(targetRules.roas.target);
  const accountsDesc = selectedAccount || 'All accounts';
  const summaryText = accountsDesc + '  ·  ' + (activeOnly ? 'Active ' : 'All ') + objective.toUpperCase() + ' · ' + granularity + ' · last ' + periodCount + ' ' + periodUnitLabel + '  ·  ' + targetDesc;
  const lastPeriodKey = periods ? periods[0].key : null;
  const sortOpts = lastPeriodKey ? sortOptionsFor(currentTarget, lastPeriodKey) : [];

  const filterBar = ce('div', { style: { display: 'flex', alignItems: 'flex-start', gap: 16, flexWrap: 'wrap', padding: '14px 20px', background: '#f9fafb', border: '1px solid #e5e7eb', borderRadius: 8 } },
    ui.Field('Account', ce(Select, {
      value: selectedAccount, onChange: handleAccountChange,
      style: { width: 200 }, placeholder: 'All accounts', allowClear: true,
      options: availableAccounts.map(function (a) { return { label: a, value: a }; }),
    })),
    ui.Field('Objective', ce(Segmented, { value: objective, onChange: handleObjectiveChange, options: OBJECTIVE_OPTIONS })),
    ui.Field('Time window', ce(ui.TimeWindowPopover, { granularity: granularity, periodCount: periodCount, lastDate: lastDate, loading: loading, onApply: handleApplyTimeWindow })),
    ui.Field('Show', ce('div', { style: { display: 'flex', alignItems: 'center', gap: 8, paddingTop: 4 } },
      ce(Switch, { checked: activeOnly, onChange: setActiveOnly, size: 'small' }),
      ce('span', { style: { fontSize: 13, color: '#374151' } }, activeOnly ? 'Active only' : 'All'))),
    ui.Field('Sort by last period', ce(Select, { value: sortVal, onChange: setSortVal, size: 'small', style: { width: 200 }, options: sortOpts, disabled: !sortOpts.length })),
    ui.Field('', ce(Button, { onClick: handleReload, title: 'Reload with current filters', style: { borderColor: '#0891b2', color: '#0891b2' } }, loading ? 'Refreshing…' : '↻ Refresh')));

  return ce('div', { style: { padding: 16 } },
    ce('div', { style: { fontSize: 18, fontWeight: 700, marginBottom: 4 } }, 'Facebook Ads — Creative Report'),
    ce('div', { style: { fontSize: 13, color: '#6b7280', marginBottom: 12 } }, summaryText),
    ce('div', { style: { marginBottom: 16 } }, filterBar),
    err ? ce('div', { style: { color: '#dc2626', marginBottom: 16, fontSize: 13 } }, 'Failed to load: ' + err) : null,

    dataQuality && !loading && objective === 'reach' && ce('div', {
      style: { display: 'flex', alignItems: 'center', gap: 8, padding: '8px 14px', marginBottom: 12, background: '#eff6ff', border: '1px solid #bfdbfe', borderRadius: 6, fontSize: 12, color: '#1e3a8a' },
    },
      ce('span', { style: { width: 8, height: 8, borderRadius: 4, background: '#3b82f6', flexShrink: 0 } }),
      dataQuality.approx + ' of ' + dataQuality.total + ' ad-period reach values below are approximated (marked "~ approx reach") — fb_ads_period_data hasn\'t been backfilled for those yet.'),

    loading
      ? ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af' } }, ce(Spin), ce('div', { style: { marginTop: 8 } }, 'Loading…'))
      : (data && periods
        ? ce('div', null, ce(LevelTable, { level: 'creative', rows: applyActiveFilter(data.creative), periods: periods, target: currentTarget, sortVal: sortVal, sortOpts: sortOpts }))
        : null));
};

ctx.render(ce(Root));
