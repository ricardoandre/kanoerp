// ── main loader ──
// =====================================================
function loadDetailsData(objective, granularity, periods, account) {
  const since = periods[periods.length - 1].start, until = periods[0].end;
  const lastPeriodKey = periods[0].key;
  const needsPeriodReach = granularity !== 'daily';
  const periodType = granularity === 'monthly' ? 'month' : 'week';
  const checkingToday = granularity === 'daily' && periods[0].partial;

  return fetchCampaignNameLookup(account).then(function (campaigns) {
    const allCampaignIds = campaigns.map(function (c) { return c.campaign_id; });
    const campMap = {}; campaigns.forEach(function (c) { campMap[c.campaign_id] = c.campaign_name; });

    // Real objective classification, not name-guessing — same pattern as
    // the Structure/Overview reports.
    return fn.fetchObjectiveMap(ctx, allCampaignIds).then(function (objectiveMap) {
      const matchIds = campaigns
        .filter(function (c) { return fn.resolveObjective(objectiveMap[c.campaign_id], c.campaign_name).objective === objective; })
        .map(function (c) { return c.campaign_id; });

      if (!matchIds.length) return { creative: [], hasToday: false };

      return Promise.all([
        fetchPeriodAgg('ad', granularity, since, until, matchIds),
        fetchAdsetIdentityLookup(matchIds),
        fetchAdIdentityLookup(since, until, matchIds),
        fetchCreativeMeta(),
        fetchCreativeImages(),
      ]).then(function (res) {
        const adPeriodRows = res[0];
        const adsetIdentity = res[1], adIdentity = res[2], creatives = res[3], images = res[4];

        const adsetMap = {}; adsetIdentity.forEach(function (a) { adsetMap[a.adset_id] = a; });
        const creativeMap = {}; creatives.forEach(function (c) { creativeMap[c.ad_id] = c; });

        const adByEntity = groupPeriodRows(adPeriodRows);
        const adIds = Object.keys(adByEntity);
        const hasToday = checkingToday ? adPeriodRows.some(function (r) { return r.period_key === lastPeriodKey; }) : false;

        const reachPromise = needsPeriodReach
          ? fetchAdPeriodReach(periodType, periods[periods.length - 1].start, periods[0].start, adIds)
          : Promise.resolve([]);

        return reachPromise.then(function (reachRows) {
          if (needsPeriodReach) applyAdPeriodReachOverrides(adByEntity, reachRows);

          const latestDataKey = adPeriodRows.reduce(function (best, r) {
            return (!best || r.period_key > best) ? r.period_key : best;
          }, null) || lastPeriodKey;

          const adIdentityMap = {}; adIdentity.forEach(function (a) { adIdentityMap[a.ad_id] = a; });
          const creativeRows = adIds.map(function (adId) {
            const periodMap = adByEntity[adId];
            const identityRow = adIdentityMap[adId] || {};
            const adsetName = (adsetMap[identityRow.adset_id] || {}).adset_name || '—';
            const campaignName = campMap[identityRow.campaign_id] || '(unknown campaign)';
            const creative = creativeMap[adId] || {};
            return {
              id: adId,
              identity: [identityRow.ad_name || adId, 'Adset: ' + adsetName, 'Campaign: ' + campaignName],
              image: images[adId] || '', source_url: creative.source_url || '',
              isActive: !!periodMap[latestDataKey],
              periodMap: periodMap, totals: sumTotals(periodMap),
            };
          });

          return {
            creative: creativeRows,
            hasToday: hasToday,
            reachQuality: needsPeriodReach
              ? creativeRows.reduce(function (acc, r) {
                  Object.keys(r.periodMap).forEach(function (pk) {
                    acc.total++;
                    if (r.periodMap[pk].reachSource !== 'real') acc.approx++;
                  });
                  return acc;
                }, { approx: 0, total: 0 })
              : null,
          };
        });
      });
    });
  });
}

// =====================================================
// ── per-objective target config — sourced from live targetRules ──
// =====================================================
function creativeTargetFor(objective, targetRules) {
  if (objective === 'reach') return { calc: r => fn.safeDiv(r.spend, r.reach), rule: targetRules.cost_reach, metricKey: 'reach', metricLabel: 'Reach', costLabel: 'Cost/Reach', costFmt: fn.fmtRatio, metricFmt: fn.fmtNum };
  if (objective === 'atc') return { calc: r => fn.safeDiv(r.spend, r.atc), rule: targetRules.cost_atc, metricKey: 'atc', metricLabel: 'ATC', costLabel: 'Cost/ATC', costFmt: fn.fmtMoney, metricFmt: fn.fmtNum };
  return { calc: r => fn.safeDiv(r.revenue, r.spend), rule: targetRules.roas, metricKey: 'purchase', metricLabel: 'Purchase', costLabel: 'ROAS', costFmt: fn.fmtRatio, metricFmt: fn.fmtNum };
}
const OBJECTIVE_OPTIONS = [{ label: 'Reach', value: 'reach' }, { label: 'ATC', value: 'atc' }, { label: 'Purchase', value: 'purchase' }];
const LEVEL_TITLE = { campaign: 'Campaign Level', adset: 'Adset Level', creative: 'Creative Level' };

function thStyle(extra) { return Object.assign({ textAlign: 'left', padding: '8px 10px', background: '#f9fafb', borderBottom: '1px solid #e5e7eb', fontWeight: 600, fontSize: 11, color: '#374151', whiteSpace: 'nowrap', boxSizing: 'border-box' }, extra || {}); }
function tdStyle(extra) { return Object.assign({ textAlign: 'left', padding: '6px 10px', borderBottom: '1px solid #f3f4f6', verticalAlign: 'top', color: '#374151', fontSize: 11, boxSizing: 'border-box' }, extra || {}); }

function StatusBadge(props) {
  const active = props.active;
  return ce('span', { style: { display: 'inline-block', padding: '1px 8px', borderRadius: 999, fontSize: 10, fontWeight: 700, background: active ? '#dcfce7' : '#f3f4f6', color: active ? fn.COLOR_GOOD : '#9ca3af' } }, active ? 'Active' : 'Inactive');
}

function PeriodCell(props) {
  const row = props.row, target = props.target;
  if (!row) return ce('div', { style: { color: '#d1d5db', width: PERIOD_COL_W - 20 } }, '—');
  const costVal = target.calc(row);
  const noSpend = fn.num(row.spend) === 0;
  const rule = target.rule;
  const achieved = !noSpend && rule && rule.target > 0 && isFinite(costVal) ? (rule.direction === 'lt' ? costVal < rule.target : costVal > rule.target) : false;
  const remarkColor = noSpend ? '#9ca3af' : achieved ? fn.COLOR_GOOD : fn.COLOR_BAD;
  const remarkText = noSpend ? '— Not Spending' : achieved ? '✓ Achieved' : '✗ Below Target';
  const showApproxNote = target.metricKey === 'reach' && row.reachSource === 'approx';
  return ce('div', { style: { lineHeight: 1.5, width: PERIOD_COL_W - 20 } },
    ce('div', null, 'Spend: ' + fn.fmtMoney(row.spend)),
    ce('div', null, target.metricLabel + ': ' + target.metricFmt(row[target.metricKey])),
    ce('div', null, target.costLabel + ': ' + target.costFmt(costVal)),
    ce('div', { style: { color: remarkColor, fontWeight: 700, marginTop: 2 } }, remarkText),
    showApproxNote && ce('div', { style: { color: '#3b82f6', fontSize: 9, marginTop: 2 }, title: 'fb_ads_period_data has no row for this ad/period yet.' }, '~ approx reach'));
}

function sortOptionsFor(target, lastPeriodKey) {
  function lastRow(r) { return r.periodMap[lastPeriodKey]; }
  function lastVal(r, key) { const row = lastRow(r); return row ? fn.num(row[key]) : -1; }
  function lastCost(r) { const row = lastRow(r); return row ? target.calc(row) : -1; }
  return [
    { value: 'name_asc', label: 'Name (A→Z)', sort: (a, b) => String(a.identity[0]).localeCompare(String(b.identity[0])) },
    { value: 'spend_desc', label: 'Spend (High→Low)', sort: (a, b) => lastVal(b, 'spend') - lastVal(a, 'spend') },
    { value: 'spend_asc', label: 'Spend (Low→High)', sort: (a, b) => lastVal(a, 'spend') - lastVal(b, 'spend') },
    { value: 'metric_desc', label: target.metricLabel + ' (High→Low)', sort: (a, b) => lastVal(b, target.metricKey) - lastVal(a, target.metricKey) },
    { value: 'metric_asc', label: target.metricLabel + ' (Low→High)', sort: (a, b) => lastVal(a, target.metricKey) - lastVal(b, target.metricKey) },
    { value: 'cost_desc', label: target.costLabel + ' (High→Low)', sort: (a, b) => lastCost(b) - lastCost(a) },
    { value: 'cost_asc', label: target.costLabel + ' (Low→High)', sort: (a, b) => lastCost(a) - lastCost(b) },
  ];
}

function ImageCell(props) {
