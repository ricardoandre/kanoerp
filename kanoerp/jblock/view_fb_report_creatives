      width: 220, pointerEvents: 'none',
    }},
    r.identity.map(function (line, idx) { return ce('div', { key: idx, style: { marginBottom: 2, fontSize: 12, fontWeight: idx === 0 ? 700 : 400, color: idx === 0 ? '#111827' : idx === 1 ? '#6b7280' : '#9ca3af' } }, line); }),
    ce('div', { style: { marginTop: 6 } }, statusBadgeEl));
  const img = r.image
    ? ce('img', { src: r.image, style: { width: 44, height: 44, objectFit: 'cover', borderRadius: 6, display: 'block' } })
    : ce('div', { style: { width: 44, height: 44, background: '#f3f4f6', borderRadius: 6, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: 18, color: '#d1d5db' } }, '?');
  return ce('td', {
    style: { padding: '6px 8px', borderBottom: '1px solid #f3f4f6', verticalAlign: 'middle', background: rowBg, position: 'sticky', left: 0, zIndex: 2, boxShadow: '2px 0 6px -2px rgba(0,0,0,0.10)', cursor: 'pointer', boxSizing: 'border-box', width: 60 },
    onMouseEnter: function () { setOpen(true); },
    onMouseLeave: function () { setOpen(false); },
    onClick: function () { setOpen(!open); },
  }, ce('div', { style: { position: 'relative' } }, img, tooltip));
}

function LevelTable(props) {
  const level = props.level, rows = props.rows, periods = props.periods, target = props.target;
  const sortVal = props.sortVal, sortOpts = props.sortOpts;
  const showImage = level === 'creative';

  const sortDef = sortOpts.find(function (s) { return s.value === sortVal; }) || sortOpts[3];
  const sorted = rows.slice().sort(sortDef.sort);

  const colDefs = [];
  if (showImage) colDefs.push({ key: 'img', w: 60 });
  colDefs.push({ key: 'identity', w: 180 });
  colDefs.push({ key: 'status', w: 76 });
  periods.forEach(function (p) { colDefs.push({ key: p.key, w: PERIOD_COL_W }); });
  const colgroup = ce('colgroup', null, colDefs.map(function (c) { return ce('col', { key: c.key, style: { width: c.w } }); }));

  const headerCells = [];
  if (showImage) headerCells.push(ce('th', { key: 'img', style: thStyle({ position: 'sticky', left: 0, zIndex: 3, background: '#f9fafb', boxShadow: '2px 0 6px -2px rgba(0,0,0,0.10)', width: 60 }) }, ''));
  headerCells.push(ce('th', { key: 'identity', style: thStyle() }, 'Creative / Adset / Campaign'));
  headerCells.push(ce('th', { key: 'status', style: thStyle() }, 'Status'));
  periods.forEach(function (p) { headerCells.push(ce('th', { key: p.key, style: thStyle() }, p.label)); });

  const bodyRows = sorted.map(function (r, i) {
    const rowBg = i % 2 ? '#fafafa' : '#fff';
    const cells = [];
    if (showImage) cells.push(ce(ImageCell, { key: 'img', r: r, rowBg: rowBg }));
    cells.push(ce('td', { key: 'identity', style: tdStyle({ background: rowBg }) },
      r.identity.map(function (line, idx) { return ce('div', { key: idx, style: idx === 0 ? { fontWeight: 700, color: '#111827' } : { color: idx === 1 ? '#6b7280' : '#9ca3af' } }, line); })));
    cells.push(ce('td', { key: 'status', style: tdStyle({ background: rowBg }) }, ce(StatusBadge, { active: r.isActive })));
    periods.forEach(function (p) {
      cells.push(ce('td', { key: p.key, style: tdStyle() }, ce(PeriodCell, { row: r.periodMap[p.key], target: target })));
    });
    return ce('tr', { key: r.id, style: { background: rowBg } }, cells);
  });

  return ce('div', { style: { marginBottom: 32 } },
    ce('div', { style: { fontWeight: 700, fontSize: 14, color: '#111827', marginBottom: 8 } }, LEVEL_TITLE[level] + ' (' + sorted.length + ')'),
    ce('div', { style: { overflowX: 'auto', border: '1px solid #e5e7eb', borderRadius: 8, WebkitOverflowScrolling: 'touch' } },
      ce('table', { style: { borderCollapse: 'separate', borderSpacing: 0, tableLayout: 'fixed' } },
        colgroup, ce('thead', null, ce('tr', null, headerCells)), ce('tbody', null, bodyRows))));
}

