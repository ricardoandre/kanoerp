// =====================================================
// jblock — FACEBOOK CREATIVE ADS REPORT
//
// Pick account (single-select), pick ONE objective (Reach / ATC /
// Purchase), pick Time window (Group by / Periods back / Last date +
// Apply), optionally filter to active-only, sort, then browse the Creative
// level table. Objective matching now uses real fb_ads_status.objective_key
// (fn.resolveObjective) instead of classifyCampaignName — see
// loadDetailsData below.
//
// Shared logic/UI lives in source_code rows (fn_fbads_data,
// ui_fbads_controls) — see view_fb_ads_structure.js for the same pattern.
// =====================================================

const { React, antd, dayjs } = ctx.libs;
const { useState, useEffect } = React;
const { Spin, Segmented, Button, Switch, Select } = antd;
const ce = React.createElement;

const DEFAULT_OBJECTIVE = 'atc';
const DEFAULT_GRANULARITY = 'weekly';
const DEFAULT_PERIOD_COUNT = 4;
const DEFAULT_ACTIVE_ONLY = true;
const PERIOD_COL_W = 140;

// ── shared code loader (README §3) ──
let fn = null, ui = null;
const _codeCache = {};
async function loadCode(name) {
  if (_codeCache[name]) return _codeCache[name];
  const uid = 'code_' + name;
  const rows = await ctx.sql.save({ uid, dataSourceKey: 'main', sql: "SELECT code FROM source_code WHERE name='" + name + "'" })
    .then(() => ctx.sql.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }));
  const src = (rows && rows[0] && rows[0].code) || '';
  _codeCache[name] = new Function('React', 'antd', 'dayjs', 'ctx', src)(React, antd, dayjs, ctx);
  return _codeCache[name];
}

// =====================================================
// ── lookups ──
// =====================================================
function fetchCampaignNameLookup(account) {
  return fn.runSql(ctx, 'fbdet_campaign_lookup',
    "SELECT campaign_id, MAX(campaign_name) AS campaign_name FROM campaigns_insights " +
    "WHERE 1=1 " + fn.accountFilterSql(account) +
    "GROUP BY campaign_id"
  );
}
function fetchAdsetIdentityLookup(campaignIds) {
  const idFilter = " WHERE campaign_id IN (" + fn.sqlInList(campaignIds) + ") ";
  return fn.runSql(ctx, 'fbdet_adset_identity', "SELECT adset_id, MAX(adset_name) AS adset_name, MAX(campaign_id) AS campaign_id FROM adsets_insights " + idFilter + " GROUP BY adset_id");
}
function fetchAdIdentityLookup(since, until, campaignIds) {
  const idFilter = " AND campaign_id IN (" + fn.sqlInList(campaignIds) + ") ";
  return fn.runSql(ctx, 'fbdet_ad_identity',
    "SELECT ad_id, MAX(ad_name) AS ad_name, MAX(adset_id) AS adset_id, MAX(campaign_id) AS campaign_id FROM ads_insights " +
    "WHERE date BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " + idFilter + " GROUP BY ad_id"
  );
}
function fetchCreativeMeta() {
  return fn.runSql(ctx, 'fbdet_creative_meta', "SELECT ad_id, creative_id, source_url FROM ads_creative");
}
function fetchCreativeImages() {
  return fn.runSql(ctx, 'fbdet_imgmeta', "SELECT CAST(options AS CHAR) AS options FROM fields WHERE collection_name='ads_creative' AND name='image'")
    .then(function (rows) {
      if (!rows.length) return {};
      let opt = {};
      try { opt = JSON.parse(rows[0].options || '{}'); } catch (e) { return {}; }
      const through = opt.through, fk = opt.foreignKey, ok = opt.otherKey, sk = opt.sourceKey || 'ad_id';
      if (!through || !fk || !ok) return {};
      return fn.runSql(ctx, 'fbdet_imgjoin',
        "SELECT ads_creative.ad_id AS ad_id, attachments.url AS url, attachments.filename AS filename " +
        "FROM ads_creative " +
        "JOIN " + through + " ON " + through + "." + fk + " = ads_creative." + sk + " " +
        "JOIN attachments ON attachments.id = " + through + "." + ok + " " +
        "ORDER BY attachments.id ASC"
      ).then(function (irows) {
        const map = {};
        irows.forEach(function (r) { if (!map[r.ad_id]) map[r.ad_id] = r.url || (r.filename ? '/storage/uploads/' + r.filename : ''); });
        return map;
      });
    }).catch(function () { return {}; });
}

function fetchPeriodAgg(level, granularity, since, until, campaignIds) {
  const keyExpr = fn.periodKeyExpr(granularity);
  const table = level === 'campaign' ? 'campaigns_insights' : level === 'adset' ? 'adsets_insights' : 'ads_insights';
  const idCol = level === 'campaign' ? 'campaign_id' : level === 'adset' ? 'adset_id' : 'ad_id';
  return fn.runSql(ctx, 'fbdet_periodagg_' + level,
    "SELECT " + idCol + " AS entity_id, " + keyExpr + " AS period_key, " +
    "       COALESCE(SUM(reach),0) AS reach, COALESCE(SUM(link_clicks),0) AS link_clicks, " +
    "       COALESCE(SUM(atc),0) AS atc, COALESCE(SUM(purchase),0) AS purchase, " +
    "       COALESCE(SUM(spend),0) AS spend, COALESCE(SUM(revenue),0) AS revenue " +
    "FROM " + table + " " +
    "WHERE date BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "AND campaign_id IN (" + fn.sqlInList(campaignIds) + ") " +
    "GROUP BY " + idCol + ", period_key"
  );
}
function fetchAdPeriodReach(periodType, since, until, adIds) {
  if (!adIds.length) return Promise.resolve([]);
  return fn.runSql(ctx, 'fbdet_period_reach',
    "SELECT entity_id AS ad_id, period_start AS period_key, COALESCE(SUM(reach),0) AS reach " +
    "FROM fb_ads_period_data " +
    "WHERE entity_type = 'ad' " +
    "  AND period_type = '" + periodType + "' " +
    "  AND period_start BETWEEN '" + fn.sqlDate(since) + "' AND '" + fn.sqlDate(until) + "' " +
    "  AND CAST(entity_id AS CHAR) IN (" + fn.sqlInList(adIds) + ") " +
    "GROUP BY entity_id, period_start"
  );
}
function applyAdPeriodReachOverrides(byEntity, reachRows) {
  const map = {};
  reachRows.forEach(function (r) { map[r.ad_id + '|' + r.period_key] = r; });
  Object.keys(byEntity).forEach(function (adId) {
    const periodMap = byEntity[adId];
    Object.keys(periodMap).forEach(function (pk) {
      const hit = map[adId + '|' + pk];
      if (hit) { periodMap[pk].reach = hit.reach; periodMap[pk].reachSource = 'real'; }
      else { periodMap[pk].reachSource = 'approx'; }
    });
  });
}
function groupPeriodRows(periodRows) {
  const byEntity = {};
  periodRows.forEach(function (r) {
    if (!byEntity[r.entity_id]) byEntity[r.entity_id] = {};
    byEntity[r.entity_id][r.period_key] = r;
  });
  return byEntity;
}
function sumTotals(periodMap) {
  const t = { reach: 0, link_clicks: 0, atc: 0, purchase: 0, spend: 0, revenue: 0 };
  Object.keys(periodMap).forEach(function (pk) {
    const r = periodMap[pk];
    t.reach += fn.num(r.reach); t.link_clicks += fn.num(r.link_clicks);
    t.atc += fn.num(r.atc); t.purchase += fn.num(r.purchase);
    t.spend += fn.num(r.spend); t.revenue += fn.num(r.revenue);
  });
  return t;
}

