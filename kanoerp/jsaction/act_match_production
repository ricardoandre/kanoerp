// =====================================================
// act_match_production — thin JSAction shell → ui_match_production.
//
// Table-level bulk action on production_result. Attach to that list
// block's toolbar (multi-select rows first).
//
// CONVERTED (2026-07): this JSAction used to contain a full, standalone
// copy of the matching logic (raw ctx.sql, per-product-code query loop).
// A separate, newer, resource-based, reusable version of the exact same
// feature already existed as ui_match_production.js — documented there as
// meant to be shared with ui_result_import/ui_result_bulk_add — but this
// JSAction wasn't actually calling it, so the two had drifted (this one
// on the slower N+1 query pattern the shared version already fixed).
// Converted to the standard thin-shell pattern used by every other
// act_production_* JSAction, so there's exactly one implementation to
// maintain going forward.
// =====================================================

const _codeCache = {};
async function loadCode(name) {
  if (_codeCache[name]) return _codeCache[name];
  const res = await ctx.api.resource('source_code').list({
    filter: { name: name },
    fields: ['code'],
    pageSize: 1,
  });
  const rows = (res && res.data && res.data.data) || [];
  const src = (rows[0] && rows[0].code) || '';
  if (!src) throw new Error("source_code row '" + name + "' was not found or is empty.");
  const { React, antd, dayjs } = ctx.libs;
  _codeCache[name] = new Function('React', 'antd', 'dayjs', 'ctx', src)(React, antd, dayjs, ctx);
  return _codeCache[name];
}

const selectedRows = ctx.resource?.getSelectedRows?.() || [];
if (!selectedRows.length) {
  ctx.message.warning('Please select at least one production result record.');
} else {
  const ids = selectedRows.map(r => r.id).filter(Boolean);
  if (!ids.length) {
    ctx.message.warning('Selected rows have no valid ID.');
  } else {
    try {
      const MP = await loadCode('ui_match_production');
      await MP.openMatchModal({
        ctx: ctx,
        ids: ids,
        onDone: () => { if (ctx.resource?.refresh) ctx.resource.refresh(); },
      });
    } catch (e) {
      console.error('act_match_production error:', e);
      ctx.message.error('Failed to open Match Production: ' + ((e && e.message) || 'unknown error'));
    }
  }
}
