// =====================================================
// ui_import_material_details — bulk-CREATE material_details rows from an
// uploaded CSV file (4 columns: code, fk_material_code, variant,
// supplier_variant_code).
//
// material_details fields:
//   code                  -> unique identifier (required)
//   fk_material_code      -> raw_material.code (required, confirmed)
//   variant                -> free text (optional)
//   supplier_variant_code   -> free text (optional)
//
// Create-only: if `code` already exists in material_details, the row is
// skipped and reported — no update/overwrite path (matches
// ui_import_product_material's behavior).
//
// SANDBOX NOTE (same environment as the other importers): SES lockdown
// blocks document.* property access, fetch(), writing to any global, and
// `new FileReader()`. So:
//   - Mounting follows ui_material_out's pattern: antd Modal.confirm() with
//     OK/Cancel hidden, custom buttons inside `content`, Modal.destroyAll()
//     to close.
//   - Files are read via Blob.prototype.text() on the File object antd's
//     Upload already hands us, parsed as plain delimited text
//     (comma/semicolon/tab, auto-detected).
//
// Stored as a `source_code` row named 'ui_import_material_details'.
// Loaded via loadCode(ctx, 'ui_import_material_details'); compiled with
// new Function('React','antd','dayjs','ctx', src)(React, antd, dayjs, ctx).
//
// EXPORTS (contract):
//   openModal({ ctx, onSaved })
//     — opens the wizard (pick file -> preview/validate -> confirm -> run ->
//       summary) via Modal.confirm. onSaved() fires once, after the modal is
//       closed, IF at least one row was actually created.
//
// Classification before running anything, per row { code, fk_material_code,
// variant, supplier_variant_code }:
//   - all four cells blank                            -> ignored entirely
//   - missing code and/or fk_material_code             -> skipped, invalid
//   - code already exists in material_details          -> skipped, duplicate
//   - fk_material_code not found in material            -> skipped, listed
//   - otherwise                                        -> created; variant
//     and supplier_variant_code are only included in the create payload if
//     non-blank (left unset otherwise, not sent as empty string)
// =====================================================

const { useState } = React;
const { Modal, Upload, Button, Table, Alert, Progress } = antd;
const ce = React.createElement;

function runSql(ctx, uid, sql) {
  return ctx.sql.save({ uid, sql, dataSourceKey: 'main' })
    .then(() => ctx.sql.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }))
    .then(r => r || []).catch(() => []);
}

// Reads the File object antd's Upload already handed us. Deliberately NOT
// `new FileReader()` — that constructor is blocked in this sandbox, same as
// document.* and fetch(). Blob.prototype.text() is an instance method on an
// object the platform already gave us, not a global we're instantiating, so
// it isn't subject to the same restriction.
function readFileAsText(file) {
  if (file && typeof file.text === 'function') return file.text();
  return Promise.reject(new Error('Cannot read this file in this sandbox.'));
}

function splitDelimitedLine(line, delim) {
  const out = []; let cur = ''; let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') {
      if (inQuotes && line[i + 1] === '"') { cur += '"'; i++; }
      else inQuotes = !inQuotes;
    } else if (ch === delim && !inQuotes) {
      out.push(cur); cur = '';
    } else cur += ch;
  }
  out.push(cur);
  return out;
}

function detectDelimiter(firstLine) {
  const cands = [',', ';', '\t'];
  let best = ',', bestCount = -1;
  cands.forEach(function (d) {
    const c = firstLine.split(d).length - 1;
    if (c > bestCount) { bestCount = c; best = d; }
  });
  return best;
}

// Shared normalizer: raw = array of row-arrays (cells: code,
// fk_material_code, variant, supplier_variant_code). Skips a header row
// heuristically. Rows where ALL FOUR cells are blank are dropped silently.
function rowsFromCells(raw) {
  if (!raw || !raw.length) return [];
  let start = 0;
  const c0 = String(raw[0][0] == null ? '' : raw[0][0]).trim().toLowerCase();
  const c1 = String(raw[0][1] == null ? '' : raw[0][1]).trim().toLowerCase();
  const c2 = String(raw[0][2] == null ? '' : raw[0][2]).trim().toLowerCase();
  const c3 = String(raw[0][3] == null ? '' : raw[0][3]).trim().toLowerCase();
  if (c0 === 'code' || c1 === 'fk_material_code' || c1 === 'material_code'
      || c2 === 'variant' || c3 === 'supplier_variant_code' || c3 === 'supplier variant code') start = 1;
  const out = [];
  for (let i = start; i < raw.length; i++) {
    const r = raw[i] || [];
    const code = String(r[0] == null ? '' : r[0]).trim();
    const fk_material_code = String(r[1] == null ? '' : r[1]).trim();
    const variant = String(r[2] == null ? '' : r[2]).trim();
    const supplier_variant_code = String(r[3] == null ? '' : r[3]).trim();
    if (!code && !fk_material_code && !variant && !supplier_variant_code) continue; // fully blank row — ignore
    out.push({ code: code, fk_material_code: fk_material_code, variant: variant, supplier_variant_code: supplier_variant_code, row: i + 1 });
  }
  return out;
}

function csvToCells(text) {
  const lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').filter(l => l.trim() !== '');
  if (!lines.length) return [];
  const delim = detectDelimiter(lines[0]);
  return lines.map(function (l) { return splitDelimitedLine(l, delim); });
}

function parseCsvRows(text) { return rowsFromCells(csvToCells(text)); }

function ImportContent(props) {
  const ctx = props.ctx;
  const onSaved = props.onSaved;
  const sP = useState('pick'); const phase = sP[0]; const setPhase = sP[1]; // pick | parsing | preview | running | done
  const sErr = useState(''); const err = sErr[0]; const setErr = sErr[1];
  const sRows = useState([]); const rows = sRows[0]; const setRows = sRows[1];
  const sToCreate = useState([]); const toCreate = sToCreate[0]; const setToCreate = sToCreate[1];
  const sDup = useState([]); const dup = sDup[0]; const setDup = sDup[1]; // code already exists
  const sNoMaterial = useState([]); const noMaterial = sNoMaterial[0]; const setNoMaterial = sNoMaterial[1]; // fk_material_code not found
  const sInvalid = useState([]); const invalid = sInvalid[0]; const setInvalid = sInvalid[1]; // missing code / fk_material_code
  const sBlankSkipped = useState(0); const blankSkipped = sBlankSkipped[0]; const setBlankSkipped = sBlankSkipped[1];
  const sProg = useState({ done: 0, total: 0 }); const prog = sProg[0]; const setProg = sProg[1];
  const sRes = useState({ created: 0, errors: [] }); const results = sRes[0]; const setResults = sRes[1];
  const sBusy = useState(false); const busy = sBusy[0]; const setBusy = sBusy[1];
  const savedAnyRef = React.useRef(false);

  function reset() {
    setPhase('pick'); setErr(''); setRows([]);
    setToCreate([]); setDup([]); setNoMaterial([]); setInvalid([]); setBlankSkipped(0);
    setProg({ done: 0, total: 0 }); setResults({ created: 0, errors: [] });
  }

  function handleFile(file) {
    setErr(''); setPhase('parsing'); setBusy(true);
    let parsed = [];
    Promise.resolve()
      .then(function () { return readFileAsText(file); })
      .then(function (text) {
        parsed = parseCsvRows(text);
        if (!parsed.length) throw new Error('No data rows found in the file.');
        setRows(parsed);
        return Promise.all([
          runSql(ctx, 'imd_existing', 'SELECT code FROM material_details'),
          runSql(ctx, 'imd_materials', 'SELECT code FROM raw_material'),
        ]);
      })
      .then(function (results2) {
        const existingRows = results2[0], materialRows = results2[1];
        const existingSet = {};
        (existingRows || []).forEach(function (e) { existingSet[String(e.code).trim()] = true; });
        const materialSet = {};
        (materialRows || []).forEach(function (m) { materialSet[String(m.code).trim()] = true; });

        const create = [], du = [], noMat = [], inv = [];
        parsed.forEach(function (row) {
          if (!row.code || !row.fk_material_code) {
            inv.push(Object.assign({}, row, { reason: 'missing code or fk_material_code' }));
            return;
          }
          if (existingSet[row.code]) { du.push(row); return; }
          if (!materialSet[row.fk_material_code]) { noMat.push(row); return; }
          create.push(row);
        });
        setToCreate(create); setDup(du); setNoMaterial(noMat); setInvalid(inv); setBlankSkipped(0);
        setPhase('preview'); setBusy(false);
      })
      .catch(function (e) {
        setErr((e && e.message) || String(e));
        setPhase('pick'); setBusy(false);
      });
  }

  async function runCreates() {
    setPhase('running'); setBusy(true);
    const total = toCreate.length;
    setProg({ done: 0, total: total });
    let created = 0;
    const errors = [];
    for (let i = 0; i < toCreate.length; i++) {
      const row = toCreate[i];
      try {
        const values = { code: row.code, material: row.fk_material_code };
        if (row.variant) values.variant = row.variant;
        if (row.supplier_variant_code) values.supplier_variant_code = row.supplier_variant_code;
        await ctx.api.resource('material_details').create({ values: values });
        created++;
      } catch (e) {
        errors.push({ code: row.code, message: (e && e.message) || String(e) });
      }
      setProg({ done: i + 1, total: total });
    }
    setResults({ created: created, errors: errors });
    setBusy(false); setPhase('done');
    if (created > 0) savedAnyRef.current = true;
  }

  function close() {
    if (busy) return;
    Modal.destroyAll();
    if (savedAnyRef.current) onSaved();
  }

  const createCols = [
    { title: 'Code', dataIndex: 'code', key: 'code' },
    { title: 'Fk Material Code', dataIndex: 'fk_material_code', key: 'fk_material_code' },
    { title: 'Variant', dataIndex: 'variant', key: 'variant',
      render: v => v || ce('span', { style: { color: '#cbd5e1', fontStyle: 'italic' } }, '(not set)') },
    { title: 'Supplier Variant Code', dataIndex: 'supplier_variant_code', key: 'supplier_variant_code',
      render: v => v || ce('span', { style: { color: '#cbd5e1', fontStyle: 'italic' } }, '(not set)') },
  ];
  const plainCols = [
    { title: 'Code', dataIndex: 'code', key: 'code' },
    { title: 'Fk Material Code', dataIndex: 'fk_material_code', key: 'fk_material_code' },
    { title: 'Variant', dataIndex: 'variant', key: 'variant' },
    { title: 'Supplier Variant Code', dataIndex: 'supplier_variant_code', key: 'supplier_variant_code' },
  ];
  const invalidCols = plainCols.concat([{ title: 'Reason', dataIndex: 'reason', key: 'reason' }]);

  if (phase === 'pick' || phase === 'parsing') {
    return ce('div', { style: { fontFamily: 'system-ui,sans-serif' } },
      ce(Upload.Dragger, {
        accept: '.csv,.txt,.tsv',
        showUploadList: false,
        disabled: phase === 'parsing',
        beforeUpload: function (file) { handleFile(file); return false; },
      },
        ce('p', { style: { fontSize: 28, margin: '4px 0' } }, phase === 'parsing' ? '⏳' : '📄'),
        ce('p', { style: { fontWeight: 600 } }, phase === 'parsing' ? 'Reading file…' : 'Click or drag a CSV file here'),
        ce('p', { style: { fontSize: 12, color: '#9ca3af' } }, 'Column A: code, B: fk_material_code, C: variant, D: supplier_variant_code')),
      err ? ce(Alert, { type: 'error', showIcon: true, message: err, style: { marginTop: 12 } }) : null,
      ce('div', { style: { display: 'flex', justifyContent: 'flex-end', marginTop: 16 } },
        ce(Button, { onClick: close, disabled: phase === 'parsing' }, 'Cancel')));
  }

  if (phase === 'preview') {
    const summaryBits = [];
    summaryBits.push(toCreate.length + ' will be created');
    if (dup.length) summaryBits.push(dup.length + ' code(s) already exist (skipped)');
    if (noMaterial.length) summaryBits.push(noMaterial.length + ' fk_material_code not found (skipped)');
    if (invalid.length) summaryBits.push(invalid.length + ' invalid row(s) (skipped)');

    return ce('div', { style: { fontFamily: 'system-ui,sans-serif' } },
      ce(Alert, {
        type: (dup.length || noMaterial.length || invalid.length) ? 'warning' : 'info', showIcon: true,
        message: rows.length + ' row(s) read from the file.',
        description: summaryBits.join('. ') + '.',
      }),
      toCreate.length ? ce('div', { style: { marginTop: 12 } },
        ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Will create (' + toCreate.length + ')'),
        ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: createCols, dataSource: toCreate })) : null,
      dup.length ? ce('div', { style: { marginTop: 16 } },
        ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Already exist — skipped (' + dup.length + ')'),
        ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: plainCols, dataSource: dup })) : null,
      noMaterial.length ? ce('div', { style: { marginTop: 16 } },
        ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'fk_material_code not found (' + noMaterial.length + ')'),
        ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: plainCols, dataSource: noMaterial })) : null,
      invalid.length ? ce('div', { style: { marginTop: 16 } },
        ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Invalid rows (' + invalid.length + ')'),
        ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: invalidCols, dataSource: invalid })) : null,
      ce('div', { style: { display: 'flex', justifyContent: 'space-between', marginTop: 16 } },
        ce(Button, { onClick: reset }, 'Back'),
        ce('div', { style: { display: 'flex', gap: 8 } },
          ce(Button, { onClick: close }, 'Cancel'),
          ce(Button, { type: 'primary', disabled: !toCreate.length, onClick: runCreates },
            'Run import — ' + toCreate.length + ' row(s)'))));
  }

  if (phase === 'running') {
    return ce('div', { style: { padding: '20px 0', textAlign: 'center' } },
      ce(Progress, { percent: prog.total ? Math.round((prog.done / prog.total) * 100) : 0 }),
      ce('div', { style: { marginTop: 8, color: '#6b7280', fontSize: 13 } }, 'Creating ' + prog.done + ' / ' + prog.total + '…'));
  }

  // done
  function statRow(label, value, color) {
    return ce('div', { style: { display: 'flex', justifyContent: 'space-between', padding: '4px 0', borderBottom: '1px solid #f1f5f9' } },
      ce('span', { style: { color: '#475569' } }, label),
      ce('span', { style: { fontWeight: 600, color: color || '#111827' } }, value));
  }

  return ce('div', { style: { fontFamily: 'system-ui,sans-serif' } },
    ce(Alert, {
      type: results.errors.length ? 'warning' : 'success', showIcon: true,
      message: 'Created ' + results.created + ' of ' + toCreate.length + ' attempted.',
    }),
    ce('div', { style: { marginTop: 12, border: '1px solid #e5e7eb', borderRadius: 6, padding: '4px 12px' } },
      statRow('Rows read from file', rows.length),
      statRow('Created successfully', results.created, '#16a34a'),
      results.errors.length ? statRow('Failed during create', results.errors.length, '#dc2626') : null,
      dup.length ? statRow('Already existed (skipped)', dup.length) : null,
      noMaterial.length ? statRow('fk_material_code not found (skipped)', noMaterial.length) : null,
      invalid.length ? statRow('Invalid rows (skipped)', invalid.length) : null),
    results.errors.length ? ce('div', { style: { marginTop: 16 } },
      ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Failed rows'),
      ce(Table, {
        size: 'small', rowKey: 'code', pagination: { pageSize: 5 },
        columns: [{ title: 'Code', dataIndex: 'code' }, { title: 'Error', dataIndex: 'message' }],
        dataSource: results.errors,
      })) : null,
    dup.length ? ce('div', { style: { marginTop: 16 } },
      ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Already existed — skipped'),
      ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: plainCols, dataSource: dup })) : null,
    noMaterial.length ? ce('div', { style: { marginTop: 16 } },
      ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'fk_material_code not found'),
      ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: plainCols, dataSource: noMaterial })) : null,
    invalid.length ? ce('div', { style: { marginTop: 16 } },
      ce('div', { style: { fontWeight: 600, marginBottom: 4 } }, 'Invalid rows'),
      ce(Table, { size: 'small', rowKey: 'row', pagination: { pageSize: 5 }, columns: invalidCols, dataSource: invalid })) : null,
    ce('div', { style: { display: 'flex', justifyContent: 'flex-end', marginTop: 16 } },
      ce(Button, { type: 'primary', onClick: close }, 'Close')));
}

// ===== entry point: mirrors ui_material_out's openModal shell exactly =====
function openModal(args) {
  const ctx = args.ctx;
  const onSaved = args.onSaved;
  if (!ctx) return;
  Modal.confirm({
    title: 'Import Material Details',
    width: 700,
    icon: null,
    content: ce(ImportContent, { ctx: ctx, onSaved: onSaved }),
    okButtonProps: { style: { display: 'none' } },
    cancelButtonProps: { style: { display: 'none' } },
    maskClosable: true,
    onCancel() {},
  });
}

return { openModal };
