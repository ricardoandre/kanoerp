// Paginates through ctx.api.resource(collection).list() until a short page
// comes back, so full-table lookups (no WHERE) don't silently truncate.
async function fetchAllRows(ctx, collection, fields) {
  const pageSize = 500;
  let page = 1;
  let out = [];
  while (true) {
    const res = await ctx.api.resource(collection).list({ fields: fields, page: page, pageSize: pageSize }).catch(() => null);
    const rows = (res && res.data && res.data.data) || [];
    out = out.concat(rows);
    if (rows.length < pageSize) break;
    page++;
  }
  return out;
}

