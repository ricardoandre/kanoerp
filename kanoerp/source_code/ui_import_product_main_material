  const sFresh = useState([]); const fresh = sFresh[0]; const setFresh = sFresh[1]; // will update, no confirmation needed
  const sConflicts = useState([]); const conflicts = sConflicts[0]; const setConflicts = sConflicts[1]; // needs confirmation
  const sSelectedConflicts = useState([]); const selectedConflicts = sSelectedConflicts[0]; const setSelectedConflicts = sSelectedConflicts[1]; // rowKeys
  const sNoop = useState([]); const noop = sNoop[0]; const setNoop = sNoop[1]; // already correct
