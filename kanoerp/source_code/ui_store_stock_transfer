// ===== loader: opens instantly, fetches reference data inside =====
function TransferLoader(props) {
  const ctx = props.ctx;
  const onSaved = props.onSaved;
  const [state, setState] = useState({ loading: true, stores: [], products: [], skuOptions: [], productVariants: [], err: null });
  useEffect(function () {
    let alive = true;
    Promise.all([fetchStores(ctx), fetchProducts(ctx), fetchSkuOptions(ctx), fetchProductVariants(ctx)])
      .then(function (res) {
        if (alive) setState({ loading: false, stores: res[0], products: res[1], skuOptions: res[2], productVariants: res[3], err: null });
      })
      .catch(function (e) {
        if (alive) setState({ loading: false, stores: [], products: [], skuOptions: [], productVariants: [], err: (e && e.message) || 'load failed' });
      });
    return function () { alive = false; };
  }, []);
  if (state.loading) return ce('div', { style: { padding: 40, textAlign: 'center', color: '#9ca3af', fontSize: 13 } }, 'Loading…');
  if (state.err) return ce('div', { style: { padding: 24, color: '#ef4444', fontSize: 13 } }, state.err);
  const todayStr = dayjs ? dayjs().format('YYYY-MM-DD') : new Date().toISOString().substring(0, 10);
  return ce(TransferContent, {
    ctx: ctx, stores: state.stores, products: state.products, skuOptions: state.skuOptions,
    productVariants: state.productVariants, todayStr: todayStr, onSaved: onSaved,
  });
}
// ===== entry point =====
function openModal(args) {
  const ctx = args.ctx;
  const onSaved = args.onSaved;
  if (!ctx) return;
  Modal.confirm({
    title: 'Bulk Stock Transfer',
    width: 820,
    icon: null,
    content: ce(TransferLoader, { ctx: ctx, onSaved: onSaved }),
    okButtonProps: { style: { display: 'none' } },
    cancelButtonProps: { style: { display: 'none' } },
    maskClosable: true,
    onCancel() {},
  });
}
return { openModal };
