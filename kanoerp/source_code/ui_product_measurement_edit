// ── load an existing set: header, linked products, size rows (ALL columns) ──
function fetchMeasurementForEdit(id) {
  return Promise.all([
    ctx.api.resource('product_measurement').get({ filterByTk: id, fields: ['id', 'name', 'remarks'] }).then(r => r.data.data),
    fetchAllPages('product', { filter: { fk_product_measurement_id: id }, fields: ['code', 'name'] }),
    fetchAllPages('product_measurement_variant', { filter: { fk_product_measurement_variant_id: id }, fields: ['id'].concat(MEASURE_FIELDS.map(f => f.key)), appends: ['sku_option'] }),
  ]).then(function (r) {
    const pm = r[0]; const products = r[1]; const varRows = r[2];
    const gridRows = varRows.map(v => {
      const sk = v.sku_option || {};
      const values = {}; MEASURE_FIELDS.forEach(f => { values[f.key] = v[f.key]; });
      return { variant_id: v.id, sku_id: sk.id, sku_display: sk.display || '—', sku_sort: sk.sort || 0, values: values };
    }).sort((a, b) => a.sku_sort - b.sku_sort);
    return { name: pm.name || '', remarks: pm.remarks || '', productCodes: products.map(p => p.code), gridRows: gridRows };
  });
}

async function updateProductMeasurement(id, form) {
  await ctx.api.resource('product_measurement').update({ filterByTk: id, values: { name: form.name, remarks: form.remarks || '' } });

  const toUpdate = form.gridRows.filter(r => r.variant_id);
  const toCreate = form.gridRows.filter(r => !r.variant_id);
  const currentVariantIds = new Set(toUpdate.map(r => r.variant_id));
  const toDelete = form.originalVariantIds.filter(vid => !currentVariantIds.has(vid));

  for (const row of toUpdate) {
    await ctx.api.resource('product_measurement_variant').update({ filterByTk: row.variant_id, values: Object.assign({}, row.values, { sku_option: { id: row.sku_id } }) });
  }
  for (const row of toCreate) {
    const values = Object.assign({}, row.values, { sku_option: { id: row.sku_id }, fk_product_measurement_variant_id: id });
    await ctx.api.resource('product_measurement_variant').create({ values });
  }
  for (const vid of toDelete) { await ctx.api.resource('product_measurement_variant').destroy({ filterByTk: vid }); }

  const currentCodes = new Set(form.selectedProducts);
  const addedCodes = form.selectedProducts.filter(c => !form.originalProductCodes.includes(c));
  const removedCodes = form.originalProductCodes.filter(c => !currentCodes.has(c));
  for (const code of addedCodes) { await ctx.api.resource('product').update({ filterByTk: code, values: { fk_product_measurement_id: id } }); }
  for (const code of removedCodes) { await ctx.api.resource('product').update({ filterByTk: code, values: { fk_product_measurement_id: null } }); }
}

