// =====================================================
// ui_match_production — shared Match-[Result] logic + modal.
//
// Stored as a `source_code` row named 'ui_match_production'.
// Loaded via loadCode('ui_match_production'); compiled with
//   new Function('React','antd','dayjs','ctx', src)(React, antd, dayjs, ctx).
//
// GENERALIZED (2026-07) to serve BOTH production_result and qc_result
// matching — these were previously two near-identical, fully duplicated
// JSActions (act_match_production, act_match_qc_result), differing only in:
// table name, date field, person field, defect/permak flag + badge style,
// and whether a successful match also bumps the production's status to
// 'qc'. One difference (production's matcher disabling Apply permanently
// after a successful run, "done" state; QC's original never had this) was
// initially preserved as-is on the assumption it was intentional — later
// confirmed to have actually been an oversight, not a deliberate design
// choice. Both kinds now set hasDoneState: true — matching is one-time-only
// for QC as well.
//
// This is otherwise an EXACT port of each original's raw ctx.sql queries
// (same INNER JOIN behavior on the production-candidate lookup — a
// production whose fk_konveksi_code/fk_product_code doesn't resolve is
// silently excluded, matching both originals) and the same atomic
// single-statement status bump for production_result specifically.
//
// EXPORTS (contract):
//   openMatchModal({ ctx, ids, onDone, kind })
//     — kind: 'production_result' (default, matches the original
//       act_match_production caller which doesn't pass kind) or
//       'qc_result'. Fetches + opens the matcher modal for that kind.
//
// Depends on: none.
// =====================================================
const { useState } = React;
const { Modal } = antd;
const ce = React.createElement;

// ===== per-kind configuration — everything that differs between
// production_result and qc_result matching lives here, nothing scattered
// elsewhere in the file. =====
const KIND_CONFIG = {
  production_result: {
    table: 'production_result',
    dateField: 'shipment_date',
    dateColumnLabel: 'Shipment Date',
    personField: 'checking_pic',
    flagField: 'is_permakan',
    // flag badge: only rendered when true (no "not permakan" badge) —
    // matches the original exactly.
    flagBadge: function (row) {
      return row.is_permakan
        ? ce('span', { style: { display: 'inline-block', background: '#fef2f2', color: '#ef4444', border: '1px solid #fca5a5', borderRadius: 3, padding: '0 5px', fontSize: 10, fontWeight: 600, marginTop: 3 } }, 'PERMAK')
        : null;
    },
    bumpProductionStatus: true,
    hasDoneState: true,
    modalTitle: 'Match Production Results → Production',
    selectWarnLabel: 'production result',
    emptyStateLabel: 'production result',
    successDescription: function (ok) { return ok + ' production result(s) linked. Eligible productions moved to QC.'; },
  },
  qc_result: {
    table: 'qc_result',
    dateField: 'qc_date',
    dateColumnLabel: 'QC Date',
    personField: 'qc_person',
    flagField: 'is_defect',
    // flag badge: ALWAYS rendered, either DEFECT or OK — matches the
    // original exactly (unlike production_result's permakan badge, which
    // only shows on true).
    flagBadge: function (row) {
      return row.is_defect
        ? ce('span', { style: { display: 'inline-block', background: '#fef2f2', color: '#ef4444', border: '1px solid #fca5a5', borderRadius: 3, padding: '0 5px', fontSize: 10, fontWeight: 600, marginTop: 3 } }, 'DEFECT')
        : ce('span', { style: { display: 'inline-block', background: '#f0fdf4', color: '#16a34a', border: '1px solid #86efac', borderRadius: 3, padding: '0 5px', fontSize: 10, fontWeight: 600, marginTop: 3 } }, 'OK');
    },
    bumpProductionStatus: false,
    // CHANGED 2026-07: was false — production_result's matcher already
    // disabled Apply permanently after one successful run and QC's didn't;
    // confirmed this was an oversight, not an intentional difference.
    // Matching is one-time-only for both kinds now.
    hasDoneState: true,
    modalTitle: 'Match QC Results → Production',
    selectWarnLabel: 'QC result',
    emptyStateLabel: 'QC result',
    successDescription: function (ok) { return ok + ' QC result(s) successfully linked to production.'; },
  },
};

// ===== SQL helpers (raw ctx.sql — confirmed NOT admin-gated, see README §3
// correction; matches what both originals used) =====
async function runSql(ctx, uid, sql) {
  if (ctx.flowSettingsEnabled) {
    await ctx.sql.save({ uid, sql, dataSourceKey: 'main' }).catch(() => {});
  }
  return ctx.sql.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }).then(r => r || []).catch(() => []);
}
async function execSql(ctx, uid, sql) {
  if (ctx.flowSettingsEnabled) {
    await ctx.sql.save({ uid, sql, dataSourceKey: 'main' }).catch(() => {});
  }
  return ctx.sql.runById(uid, { type: 'exec', dataSourceKey: 'main' }).catch(() => null);
}

function fmt(d) { return d ? String(d).substring(0, 10) : '-'; }

// ─────────────────────────────────────────────────────
// DATA LAYER
// ─────────────────────────────────────────────────────
async function fetchMatchData(ctx, ids, cfg) {
  ids = (ids || []).filter(Boolean);
  if (!ids.length) return { resultRows: [], productionMap: {}, variantMap: {} };

  const idList = ids.map(id => `'${id}'`).join(',');
  const uidPrefix = cfg.table === 'qc_result' ? 'qc_match' : 'pr_match';

  const resultRows = await runSql(ctx, uidPrefix + '_results',
    `SELECT ${cfg.table}.id, ${cfg.table}.import_product_code, ` +
    `${cfg.table}.quantity, ${cfg.table}.remarks, ` +
    `${cfg.table}.${cfg.dateField}, ${cfg.table}.${cfg.personField}, ` +
    `${cfg.table}.${cfg.flagField}, ${cfg.table}.fk_production_id, ` +
    `${cfg.table}.fk_sku_option_id, ` +
    `sku_option.display AS sku_display, sku_option.sort AS sku_sort, ` +
    `product.name AS product_name ` +
    `FROM ${cfg.table} ` +
    `LEFT JOIN sku_option ON ${cfg.table}.fk_sku_option_id = sku_option.id ` +
    `LEFT JOIN product ON ${cfg.table}.import_product_code = product.code ` +
    `WHERE ${cfg.table}.id IN (${idList}) ` +
    `ORDER BY ${cfg.table}.${cfg.dateField}, ${cfg.table}.import_product_code, sku_option.sort`
  );

  const productCodes = [...new Set(resultRows.map(r => r.import_product_code).filter(Boolean))];
  const productionMap = {};
  for (const code of productCodes) {
    productionMap[code] = await runSql(ctx, uidPrefix + '_prod_' + code,
      `SELECT production.id, production.production_ref, production.status, ` +
      `production.est_production_start, production.est_production_finish, ` +
      `konveksi.name AS konveksi_name, product.name AS product_name ` +
      `FROM production, konveksi, product ` +
      `WHERE production.fk_product_code = '${code}' ` +
      `AND production.status <> 'planning' AND production.status <> 'done' ` +
      `AND production.fk_konveksi_code = konveksi.code ` +
      `AND production.fk_product_code = product.code ` +
      `ORDER BY production.est_production_finish`
    );
  }

  const allProductionIds = Object.values(productionMap).flat().map(p => p.id);
  const variantMap = {};
  for (const prodId of allProductionIds) {
    const rows = await runSql(ctx, uidPrefix + '_var_' + prodId,
      `SELECT fk_sku_option_id FROM production_quantity_details ` +
      `WHERE fk_production_id = '${prodId}'`
    );
    variantMap[prodId] = new Set(rows.map(r => String(r.fk_sku_option_id)));
  }

  return { resultRows, productionMap, variantMap };
}

// ─────────────────────────────────────────────────────
// WRITE LAYER
// ─────────────────────────────────────────────────────
async function applyMatches(ctx, selections, cfg) {
  const toUpdate = Object.entries(selections).filter(([, prodId]) => prodId !== null && prodId !== undefined);
  const uidPrefix = cfg.table === 'qc_result' ? 'qc' : 'pr';
  let ok = 0;
  for (const [resultId, prodId] of toUpdate) {
    const res = await execSql(ctx, uidPrefix + '_upd_' + resultId,
      `UPDATE ${cfg.table} SET fk_production_id = '${prodId}' WHERE id = '${resultId}'`
    );
    if (res !== null) ok++;
  }

  if (cfg.bumpProductionStatus) {
    const uniqueProdIds = [...new Set(toUpdate.map(([, prodId]) => prodId))];
    for (const prodId of uniqueProdIds) {
      await execSql(ctx, uidPrefix + '_status_' + prodId,
        `UPDATE production SET status = 'qc' WHERE id = '${prodId}' AND status IN ('cutting', 'production')`
      );
    }
  }

  return { ok: ok, total: toUpdate.length };
}

// ─────────────────────────────────────────────────────
// MATCHER UI — presentation only; data + ctx + cfg come from props.
// ─────────────────────────────────────────────────────
function MatcherContent(props) {
  const ctx = props.ctx;
  const cfg = props.cfg;
  const resultRows = props.resultRows || [];
  const productionMap = props.productionMap || {};
  const variantMap = props.variantMap || {};
  const onDone = props.onDone;

  const initSelections = {};
  resultRows.forEach(r => {
    const options = productionMap[r.import_product_code] || [];
    initSelections[r.id] = options.length === 1 ? options[0].id : (r.fk_production_id || null);
  });

  const [selections, setSelections] = useState(initSelections);
  const [applying, setApplying] = useState(false);
  const [done, setDone] = useState(false);

  function handleClose() { Modal.destroyAll(); }

  function toggleSelection(resultId, productionId) {
    setSelections(prev => ({
      ...prev,
      [resultId]: prev[resultId] === productionId ? null : productionId
    }));
  }

  async function applyAll() {
    const hasAny = Object.values(selections).some(v => v !== null);
    if (!hasAny) { ctx.message.warning('No matches selected.'); return; }
    setApplying(true);
    const res = await applyMatches(ctx, selections, cfg);
    if (cfg.hasDoneState) setDone(true);
    setApplying(false);

    const failed = res.total - res.ok;
    Modal.destroyAll();
    if (failed === 0) {
      ctx.notification.success({
        message: 'Matching Complete',
        description: cfg.successDescription(res.ok),
        duration: 6,
      });
    } else {
      ctx.notification.warning({
        message: 'Matching Partial',
        description: `${res.ok} record(s) updated, ${failed} failed. Please check and retry the failed rows.`,
        duration: 8,
      });
    }
    if (onDone) onDone();
  }

  const matchedCount = Object.values(selections).filter(v => v !== null).length;
  const unmatched = resultRows.length - matchedCount;

  const hasInvalidSelections = resultRows.some(row => {
    const selectedProdId = selections[row.id];
    if (!selectedProdId) return false;
    const validVariants = variantMap[selectedProdId] || new Set();
    return validVariants.size > 0 && !validVariants.has(String(row.fk_sku_option_id));
  });

  const th = {
    background: '#fafafa', borderBottom: '2px solid #e8e8e8',
    padding: '7px 8px', fontWeight: 600, textAlign: 'left', fontSize: 11, color: '#555'
  };
  const td = (alt) => ({
    borderBottom: '1px solid #f0f0f0', padding: '8px',
    verticalAlign: 'top', fontSize: 12, background: alt ? '#fafafa' : '#fff'
  });
  const optBox = (sel) => ({
    display: 'flex', alignItems: 'flex-start', gap: 6,
    padding: '5px 6px', borderRadius: 4, marginBottom: 4,
    border: sel ? '1px solid #86efac' : '1px solid #e8e8e8',
    cursor: 'pointer', background: sel ? '#f0fdf4' : '#fff'
  });

  if (!resultRows.length) {
    return ce('div', { style: { fontFamily: 'system-ui,sans-serif', padding: '12px 0' } },
      ce('div', { style: { color: '#f59e0b', marginBottom: 16, fontSize: 13 } },
        '⚠ No ' + cfg.emptyStateLabel + ' records could be loaded for the selected rows.'
      ),
      ce('div', { style: { display: 'flex', justifyContent: 'flex-end' } },
        ce('button', {
          onClick: handleClose,
          style: { padding: '5px 14px', fontSize: 12, cursor: 'pointer', border: '1px solid #d9d9d9', borderRadius: 4, background: '#fff' }
        }, 'Close')
      )
    );
  }

  return ce('div', { style: { fontFamily: 'system-ui,sans-serif', fontSize: 12 } },

    ce('div', { style: { color: '#888', fontSize: 11, marginBottom: 12 } },
      `${resultRows.length} result(s) · ${matchedCount} matched · ${unmatched} unmatched`
    ),

    ce('div', { style: { overflowX: 'auto' } },
      ce('table', { style: { width: '100%', borderCollapse: 'collapse', tableLayout: 'fixed' } },
        ce('colgroup', null,
          ce('col', { style: { width: '90px' } }),
          ce('col', { style: { width: '150px' } }),
          ce('col', { style: { width: '55px' } }),
          ce('col', { style: { width: cfg.table === 'qc_result' ? '130px' : '120px' } }),
          ce('col', { style: { width: 'auto' } })
        ),
        ce('thead', null,
          ce('tr', null,
            [cfg.dateColumnLabel, 'Product', 'Qty', 'Remarks', 'Production Match'].map(l =>
              ce('th', { key: l, style: th }, l)
            )
          )
        ),
        ce('tbody', null,
          resultRows.map((row, i) => {
            const options = productionMap[row.import_product_code] || [];
            const selected = selections[row.id];
            const c = td(i % 2 === 1);
            const personVal = row[cfg.personField];

            return ce('tr', { key: row.id },

              ce('td', { style: c }, fmt(row[cfg.dateField])),

              ce('td', { style: c },
                ce('div', { style: { fontWeight: 600, fontSize: 12 } }, row.import_product_code || '-'),
                ce('div', { style: { fontSize: 11, color: '#888', marginTop: 2 } },
                  [row.product_name, row.sku_display].filter(Boolean).join(' — ')
                )
              ),

              ce('td', { style: { ...c, textAlign: 'right' } }, row.quantity ?? '-'),

              ce('td', { style: c },
                personVal
                  ? ce('div', { style: { fontSize: 11, color: '#555' } }, '👤 ' + personVal)
                  : null,
                cfg.flagBadge(row),
                row.remarks
                  ? ce('div', { style: { fontSize: 10, color: '#aaa', marginTop: 3 } }, row.remarks)
                  : null
              ),

              ce('td', { style: c },
                options.length === 0
                  ? ce('span', { style: { color: '#bbb', fontSize: 11, fontStyle: 'italic' } }, '— no active production found')
                  : options.map(opt => {
                      const isSel = selected === opt.id;
                      const wasLinked = row.fk_production_id === opt.id;
                      const validVariants = variantMap[opt.id] || new Set();
                      const invalidVariant = validVariants.size > 0 && !validVariants.has(String(row.fk_sku_option_id));

                      return ce('div', {
                        key: opt.id,
                        style: optBox(isSel),
                        onClick: () => toggleSelection(row.id, opt.id)
                      },
                        ce('input', {
                          type: 'checkbox', checked: isSel, readOnly: true,
                          style: { marginTop: 2, cursor: 'pointer', flexShrink: 0 }
                        }),
                        ce('div', { style: { flex: 1 } },
                          ce('div', { style: { display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 4 } },
                            ce('span', { style: { fontWeight: 600, fontSize: 12, color: '#166534' } },
                              opt.production_ref || ('ID: ' + opt.id)
                            ),
                            wasLinked
                              ? ce('span', { style: { color: '#3b82f6', fontSize: 10 } }, '(linked)')
                              : null,
                            invalidVariant
                              ? ce('span', { style: { background: '#fef2f2', color: '#dc2626', border: '1px solid #fca5a5', borderRadius: 3, padding: '1px 6px', fontSize: 10, fontWeight: 600 } }, '⚠ invalid variant')
                              : null
                          ),
                          ce('div', { style: { fontSize: 10, color: '#888', marginTop: 1 } },
                            [opt.konveksi_name, opt.product_name, opt.status].filter(Boolean).join(' · ')
                          ),
                          (opt.est_production_start || opt.est_production_finish)
                            ? ce('div', { style: { fontSize: 10, color: '#aaa', marginTop: 1 } },
                                [
                                  opt.est_production_start ? 'start ' + fmt(opt.est_production_start) : null,
                                  opt.est_production_finish ? 'finish ' + fmt(opt.est_production_finish) : null
                                ].filter(Boolean).join(' → ')
                              )
                            : null
                        )
                      );
                    })
              )
            );
          })
        )
      )
    ),

    ce('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginTop: 14, paddingTop: 10, borderTop: '1px solid #eee' } },
      ce('div', { style: { display: 'flex', flexDirection: 'column', gap: 2 } },
        ce('span', { style: { fontSize: 11, color: unmatched > 0 ? '#f59e0b' : '#22c55e' } },
          unmatched > 0 ? `⚠ ${unmatched} not yet matched` : `✓ All matched`
        ),
        hasInvalidSelections
          ? ce('span', { style: { fontSize: 11, color: '#dc2626' } },
              '✕ Fix invalid variant warnings before applying'
            )
          : null
      ),
      ce('div', { style: { display: 'flex', gap: 8 } },
        ce('button', {
          onClick: handleClose,
          style: { padding: '5px 14px', fontSize: 12, cursor: 'pointer', border: '1px solid #d9d9d9', borderRadius: 4, background: '#fff' }
        }, 'Cancel'),
        ce('button', {
          onClick: applyAll,
          disabled: applying || (cfg.hasDoneState && done) || hasInvalidSelections,
          style: { padding: '5px 16px', fontSize: 12, cursor: (applying || (cfg.hasDoneState && done) || hasInvalidSelections) ? 'not-allowed' : 'pointer', border: 'none', borderRadius: 4, fontWeight: 600, color: '#fff', background: (cfg.hasDoneState && done) ? '#86efac' : (applying || hasInvalidSelections) ? '#d9d9d9' : '#22c55e' }
        }, applying ? 'Applying…' : (cfg.hasDoneState && done) ? 'Done ✓' : 'Apply All Matching')
      )
    )
  );
}

// ─────────────────────────────────────────────────────
// ENTRY — fetch data for the given ids, then open the matcher modal.
// kind: 'production_result' (default) | 'qc_result'.
// ─────────────────────────────────────────────────────
async function openMatchModal(args) {
  const ctx = args.ctx, ids = args.ids, onDone = args.onDone;
  const kind = args.kind || 'production_result';
  const cfg = KIND_CONFIG[kind];
  if (!ctx) return;
  if (!cfg) { ctx.message.error('Unknown match kind: ' + kind); return; }
  if (!ids || !ids.length) { ctx.message.warning('Please select at least one ' + cfg.selectWarnLabel + ' record.'); return; }
  const data = await fetchMatchData(ctx, ids, cfg);
  Modal.confirm({
    title: cfg.modalTitle,
    width: 900,
    icon: null,
    content: ce(MatcherContent, { ctx: ctx, cfg: cfg, resultRows: data.resultRows, productionMap: data.productionMap, variantMap: data.variantMap, onDone: onDone }),
    okButtonProps: { style: { display: 'none' } },
    cancelButtonProps: { style: { display: 'none' } },
    maskClosable: true,
    onCancel() {},
  });
}

return { openMatchModal, fetchMatchData, applyMatches, KIND_CONFIG };
