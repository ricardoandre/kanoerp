// =====================================================
// ui_match_production — shared Match-Production logic + modal.
//
// Stored as a `source_code` row named 'ui_match_production'.
// Loaded via loadCode('ui_match_production'); compiled with
//   new Function('React','antd','dayjs','ctx', src)(React, antd, dayjs, ctx).
//
// WHAT IT DOES (identical behavior to the original JSAction):
//   • Reads production_result rows by id (import_product_code + variant already set,
//     fk_production_id may be null).
//   • For each import_product_code, finds candidate productions
//     (status NOT IN planning/done), ordered by est_production_finish.
//   • Auto-selects when exactly one candidate; otherwise keeps any existing link.
//   • Per-production variant validation: the row's fk_sku_option_id must be one of
//     the production's production_quantity_details variants, else "invalid variant".
//   • On Apply: UPDATE production_result.fk_production_id, then bump matched
//     productions cutting/production → qc.
//
// EXPORTS (contract):
//   openMatchModal({ ctx, ids, onDone })  — fetch + open the matcher modal.
//        onDone() is called after a successful apply (e.g. to refresh a list).
//   fetchMatchData(ctx, ids)              — { resultRows, productionMap, variantMap }.
//        Reused by ui_result_import / ui_result_bulk_add for pre-resolution.
//   applyMatches(ctx, selections)         — { ok, total }. Writes links + QC bump.
//        selections: { [resultId]: productionId|null }.
//
// Depends on: none. (ctx is threaded as a param so the CALLER's ctx is always used.)
// =====================================================
const { useState } = React;
const { Modal } = antd;
const ce = React.createElement;

// ── SQL helpers (ctx threaded so import/bulk-add/native all share) ──
async function runSql(ctx, uid, sql) {
  if (ctx.flowSettingsEnabled) {
    await ctx.sql.save({ uid, sql, dataSourceKey: 'main' }).catch(() => {});
  }
  return ctx.sql.runById(uid, { type: 'selectRows', dataSourceKey: 'main' }).then(r => r || []).catch(() => []);
}
async function execSql(ctx, uid, sql) {
  if (ctx.flowSettingsEnabled) {
    await ctx.sql.save({ uid, sql, dataSourceKey: 'main' }).catch(() => {});
  }
  return ctx.sql.runById(uid, { type: 'exec', dataSourceKey: 'main' }).catch(() => null);
}

function fmt(d) { return d ? String(d).substring(0, 10) : '-'; }

// ─────────────────────────────────────────────────────
// DATA LAYER — reusable. Returns the three maps the matcher (and import / bulk-add)
// need: result rows, candidate productions per import_product_code, valid-variant
// sets per production id.
// ─────────────────────────────────────────────────────
async function fetchMatchData(ctx, ids) {
  ids = (ids || []).filter(Boolean);
  if (!ids.length) return { resultRows: [], productionMap: {}, variantMap: {} };
  const idList = ids.map(id => "'" + id + "'").join(',');

  const resultRows = await runSql(ctx, 'pr_match_results',
    "SELECT production_result.id, production_result.import_product_code, " +
    "production_result.quantity, production_result.remarks, " +
    "production_result.shipment_date, production_result.checking_pic, " +
    "production_result.is_permakan, production_result.fk_production_id, " +
    "production_result.fk_sku_option_id, " +
    "sku_option.display AS sku_display, sku_option.sort AS sku_sort, " +
    "product.name AS product_name " +
    "FROM production_result " +
    "LEFT JOIN sku_option ON production_result.fk_sku_option_id = sku_option.id " +
    "LEFT JOIN product ON production_result.import_product_code = product.code " +
    "WHERE production_result.id IN (" + idList + ") " +
    "ORDER BY production_result.shipment_date, production_result.import_product_code, sku_option.sort"
  );

  const productCodes = [...new Set(resultRows.map(r => r.import_product_code).filter(Boolean))];
  const productionMap = {};
  for (const code of productCodes) {
    productionMap[code] = await runSql(ctx, 'pr_match_prod_' + code,
      "SELECT production.id, production.production_ref, production.status, " +
      "production.est_production_start, production.est_production_finish, " +
      "konveksi.name AS konveksi_name, konveksi.code AS konveksi_code, product.name AS product_name " +
      "FROM production, konveksi, product " +
      "WHERE production.fk_product_code = '" + code + "' " +
      "AND production.status <> 'planning' AND production.status <> 'done' " +
      "AND production.fk_konveksi_code = konveksi.code " +
      "AND production.fk_product_code = product.code " +
      "ORDER BY production.est_production_finish"
    );
  }

  const allProductionIds = Object.values(productionMap).flat().map(p => p.id);
  const variantMap = {};
  for (const prodId of allProductionIds) {
    const rows = await runSql(ctx, 'pr_match_var_' + prodId,
      "SELECT fk_sku_option_id FROM production_quantity_details WHERE fk_production_id = '" + prodId + "'"
    );
    variantMap[prodId] = new Set(rows.map(r => String(r.fk_sku_option_id)));
  }

  return { resultRows, productionMap, variantMap };
}

// ─────────────────────────────────────────────────────
// WRITE LAYER — link results + bump eligible productions to QC.
// ─────────────────────────────────────────────────────
async function applyMatches(ctx, selections) {
  const toUpdate = Object.entries(selections).filter(function (e) { return e[1] !== null && e[1] !== undefined; });
  let ok = 0;
  for (const pair of toUpdate) {
    const resultId = pair[0], prodId = pair[1];
    const res = await execSql(ctx, 'pr_upd_' + resultId,
      "UPDATE production_result SET fk_production_id = '" + prodId + "' WHERE id = '" + resultId + "'");
    if (res !== null) ok++;
  }
  const uniqueProdIds = [...new Set(toUpdate.map(function (e) { return e[1]; }))];
  for (const prodId of uniqueProdIds) {
    await execSql(ctx, 'pr_status_' + prodId,
      "UPDATE production SET status = 'qc' WHERE id = '" + prodId + "' AND status IN ('cutting', 'production')");
  }
  return { ok: ok, total: toUpdate.length };
}

// ─────────────────────────────────────────────────────
// MATCHER UI — presentation only; data + ctx come from props.
// ─────────────────────────────────────────────────────
function MatcherContent(props) {
  const ctx = props.ctx;
  const resultRows = props.resultRows || [];
  const productionMap = props.productionMap || {};
  const variantMap = props.variantMap || {};
  const onDone = props.onDone;

  const initSelections = {};
  resultRows.forEach(function (r) {
    const options = productionMap[r.import_product_code] || [];
    initSelections[r.id] = options.length === 1 ? options[0].id : (r.fk_production_id || null);
  });

  const [selections, setSelections] = useState(initSelections);
  const [applying, setApplying] = useState(false);
  const [done, setDone] = useState(false);

  function handleClose() { Modal.destroyAll(); }

  function toggleSelection(resultId, productionId) {
    setSelections(function (prev) {
      const next = Object.assign({}, prev);
      next[resultId] = prev[resultId] === productionId ? null : productionId;
      return next;
    });
  }

  async function applyAll() {
    const hasAny = Object.values(selections).some(function (v) { return v !== null; });
    if (!hasAny) { ctx.message.warning('No matches selected.'); return; }
    setApplying(true);
    const res = await applyMatches(ctx, selections);
    Modal.destroyAll();
    const failed = res.total - res.ok;
    if (failed === 0) {
      ctx.notification.success({
        message: 'Matching Complete',
        description: res.ok + ' production result(s) linked. Eligible productions moved to QC.',
        duration: 6,
      });
    } else {
      ctx.notification.warning({
        message: 'Matching Partial',
        description: res.ok + ' record(s) updated, ' + failed + ' failed. Please check and retry the failed rows.',
        duration: 8,
      });
    }
    if (onDone) onDone();
  }

  const matchedCount = Object.values(selections).filter(function (v) { return v !== null; }).length;
  const unmatched = resultRows.length - matchedCount;

  const hasInvalidSelections = resultRows.some(function (row) {
    const selectedProdId = selections[row.id];
    if (!selectedProdId) return false;
    const validVariants = variantMap[selectedProdId] || new Set();
    return validVariants.size > 0 && !validVariants.has(String(row.fk_sku_option_id));
  });

  const th = { background: '#fafafa', borderBottom: '2px solid #e8e8e8', padding: '7px 8px', fontWeight: 600, textAlign: 'left', fontSize: 11, color: '#555' };
  const td = function (alt) { return { borderBottom: '1px solid #f0f0f0', padding: '8px', verticalAlign: 'top', fontSize: 12, background: alt ? '#fafafa' : '#fff' }; };
  const optBox = function (sel) { return { display: 'flex', alignItems: 'flex-start', gap: 6, padding: '5px 6px', borderRadius: 4, marginBottom: 4, border: sel ? '1px solid #86efac' : '1px solid #e8e8e8', cursor: 'pointer', background: sel ? '#f0fdf4' : '#fff' }; };

  if (!resultRows.length) {
    return ce('div', { style: { fontFamily: 'system-ui,sans-serif', padding: '12px 0' } },
      ce('div', { style: { color: '#f59e0b', marginBottom: 16, fontSize: 13 } }, '⚠ No production result records could be loaded for the selected rows.'),
      ce('div', { style: { display: 'flex', justifyContent: 'flex-end' } },
        ce('button', { onClick: handleClose, style: { padding: '5px 14px', fontSize: 12, cursor: 'pointer', border: '1px solid #d9d9d9', borderRadius: 4, background: '#fff' } }, 'Close')));
  }

  return ce('div', { style: { fontFamily: 'system-ui,sans-serif', fontSize: 12 } },
    ce('div', { style: { color: '#888', fontSize: 11, marginBottom: 12 } }, resultRows.length + ' result(s) · ' + matchedCount + ' matched · ' + unmatched + ' unmatched'),
    ce('div', { style: { overflowX: 'auto' } },
      ce('table', { style: { width: '100%', borderCollapse: 'collapse', tableLayout: 'fixed' } },
        ce('colgroup', null,
          ce('col', { style: { width: '90px' } }), ce('col', { style: { width: '150px' } }),
          ce('col', { style: { width: '55px' } }), ce('col', { style: { width: '120px' } }),
          ce('col', { style: { width: 'auto' } })),
        ce('thead', null, ce('tr', null,
          ['Shipment Date', 'Product', 'Qty', 'Info', 'Production Match'].map(function (l) { return ce('th', { key: l, style: th }, l); }))),
        ce('tbody', null,
          resultRows.map(function (row, i) {
            const options = productionMap[row.import_product_code] || [];
            const selected = selections[row.id];
            const c = td(i % 2 === 1);
            return ce('tr', { key: row.id },
              ce('td', { style: c }, fmt(row.shipment_date)),
              ce('td', { style: c },
                ce('div', { style: { fontWeight: 600, fontSize: 12 } }, row.import_product_code || '-'),
                ce('div', { style: { fontSize: 11, color: '#888', marginTop: 2 } }, [row.product_name, row.sku_display].filter(Boolean).join(' — '))),
              ce('td', { style: Object.assign({}, c, { textAlign: 'right' }) }, row.quantity == null ? '-' : row.quantity),
              ce('td', { style: c },
                row.checking_pic ? ce('div', { style: { fontSize: 11, color: '#555' } }, '👤 ' + row.checking_pic) : null,
                row.is_permakan ? ce('span', { style: { display: 'inline-block', background: '#fef2f2', color: '#ef4444', border: '1px solid #fca5a5', borderRadius: 3, padding: '0 5px', fontSize: 10, fontWeight: 600, marginTop: 3 } }, 'PERMAK') : null,
                row.remarks ? ce('div', { style: { fontSize: 10, color: '#aaa', marginTop: 3 } }, row.remarks) : null),
              ce('td', { style: c },
                options.length === 0
                  ? ce('span', { style: { color: '#bbb', fontSize: 11, fontStyle: 'italic' } }, '— no active production found')
                  : options.map(function (opt) {
                      const isSel = selected === opt.id;
                      const wasLinked = row.fk_production_id === opt.id;
                      const validVariants = variantMap[opt.id] || new Set();
                      const invalidVariant = validVariants.size > 0 && !validVariants.has(String(row.fk_sku_option_id));
                      return ce('div', { key: opt.id, style: optBox(isSel), onClick: function () { toggleSelection(row.id, opt.id); } },
                        ce('input', { type: 'checkbox', checked: isSel, readOnly: true, style: { marginTop: 2, cursor: 'pointer', flexShrink: 0 } }),
                        ce('div', { style: { flex: 1 } },
                          ce('div', { style: { display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 4 } },
                            ce('span', { style: { fontWeight: 600, fontSize: 12, color: '#166534' } }, opt.production_ref || ('ID: ' + opt.id)),
                            wasLinked ? ce('span', { style: { color: '#3b82f6', fontSize: 10 } }, '(linked)') : null,
                            invalidVariant ? ce('span', { style: { background: '#fef2f2', color: '#dc2626', border: '1px solid #fca5a5', borderRadius: 3, padding: '1px 6px', fontSize: 10, fontWeight: 600 } }, '⚠ invalid variant') : null),
                          ce('div', { style: { fontSize: 10, color: '#888', marginTop: 1 } }, [opt.konveksi_name, opt.product_name, opt.status].filter(Boolean).join(' · ')),
                          (opt.est_production_start || opt.est_production_finish)
                            ? ce('div', { style: { fontSize: 10, color: '#aaa', marginTop: 1 } }, [opt.est_production_start ? 'start ' + fmt(opt.est_production_start) : null, opt.est_production_finish ? 'finish ' + fmt(opt.est_production_finish) : null].filter(Boolean).join(' → '))
                            : null)));
                    })));
          }))),
    ce('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginTop: 14, paddingTop: 10, borderTop: '1px solid #eee' } },
      ce('div', { style: { display: 'flex', flexDirection: 'column', gap: 2 } },
        ce('span', { style: { fontSize: 11, color: unmatched > 0 ? '#f59e0b' : '#22c55e' } }, unmatched > 0 ? ('⚠ ' + unmatched + ' not yet matched') : '✓ All matched'),
        hasInvalidSelections ? ce('span', { style: { fontSize: 11, color: '#dc2626' } }, '✕ Fix invalid variant warnings before applying') : null),
      ce('div', { style: { display: 'flex', gap: 8 } },
        ce('button', { onClick: handleClose, style: { padding: '5px 14px', fontSize: 12, cursor: 'pointer', border: '1px solid #d9d9d9', borderRadius: 4, background: '#fff' } }, 'Cancel'),
        ce('button', { onClick: applyAll, disabled: applying || done || hasInvalidSelections,
          style: { padding: '5px 16px', fontSize: 12, cursor: (applying || done || hasInvalidSelections) ? 'not-allowed' : 'pointer', border: 'none', borderRadius: 4, fontWeight: 600, color: '#fff', background: done ? '#86efac' : (applying || hasInvalidSelections) ? '#d9d9d9' : '#22c55e' } },
          applying ? 'Applying…' : done ? 'Done ✓' : 'Apply All Matching'))));
}

// ─────────────────────────────────────────────────────
// ENTRY — fetch data for the given ids, then open the matcher modal.
// ─────────────────────────────────────────────────────
async function openMatchModal(args) {
  const ctx = args.ctx, ids = args.ids, onDone = args.onDone;
  if (!ctx) return;
  if (!ids || !ids.length) { ctx.message.warning('Please select at least one production result record.'); return; }
  const data = await fetchMatchData(ctx, ids);
  Modal.confirm({
    title: 'Match Production Results → Production',
    width: 900,
    icon: null,
    content: ce(MatcherContent, { ctx: ctx, resultRows: data.resultRows, productionMap: data.productionMap, variantMap: data.variantMap, onDone: onDone }),
    okButtonProps: { style: { display: 'none' } },
    cancelButtonProps: { style: { display: 'none' } },
    maskClosable: true,
    onCancel() {},
  });
}

return { openMatchModal, fetchMatchData, applyMatches };
