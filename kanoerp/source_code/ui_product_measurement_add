}

async function createProductMeasurement(form) {
  const pmRes = await ctx.api.resource('product_measurement').create({ values: { name: form.name, remarks: form.remarks || '' } });
  const pmId = extractId(pmRes);
  if (!pmId) throw new Error('Failed to create product measurement');
  for (const row of form.gridRows) {
    const values = Object.assign({}, row.values, { sku_option: { id: row.sku_id }, fk_product_measurement_variant_id: pmId });
    await ctx.api.resource('product_measurement_variant').create({ values });
  }
  for (const code of form.selectedProducts) {
    await ctx.api.resource('product').update({ filterByTk: code, values: { fk_product_measurement_id: pmId } });
  }
  return pmId;
}

// =====================================================
// SHARED FORM BODY — self-contained (owns its own Cancel/Create buttons), so
// it drops into either a Drawer (jblock) or Modal.confirm content (standalone
// JSAction) unchanged. props: onClose(), onCreated(newId), resetSignal (any
// value that changes to trigger a field reset — the Drawer passes its `open`
// flag; the Modal.confirm caller can pass a constant since it's freshly
// mounted per open anyway).
// =====================================================
function NewMeasurementFormBody(props) {
  const onClose = props.onClose, onCreated = props.onCreated;

  const sName = useState('');       const name = sName[0];           const setName = sName[1];
  const sRemarks = useState('');    const remarks = sRemarks[0];     const setRemarks = sRemarks[1];
  const sResetKey = useState(0);    const resetKey = sResetKey[0];   const setResetKey = sResetKey[1];
  const sOpts = useState([]);       const prodOpts = sOpts[0];       const setProdOpts = sOpts[1];
  const sSku = useState([]);        const skuOptions = sSku[0];      const setSkuOptions = sSku[1];
  const sSel = useState([]);        const selected = sSel[0];        const setSelected = sSel[1];
  const sLoadingV = useState(false);const loadingVariants = sLoadingV[0]; const setLoadingV = sLoadingV[1];
  const sVarInfo = useState({ ok: true, productCodes: [], missingByProduct: {} }); const variantInfo = sVarInfo[0]; const setVariantInfo = sVarInfo[1];
  const sExisting = useState([]);   const existingInfo = sExisting[0]; const setExistingInfo = sExisting[1];
  const sGrid = useState([]);       const gridRows = sGrid[0];       const setGridRows = sGrid[1];
  const sAddSkus = useState([]);    const addSkuIds = sAddSkus[0];   const setAddSkuIds = sAddSkus[1];
  const sOverwrite = useState(false); const overwriteOk = sOverwrite[0]; const setOverwriteOk = sOverwrite[1];
  const sBusy = useState(false);    const busy = sBusy[0];           const setBusy = sBusy[1];
  const sActive = useState(null);   const activeCell = sActive[0];   const setActiveCell = sActive[1];

  useEffect(function () { fetchProductOptions().then(setProdOpts).catch(() => {}); fetchSkuOptions().then(setSkuOptions).catch(() => {}); }, []);

  // reset the whole form every time resetSignal changes (Drawer: on open; Modal: once on mount)
  useEffect(function () {
    setName(''); setRemarks(''); setSelected([]); setGridRows([]);
    setVariantInfo({ ok: true, productCodes: [], missingByProduct: {} }); setExistingInfo([]);
    setAddSkuIds([]); setOverwriteOk(false); setBusy(false); setActiveCell(null);
    setResetKey(k => k + 1);
  }, [props.resetSignal]);

  function handleNameBlur() {
    if (!prodOpts.length) return;
    const candidates = parseCandidateCodesFromName(name);
    if (!candidates.length) return;
    const validCodes = candidates.filter(c => prodOpts.some(p => p.code === c));
    if (!validCodes.length) return;
    setSelected(prev => Array.from(new Set(prev.concat(validCodes))));
  }

  useEffect(function () {
    if (!selected.length) { setExistingInfo([]); setVariantInfo({ ok: true, productCodes: [], missingByProduct: {} }); return; }
    setLoadingV(true);
    Promise.all([fetchVariantsForProducts(selected), fetchProductMeasurementInfo(selected)]).then(function (results) {
      const vRows = results[0]; const exRows = results[1];
      setExistingInfo(exRows);
      const info = computeVariantInfo(vRows);
      setVariantInfo(info);
      setGridRows(function (prev) {
        const existingIds = new Set(prev.map(r => r.sku_id));
        const toAdd = info.unionSizes.filter(s => !existingIds.has(s.sku_id));
        if (!toAdd.length) return prev;
        const merged = prev.concat(toAdd.map(s => ({ sku_id: s.sku_id, sku_display: s.sku_display, sku_sort: s.sku_sort, values: emptyValues() })));
        merged.sort((a, b) => a.sku_sort - b.sku_sort);
        return merged;
      });
    }).catch(function (e) { ctx.message.error('Failed to load variants: ' + ((e && e.message) || e)); }).finally(function () { setLoadingV(false); });
  }, [selected]);

  const overwriteList = useMemo(() => existingInfo.filter(e => e.existing_id != null), [existingInfo]);
  const overwriteCount = overwriteList.length;
  const availableSkuOptions = useMemo(() => skuOptions.filter(s => !gridRows.some(r => r.sku_id === s.id)), [skuOptions, gridRows]);

  function setCell(skuId, key, val) { setGridRows(prev => prev.map(r => r.sku_id === skuId ? Object.assign({}, r, { values: Object.assign({}, r.values, { [key]: val }) }) : r)); }
  function removeRow(skuId) { setGridRows(prev => prev.filter(r => r.sku_id !== skuId)); }
  function handleAddSizes() {
    if (!addSkuIds.length) return;
    setGridRows(prev => {
      const existingIds = new Set(prev.map(r => r.sku_id));
      const toAdd = addSkuIds.filter(id => !existingIds.has(id)).map(id => skuOptions.find(s => s.id === id)).filter(Boolean)
        .map(opt => ({ sku_id: opt.id, sku_display: opt.display, sku_sort: opt.sort, values: emptyValues() }));
      if (!toAdd.length) return prev;
      const merged = prev.concat(toAdd); merged.sort((a, b) => a.sku_sort - b.sku_sort); return merged;
    });
    setAddSkuIds([]);
  }

  function applyPastedGrid(text, anchorRowIdx, anchorColIdx) {
    const lines = text.replace(/\r/g, '').split('\n');
    while (lines.length && lines[lines.length - 1] === '') lines.pop();
    if (!lines.length) return;
    setGridRows(prev => {
      const next = prev.map(r => Object.assign({}, r, { values: Object.assign({}, r.values) }));
      lines.forEach(function (line, r) {
        const rowIdx = anchorRowIdx + r; if (rowIdx < 0 || rowIdx >= next.length) return;
        line.split('\t').forEach(function (cell, c) {
          const colIdx = anchorColIdx + c; if (colIdx < 0 || colIdx >= PASTE_COLUMNS.length) return;
          const trimmed = cell.trim(); if (trimmed === '') return;
          const num = parseFloat(trimmed.replace(',', '.')); if (!isNaN(num)) next[rowIdx].values[PASTE_COLUMNS[colIdx].key] = num;
        });
      });
      return next;
    });
  }
  function handleGridPaste(e) {
    if (!activeCell) return;
    const text = e.clipboardData && e.clipboardData.getData ? e.clipboardData.getData('text/plain') : ''; if (!text) return;
    e.preventDefault();
    const rowIdx = gridRows.findIndex(r => r.sku_id === activeCell.skuId);
    const colIdx = PASTE_COLUMNS.findIndex(f => f.key === activeCell.colKey);
    if (rowIdx === -1 || colIdx === -1) return;
    applyPastedGrid(text, rowIdx, colIdx);
    ctx.message.success('Pasted.');
  }

  async function handleSave() {
    if (!name || !name.trim()) return ctx.message.warning('Enter a name.');
    if (!selected.length) return ctx.message.warning('Select at least one product.');
    if (!gridRows.length) return ctx.message.warning('Add at least one size to the grid.');
    if (overwriteCount > 0 && !overwriteOk) return ctx.message.warning('Confirm the overwrite checkbox — some products already have a measurement set linked.');
    setBusy(true);
    try {
      const newId = await createProductMeasurement({ name: name.trim(), remarks: remarks, gridRows, selectedProducts: selected });
      ctx.notification.success({ message: 'Product Measurement Created', description: 'Created 1 measurement set (' + gridRows.length + ' size row(s)), linked to ' + selected.length + ' product(s).', duration: 6 });
      if (onCreated) onCreated(newId);
    } catch (e) { setBusy(false); ctx.message.error('Save failed: ' + ((e && e.message) || e)); return; }
    setBusy(false);
  }

  const productLabel = code => { const p = prodOpts.find(x => x.code === code); return (p && p.name) ? (code + ' — ' + p.name) : code; };
  const mismatchBody = !variantInfo.ok ? ce('div', { style: { display: 'flex', flexDirection: 'column', gap: 6 } },
    ce('div', null, "Selected products don't all share the same sizes — the grid below shows every size across all of them (combined). This won't block saving."),
    variantInfo.productCodes.filter(pc => variantInfo.missingByProduct[pc]).map(pc => ce('div', { key: pc, style: { fontSize: 12 } }, ce('b', null, productLabel(pc)), ' is missing: ', variantInfo.missingByProduct[pc].join(', ')))) : null;
  const overwriteBody = overwriteCount > 0 ? ce('div', { style: { display: 'flex', flexDirection: 'column', gap: 6 } },
    overwriteList.map(e => ce('div', { key: e.code, style: { fontSize: 12 } }, ce('b', null, productLabel(e.code)), ' already linked to "', e.existing_name || e.existing_id, '"')),
    ce(Checkbox, { checked: overwriteOk, onChange: ev => setOverwriteOk(ev.target.checked) }, 'I understand saving will re-link those product(s) to the new set.')) : null;

  const sizeColumn = { title: 'Size', dataIndex: 'sku_display', key: 'sku_display', fixed: 'left', width: 88, onCell: () => ({ className: 'pms-size-cell' }), render: v => ce('span', { style: { fontWeight: 700 } }, v) };
  const removeColumn = { title: '', key: '_remove', width: 28, fixed: 'right', render: (_, record) => ce('button', { onClick: () => removeRow(record.sku_id), title: 'Remove size', style: { border: 'none', background: 'transparent', color: '#cbd5e1', cursor: 'pointer', fontSize: 12 } }, '✕') };
  const fieldColumns = MEASURE_FIELDS.map(f => ({
    title: ce('div', { style: { display: 'flex', flexDirection: 'column', alignItems: 'center', lineHeight: 1.25 } }, ce('div', { style: { fontWeight: 700, fontSize: 10, color: '#334155' } }, f.primary), ce('div', { style: { fontSize: 9, color: '#94a3b8', fontWeight: 500 } }, '(' + f.secondary + ')')),
    dataIndex: ['values', f.key], key: f.key, width: 90,
    render: (v, record) => ce(InputNumber, { size: 'small', controls: false, value: record.values[f.key], onChange: val => setCell(record.sku_id, f.key, val), style: { width: '100%' }, min: 0, onFocus: () => setActiveCell({ skuId: record.sku_id, colKey: f.key }) }),
  }));
  const gridColumns = [sizeColumn].concat(fieldColumns).concat([removeColumn]);

  return ce(React.Fragment, null,
    ce(PmsStyles, null),
    ce('div', { style: { fontFamily: 'system-ui,sans-serif', fontSize: 13, display: 'flex', flexDirection: 'column', gap: 14 } },
