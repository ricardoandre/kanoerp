// ui_product_measurement_add — "New Product Measurement" — form body reused
// two ways:
//   - ProductMeasurementNewDrawer({open,onClose,onCreated}) — Drawer, for
//     mounting inside an existing React tree (e.g. our list-engine jblock,
//     which already establishes one via ctx.render()).
//   - openModal({ctx,onSaved}) — Modal.confirm, for STANDALONE use from a
//     bare JSAction (e.g. attached to the native NocoBase table toolbar),
//     which has no React tree of its own to mount a Drawer into. This is the
//     validated sandbox pattern for that case — do not try to mount a Drawer
//     directly from a JSAction, and never nest Drawer inside Modal.confirm.
//
// Stored as a `source_code` row named 'ui_product_measurement_add'.
//
// SCHEMA / design notes: product_measurement is the named set (name,
// remarks/richText), product_measurement_variant is one row per size (16
// numeric columns + sku_option), product links to the set via
// fk_product_measurement_id. Sizes are decoupled from product_variant:
// selecting products SUGGESTS sizes (union of their variants, with a
// non-blocking warning on mismatch) but sizes can be added/removed by hand.
//
// Reads go through ctx.api.resource() (fetchAllPages/fetchByIn), not raw
// ctx.sql — ctx.sql.save() is admin/root-gated and silently fails for
// non-admin roles.
//
// EXPORTS: { ProductMeasurementNewDrawer, openModal }
//
// Depends on: none.
const { useState, useEffect, useMemo, useRef } = React;
