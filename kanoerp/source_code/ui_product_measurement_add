// ── minimal rich-text editor for remarks — contentEditable + document.execCommand. ──
function RichTextEditor(props) {
  const ref = useRef(null); const seeded = useRef(false);
  useEffect(function () { seeded.current = false; }, [props.resetKey]);
  useEffect(function () { if (ref.current && !seeded.current) { ref.current.innerHTML = props.value || ''; seeded.current = true; } });
  function exec(cmd) { if (ref.current) ref.current.focus(); try { document.execCommand(cmd, false, null); } catch (e) {} if (ref.current) props.onChange(ref.current.innerHTML); }
  function handleInput() { if (ref.current) props.onChange(ref.current.innerHTML); }
  const btn = (cmd, label, title) => ce('button', { key: cmd, title: title, onMouseDown: e => e.preventDefault(), onClick: () => exec(cmd) }, label);
