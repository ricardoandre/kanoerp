// ── entry point 1: Drawer, for mounting inside an existing React tree (jblock) ──
function ProductMeasurementNewDrawer(props) {
  const bodyNode = ce(NewMeasurementFormBody, { onClose: props.onClose, onCreated: props.onCreated, resetSignal: props.open });
  if (props.DrawerShell) {
    return ce(props.DrawerShell, {
      open: props.open, onClose: props.onClose, title: 'New Product Measurement',
      width: 1080, placement: 'right', rootClassName: 'pmm-form-drawer',
    }, bodyNode);
  }
  return ce(Drawer, {
    open: props.open, title: 'New Product Measurement', placement: 'right', onClose: props.onClose, rootClassName: 'pmm-form-drawer',
  }, bodyNode);
}

// ── entry point 2: Modal.confirm, for STANDALONE use — e.g. a JSAction
// attached to the native NocoBase table toolbar, which has no React tree of
// its own to mount a Drawer into. Call as PM.openModal({ ctx, onSaved }). ──
function openModal(args) {
  const onSaved = args && args.onSaved;
  Modal.confirm({
    title: 'New Product Measurement',
    width: 1040,
    icon: null,
    content: ce(NewMeasurementFormBody, {
      resetSignal: true,
      onClose: () => Modal.destroyAll(),
      onCreated: (newId) => { Modal.destroyAll(); if (onSaved) onSaved(newId); },
    }),
    okButtonProps: { style: { display: 'none' } },
    cancelButtonProps: { style: { display: 'none' } },
    maskClosable: true,
    onCancel() {},
  });
}

return { ProductMeasurementNewDrawer, openModal, NewMeasurementFormBody };
