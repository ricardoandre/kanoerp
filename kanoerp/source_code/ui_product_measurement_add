];
const PASTE_COLUMNS = MEASURE_FIELDS;
function emptyValues() { return MEASURE_FIELDS.reduce((acc, f) => { acc[f.key] = null; return acc; }, {}); }

function computeVariantInfo(rows) {
  const byProduct = {}; const unionMap = {};
  rows.forEach(r => { (byProduct[r.product_code] = byProduct[r.product_code] || []).push(r); unionMap[r.sku_id] = { sku_id: r.sku_id, sku_display: r.sku_display, sku_sort: r.sku_sort }; });
  const productCodes = Object.keys(byProduct);
  const unionSizes = Object.values(unionMap).sort((a, b) => a.sku_sort - b.sku_sort);
  const missingByProduct = {}; let ok = true;
  productCodes.forEach(pc => { const have = new Set(byProduct[pc].map(x => x.sku_id)); const missing = unionSizes.filter(s => !have.has(s.sku_id)); if (missing.length) { ok = false; missingByProduct[pc] = missing.map(m => m.sku_display); } });
  return { ok, byProduct, productCodes, unionSizes, missingByProduct };
}

