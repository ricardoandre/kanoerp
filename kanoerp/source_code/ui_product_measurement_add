// ── resource-based read helpers (non-admin-safe, scales past page limits) ──
const DEFAULT_PAGE_SIZE = 1000;
function fetchAllPages(resourceName, params) {
  const pageSize = (params && params.pageSize) || DEFAULT_PAGE_SIZE;
  function loadPage(page, acc) {
    return ctx.api.resource(resourceName).list(Object.assign({}, params, { pageSize: pageSize, page: page }))
      .then(function (res) {
        const rows = (res && res.data && res.data.data) || [];
        const merged = acc.concat(rows);
        if (rows.length < pageSize) return merged;
        return loadPage(page + 1, merged);
      });
  }
  return loadPage(1, []);
}
function chunk(arr, size) { const out = []; for (let i = 0; i < arr.length; i += size) out.push(arr.slice(i, i + size)); return out; }
function uniqVals(a) { const out = [], seen = {}; a.forEach(x => { if (x == null) return; const k = String(x); if (!seen[k]) { seen[k] = 1; out.push(x); } }); return out; }
function fetchByIn(resourceName, field, values, params) {
  const values2 = uniqVals(values);
  if (!values2.length) return Promise.resolve([]);
  const batches = chunk(values2, 150);
  return batches.reduce(function (p, batch) {
    return p.then(function (acc) {
      const filter = Object.assign({}, (params && params.filter) || {});
      filter[field] = { $in: batch };
      return fetchAllPages(resourceName, Object.assign({}, params, { filter: filter })).then(rows => acc.concat(rows));
    });
  }, Promise.resolve([]));
}
function extractId(res) { return (res && res.data && res.data.data && res.data.data.id) || (res && res.data && res.data.id); }
const fieldLabel = t => ce('div', { style: { fontSize: 11, fontWeight: 600, color: '#6b7280', marginBottom: 4, textTransform: 'uppercase', letterSpacing: '0.04em' } }, t);

// ── belongsTo relation resolution (same pattern used across the codebase) ──
const _relsCache = {};
function getRels(collection) {
  if (_relsCache[collection]) return Promise.resolve(_relsCache[collection]);
  return fetchAllPages('fields', { filter: { collection_name: collection, type: 'belongsTo' }, fields: ['name', 'options'] })
    .then(function (rows) {
      const byFk = {};
      (rows || []).forEach(function (r) {
        let opt = r.options || {}; if (typeof opt === 'string') { try { opt = JSON.parse(opt); } catch (e) { opt = {}; } }
        if (opt.foreignKey) byFk[opt.foreignKey] = { field: r.name, targetKey: opt.targetKey || 'id' };
      });
      _relsCache[collection] = byFk;
      return byFk;
    }).catch(function () { _relsCache[collection] = {}; return {}; });
}
function assocFragment(rels, fkColumn, value) {
  const rel = rels[fkColumn];
  const out = {};
  if (rel && value != null) { out[rel.field] = {}; out[rel.field][rel.targetKey] = value; }
  else { out[fkColumn] = value; }
  return out;
}

function fetchProductOptions() { return fetchAllPages('product', { fields: ['code', 'name'], sort: ['name'] }); }
function fetchSkuOptions() { return fetchAllPages('sku_option', { fields: ['id', 'display', 'sort'], sort: ['sort'] }); }

function fetchVariantsForProducts(codes) {
  if (!codes.length) return Promise.resolve([]);
  return fetchByIn('product_variant', 'fk_product_code', codes, { fields: ['id', 'fk_product_code'], appends: ['sku_option'] })
    .then(rows => rows.map(r => { const sk = r.sku_option || {}; return { product_code: r.fk_product_code, sku_id: sk.id, sku_display: sk.display || '—', sku_sort: sk.sort || 0 }; }));
}
function fetchProductMeasurementInfo(codes) {
  if (!codes.length) return Promise.resolve([]);
  return fetchAllPages('product', { filter: { code: { $in: codes } }, fields: ['code', 'fk_product_measurement_id'] })
    .then(function (prodRows) {
      const linkedIds = uniqVals(prodRows.map(p => p.fk_product_measurement_id).filter(Boolean));
      if (!linkedIds.length) return prodRows.map(p => ({ code: p.code, existing_id: null, existing_name: null }));
      return fetchAllPages('product_measurement', { filter: { id: { $in: linkedIds } }, fields: ['id', 'name'] }).then(function (pmRows) {
        const nameById = {}; pmRows.forEach(pm => { nameById[String(pm.id)] = pm.name; });
        return prodRows.map(p => ({ code: p.code, existing_id: p.fk_product_measurement_id, existing_name: p.fk_product_measurement_id ? nameById[String(p.fk_product_measurement_id)] : null }));
      });
    });
}

// ── "BASE/suffix" name -> candidate product codes, e.g. "O420005/06" ->
// O420005, O420006. Purely a suggestion — never overrides manual edits. ──
function parseCandidateCodesFromName(name) {
  const raw = String(name || '').trim();
  if (!raw) return [];
  const parts = raw.split('/').map(p => p.trim()).filter(Boolean);
  if (!parts.length) return [];
  const base = parts[0];
  const codes = [base];
  for (let i = 1; i < parts.length; i++) {
    const suf = parts[i];
    if (!/^[0-9A-Za-z]+$/.test(suf) || suf.length >= base.length) continue;
    codes.push(base.slice(0, base.length - suf.length) + suf);
  }
  return Array.from(new Set(codes));
}

